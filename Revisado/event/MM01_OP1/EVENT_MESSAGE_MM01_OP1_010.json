{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_OP1_010.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "...É, sem sucesso."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Pensei que talvez este lugar... mas a decadência é a mesma."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hum, ainda pode ser possível..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Você viajou de longe até aqui?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Sim. Então... deu pra perceber?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x5f,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Eu sabia! Tem uns traços ocidentais no seu jeito de falar."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Entendi. Então você já é familiarizado com isso?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x61,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Um pouco... Eu também costumo ir lá pra fazer negócios. Alías, bem-vindo ao fim do mundo."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Ao fim de mundo? Que nada. Esse lugar é bem farto."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Tem razão... Nos últimos anos, o clima tem sido calmo e agradável."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Mas alguns canais de água das cidades secaram, o que torna muito difícil atender a todos os meus pedidos de grãos."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "O solo está se tornando cada vez menos fértil. É por isso que eu vivo correndo pra lá e pra cá com essas entregas."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Hum, desculpe incomodá-lo quando você já está tão ocupado com seus próprios negócios."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x67,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Ah, imagina. É chato viajar sozinho,<CR>então a sua companhia até me deixa mais alegre."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x65,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Ainda falta bastante para chegarmos à próxima ruína,<CR>então aproveite a viagem."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Tá vendo ali? Aquela ruína depois do ateliê é a que você está procurando."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Meu destino, na verdade, é naquele ateliê. É uma loja de produtos medicinais administrada por uma jovem..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Hum? Um ateliê?<CR>Então essas coisas ainda existem por aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "...Ah, pode me deixar aqui mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Hã? Mas ainda estamos bem longe da ruína."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Não tem problema. Prefiro ir até lá com minhas próprias pernas."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Ir com as próprias pernas... Como era de se esperar de um estudioso, eu acho."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Estudioso? É o que eu pareço ser?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x125,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Ah! Desculpa, acho que me enganei. Já que você está investigando as ruínas eu..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x12,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Você não passou longe.<CR>Mas eu sou... um alquimista."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x12,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Um alquimista...?"
        }
    ]
}