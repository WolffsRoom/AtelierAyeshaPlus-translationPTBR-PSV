{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_OP1_510.ebm",
    "nb_messages": 0x1b,
    "messages": [
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "unknown2": 0x1,
            "msg_string": "...Pronto. Finalmente tirei toda a fuligem. Já pode abrir os olhos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "Hehe, obrigada."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ficar coberta de fuligem vai acabar com a sua fofura."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Nossa, você sempre fala essas coisas... Fico envergonhada toda vez que me chama de fofa..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a4,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah! Hmm, aqui tá o remédio que você pediu."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Um, dois, três... É, tá tudo aqui. Obrigado, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ah, na verdade… Eu também tenho um favor pra te pedir..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Sério? O que seria?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Bom, depois que eu mandei esse pedido, eu recebi um a mais."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Posso te pedir mais um frasco?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Claro! Se for só um frasco não vai demorar tanto assim."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0xb,
            "msg_string": "Ah… Mas talvez eu precise de mais ingredientes..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Beleza! Vou lá fora pegar uns rapidinho!"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Se precisar descobrir o que fazer em seguida, confira as Notas no menu."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Quando as suas Notas forem atualizadas, você vai ver um aviso assim. Quando não souber o que fazer, dê uma olhada nas Notas."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Além disso, informações como tarefas, boatos e panfletos também vão ficar registradas em uma lista nas suas Notas."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Tarefas podem ter uma recompensa e um prazo definidos. Quando o prazo passar, sua recompensa vai diminuir, então tome cuidado."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Também dá pra checar os detalhes das tarefas que você já completou no Histórico."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Para mais informações detalhadas, por favor dê uma olhada na Ajuda, na Biblioteca."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode abrir o menu do sistema direto do mapa mundi ao acessar o diário no cenário."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode mudar a música de fundo da batalha e do Atelier no menu de sistema."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Na cidade, você pode usar a opção de \"Descansar\". Descansar vai recuperar seu PV e PM."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Para mais informações detalhadas, por favor dê uma olhada na Ajuda, na Biblioteca."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode ver as artes do jogo no Álbum, dentro do menu."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "No começo, todas as artes ficam escondidas e não podem ser vistas."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Cada painel pode ser desbloqueado ao completar uma missão."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Se você desbloquear todos os painéis, vai receber um bônus especial."
        }
    ]
