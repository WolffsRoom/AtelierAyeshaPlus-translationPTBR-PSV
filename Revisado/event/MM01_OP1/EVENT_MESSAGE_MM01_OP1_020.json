{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_OP1_020.ebm",
    "nb_messages": 0x2e,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x0,
            "msg_string": "Hmm… isso e mais aquilo, misturar esse pó pra dar um cheirinho bom, e..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Isso parece bom! Quando o líquido ficar dourado aí..."
        },
        {
            "type": 0x3,
            "voice_id": 0x205,
            "name_id": 0x12,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "msg_string": "Oink muuuu...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ops! Foi mal, Pana. Esqueci de te dar o café da manhã."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Pega! Desculpa te fazer esperar!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Mastigue direito e coma devagar. Não faz bem comer tão rápido assim."
        },
        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x21c,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "Oink muuuu!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Ahhh... o sol tá tão gostoso e quentinho! Acho que vou aproveitar e lavar a roupa..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x8,
            "msg_string": "Mas antes disso... eu também tô com fome. Fiquei tão ocupada que até esqueci de comer."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x9,
            "msg_string": "Hmm… isso não é bom. Preciso me cuidar melhor."
        },
        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x21e,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "Oink muu!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15d,
            "expr_id": 0x5,
            "msg_id": 0xb,
            "msg_string": "O que eu vou comer? Já está tarde pro café, então acho melhor juntar com o almoço..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0x5,
            "msg_id": 0xc,
            "msg_string": "Será que eu tenho um ovo pra comer com o resto da sopa de ontem?"
        },
        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x217,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "Oink muuuuuu!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "O que foi, Pana? Estou pensando no que comer, então fica quietinha..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Ah! Eu ainda estava no meio de uma síntese. Que bom que eu lembrei."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Tenho que terminar isso antes do almoço. Beleza, vou fazer tudo junto na hora de almoçar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Ahh, tá aberto! Pode entrar."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x1,
            "msg_string": "Oi, Ayesha... Oxii!? Isso é...!?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Oiwh, udo beWm Ewnie!?<CR>(Oii, tudo bem Ewnie!?)"
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "Ahhm… aqui pelo visto sempre é cheio de fumaça e cheiroso, mas comer enquanto faz uma síntese não é muito certo…"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "Fow maw! lu tava com muida fomh...<CR>(Foi mal! Eu tava com muita fome...)"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "*glup*... Uhmm, que delícia! O remédio que você encomendou já vai ficar pronto..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "Então… espera só mais um pouquinho, tá?"
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "unknown2": 0x1,
            "msg_string": "É… tá. Valeu. Mas parece que tá rolando uma coisa séria dentro desse caldeirão..."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "unknown2": 0x1,
            "msg_string": "Tem certeza de que você devia estar tão calma com isso?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Ah…eu não tô! Pode não parecer, mas tô quase surtando aqui."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "Se eu não agilizar, isso pode dar ruim."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "unknown2": 0x1,
            "msg_string": "C-Como você deixou chegar nesse ponto...?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "unknown2": 0x1,
            "msg_string": "Bom… enquanto eu tava fazendo a síntese, a Pana me lembrou de dar comida pra ela."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "unknown2": 0x1,
            "msg_string": "E quando eu tava preparando a comidinha dela, me distrai vendo o quanto o tempo tava bom..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "unknown2": 0x1,
            "msg_string": "Aí comecei a pensar se eu devia lavar roupa, ou comer alguma coisa primeiro..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "unknown2": 0x1,
            "msg_string": "Nisso, quando fui ver… já tava saindo um monte de fumaça do caldeirão."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "unknown2": 0x1,
            "msg_string": "Ah, agora entendi. A gente precisa se apressar e fazer alguma coisa!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "unknown2": 0x1,
            "msg_string": "Você tem razão! Hmm, o que eu tava fazendo antes de dar comida pra Pana?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "unknown2": 0x1,
            "msg_string": "Eu joguei todos os ingredientes necessários lá dentro..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x24,
            "unknown2": 0x1,
            "msg_string": "É isso aí! O remédio tava começando a ficar dourado."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "unknown2": 0x1,
            "msg_string": "Agora, pra neutralizar ele, o próximo passo, eu preciso de... Vich, onde eu deixei?"
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x26,
            "unknown2": 0x1,
            "msg_string": "Ayesha, anda logo! Acho que isso não era pra estar cheirando desse jeito."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x27,
            "unknown2": 0x1,
            "msg_string": "Ainda tá tudo bem. Isso é super normal."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x28,
            "unknown2": 0x1,
            "msg_string": "Hehehe, vou só dar mais uma mordidinha."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x29,
            "unknown2": 0x1,
            "msg_string": "Ei! isso é falta de educação! Tipo… nenhuma comida fica apetitosa com esse cheiro no ar, concorda?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2a,
            "unknown2": 0x1,
            "msg_string": "Nãw, biso naw é bedadew!<CR>(Não, isso não é verdade!)"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2b,
            "unknown2": 0x1,
            "msg_string": "*glup*, *glup*… Só mais um pouquinho... Mexer só mais um tico já deve servir."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2c,
            "unknown2": 0x1,
            "msg_string": "Mexe, mexe… Prontinho!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2d,
            "unknown2": 0x1,
            "msg_string": "*cof* *cof* Tá pronto!"
        }
    ]
}