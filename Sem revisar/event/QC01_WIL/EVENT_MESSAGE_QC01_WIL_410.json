            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, é? Eu tenho um monte de coisas que são úteis pra alquimistas."
