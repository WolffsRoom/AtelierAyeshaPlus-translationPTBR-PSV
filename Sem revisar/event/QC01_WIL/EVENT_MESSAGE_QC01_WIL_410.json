            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Não. Essa loja é minha! Eu vendo as coisas que eu consigo nas minhas viagens ou fazendo outros trabalhos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Entendi. Uaaau... Você tem um monte de coisas que... eu nem sei o que são."
