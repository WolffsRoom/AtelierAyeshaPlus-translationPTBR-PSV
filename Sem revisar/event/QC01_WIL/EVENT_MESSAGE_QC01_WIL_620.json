        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf7,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Tenho certeza que o chefe toparia se desse pra notar fácil que é um grande tesouro."
