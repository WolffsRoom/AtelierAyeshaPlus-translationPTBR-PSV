        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a6,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Aham. Tipo aqueles das ruínas.<CR>Por exemplo, esse aqui."
