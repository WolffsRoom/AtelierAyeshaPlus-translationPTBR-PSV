        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1c2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Saquei... Só por curiosidade, quanto custaria esse?"
