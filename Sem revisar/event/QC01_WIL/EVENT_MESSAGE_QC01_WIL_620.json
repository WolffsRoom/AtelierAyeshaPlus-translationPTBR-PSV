        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "A gente divide a grana meio a meio,<CR>então você vem comigo."
