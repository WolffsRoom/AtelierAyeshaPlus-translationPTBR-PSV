        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "(Ixi, acho que isso vai acabar em...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Bell, acabei de lembrar que tenho um negócio pra fazer, então já vou indo..."
