        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Vamos ver... O chefe curte muito esse tipo de coisa, então seria pelo menos um milhão de Cole..."
