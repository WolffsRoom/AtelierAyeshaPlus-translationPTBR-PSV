{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_WIL_120.ebm",
    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ei, que tipo de pessoa... é a sua<CR>tataravó?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x169,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Tataravó? Bom, ela é muito legal e bonita, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x16b,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ela é super assustadora quando tá brava."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Parecia mesmo, mas ela é tão assustadora assim?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "É... Digo, ela consegue controlar o tempo e o espaço livremente."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Hã!? Como assim!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Significa exatamente o que parece. Ela também consegue se transformar em, tipo, dragões e grifos."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Quando ela me pegava fazendo bagunça quando eu era pequena, era uma loucura porque ela começava a cuspir fogo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Aiiie..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Quantos anos ela tem mesmo? Minha mãe tem 33 anos, minha avó tem 56..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Minha bisavó tem 71 anos,<CR>e a minha tataravó tem...<CR>Eu acho que ela não chegou aos cem ainda..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xb,
            "msg_string": "E-eu nem consigo imaginar que tipo de pessoa ela é..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Hehe, né? De qualquer forma, ela é uma bruxa incrível, é super bonita, e é a melhor de todas!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "(Ela deve ser uma pessoa incrível. Embora eu ainda não saiba exatamente que tipo de pessoa ela é...)"
        }
    ]
}