        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Sem falta dessa vez, beleza?"
