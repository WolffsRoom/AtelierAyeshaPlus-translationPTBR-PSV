        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "(Hmm, eu tava ocupada e acabei deixando totalmente pra depois.)"
