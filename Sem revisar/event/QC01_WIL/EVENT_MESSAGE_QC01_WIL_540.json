        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc9,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Desculpa. Tinha outras coisas que eu precisava fazer, e coisas que eu precisava procurar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xca,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Não vou esquecer dessa vez, então você pode esperar só mais um pouquinho?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Poxa, me coloca como prioridade, tá bom?"
