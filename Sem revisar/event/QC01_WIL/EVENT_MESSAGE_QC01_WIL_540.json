        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "O Ferro Sagrado Madder! Você esqueceu?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "(Ahhh, é verdade! Eu esqueci completamente disso...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc8,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "D-Desculpa. Na real ainda não tá pronto..."
