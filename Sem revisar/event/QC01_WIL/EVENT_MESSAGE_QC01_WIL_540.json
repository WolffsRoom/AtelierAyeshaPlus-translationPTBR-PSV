        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x166,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "A minha tarefa tá nas suas mãos agora."
