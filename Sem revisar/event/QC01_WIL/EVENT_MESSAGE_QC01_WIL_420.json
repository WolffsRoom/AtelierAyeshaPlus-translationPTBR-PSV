{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_WIL_420.ebm",
    "nb_messages": 0x39,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "E aí eu jurei que ia ser uma das grandes, então comecei a cavar."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Mas no fim, era só desse tamanho...<CR>Eu fiquei tão decepcionada!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hahaha, é, isso acontece às vezes. É difícil saber o tamanho da raiz olhando só da superfície."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Por outro lado, às vezes você cava um buraco do seu tamanho, e ainda vê a raiz indo mais pro fundo."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Uhum, uhum. Colher ervas medicinais faz a gente pensar. Ah, isso me lembra..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Da última vez, eu fui um pouco mais longe que o normal pra procurar umas ervas medicinais..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "E achei um lugar ótimo que ninguém conhece. Eu te levo lá na próxima!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Sério? Eba, que legal!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x81,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "...Ei, que chatoooo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x84,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Qual a graça de garotas jovens ficarem falando de raízes no meio do dia!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "Haha, desculpa, a gente se empolgou."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Poxa vida. Vamos falar de outra coisa."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Por exemplo, que tal... aquela confeitaria nova!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "Ooh, eu conheço essa loja!<CR>Ela é muito boa!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Então você já provou também, Nio? Uhum, os bolos de lá são maravilhosos!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "O bolo de morango da montanha é o melhor de todos. Você já comeu?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Morango da montanha? Não, ainda não.<CR>E você, Nio?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Eu também não.<CR>Hmm, morangos da montanha..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Eles são tão difíceis de colher."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Ué? Por quê?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Eles crescem em lugares super difíceis de chegar, tipo no meio de um penhasco ou no topo de árvores."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Ahhh, entendi."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "E eles sempre ficam longe das cidades,<CR>então só a viagem já é um saco."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Entendo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Eu sempre quis usar eles numa síntese, mas nunca tive a chance."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Eu sempre tive interesse em morangos da montanha, já que eles também servem como ingrediente pra remédio."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13c,
            "expr_id": 0x4,
            "msg_id": 0x1b,
            "msg_string": "Hmm, mas deve ser difícil, a não ser que você possa voar ou algo do tipo."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Humpf..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13e,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "Ah, Wilbell, você tá com as bochechas todas infladas! O que foi?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x1e,
            "msg_string": "Poxaaaa! Vocês tão falando de plantas de novo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x80,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Não fiquem falando de coisas que eu não conheço!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x20,
            "msg_string": "Ahhh, desculpa, Wilbell.<CR>Não foi de propósito."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "É, quando a gente tá junta, começamos a falar dessas coisas sem nem perceber."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x14,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Foi mal."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Foi mal."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x24,
            "msg_string": "Humpf, tá bom. Nem somos irmãs pra começo de conversa mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x25,
            "msg_string": "Vocês irmãs podem continuar se divertindo desse jeito. É, fiquem aí..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x26,
            "msg_string": "Ayesha, você deveria só ser egoísta e continuar se divertindo com a Nio o dia inteiro..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Ixe, a Wilbell tá fazendo biquinho..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "Anima aí, Bell. Ah, já sei!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x29,
            "msg_string": "Você pode começar a me chamar de \"Mana\" de agora em diante!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "É! Aí eu começo a chamar a Wilbell de mana também!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x2b,
            "msg_string": "Humpf. O problema não é esse!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x2c,
            "msg_string": "Kyaa, desculpa..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x2d,
            "msg_string": "Beleza, vocês estão proibidas de serem amiguinhas uma com a outra!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x2e,
            "msg_string": "O quê!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2f,
            "msg_string": "Já que vocês são grudadas demais,<CR>não tem como eu me enturmar."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x30,
            "msg_string": "Hmm... Eu não acho que a mana e eu somos tão grudadas assim..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x31,
            "msg_string": "Acho que a gente é normal."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x32,
            "msg_string": "É, que nem irmãs normais."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x33,
            "msg_string": "Então fiquem de mal. Aí vai ficar perfeito pra vocês."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x34,
            "msg_string": "I-isso é meio difícil de fazer..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x35,
            "msg_string": "Pois é, a gente não pode simplesmente começar a brigar sem motivo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x36,
            "msg_string": "Argh! Meu Deus! De qualquer forma, eu não quero ser a única a me sentir excluída!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x37,
            "msg_string": "Hmm, hmm, então vamos colher ervas medicinais na próxi-"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7f,
            "expr_id": 0x3,
            "msg_id": 0x38,
            "msg_string": "NÃO pra isso também!<CR>Eu proíbo as ervas medicinais também!"
        }
    ]
}