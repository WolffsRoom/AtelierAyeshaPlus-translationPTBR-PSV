{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_WIL_060.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oiii? Ayesha, cê tá aí?<CR>Vim passar o tempo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, Bell, seja bem-vinda. O que te traz aqui hoje?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Vim ver você sintetizando.<CR>Aquele livro que eu te dei ajudou em alguma coisa?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Uhum. Aprendi um monte de coisa útil."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, que bom. Esse livro era muito difícil... Digo, era sobre uma área que não serve pra mim."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Se tá te ajudando, fico feliz de ter passado ele pra frente."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x6,
            "msg_string": "Mas ainda tô com umas dúvidas.<CR>Não acho que eu seja uma alquimista..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Você ainda tá com essa história? Você encana muito com qualquer besteirinha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x8,
            "msg_string": "É que aquele livro descrevia os alquimistas como pessoas incríveis."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x9,
            "msg_string": "E eu tô longe de ser alguém tão incrível assim."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x168,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Humm, agora que você falou...<CR>Inacreditável... cê não tem nenhuma presença."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Hahaha... Então, mesmo que me digam que sou alquimista, a ficha não cai."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x16b,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Bom, acho que você não precisa ficar pilhada nos pequenos detalhes."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Por que a gente só não diz que você é uma<CR>boticária que também faz alquimia,<CR>e deixa por isso mesmo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "A-Ah...! Assim me sinto bem melhor!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Acho que eu não devia ter esquentado a cabeça com uma bobeira tipo o título da minha profissão..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Na verdade, cê devia se preocupar, sim. É importante saber quem você é."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Tento sempre ter em mente que sou uma bruxa."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Pra que um dia eu possa ser uma bruxa incrível, igualzinha à minha tataravó!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Cê já pensa tão longe assim?<CR>Bell, você é incrível."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Hehe, nem é lá essas coisas. Fica à vontade pra me consultar quando quiser!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Treinar a novata é o trabalho da veterana!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Hããã? Eu sou sua novata?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Isso mesmo. Eu te falei que bruxas e alquimistas são tipo parentes, não falei?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Então, você é a minha novata!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Entendi. Então eu vou contar com você."
        }
    ]
}