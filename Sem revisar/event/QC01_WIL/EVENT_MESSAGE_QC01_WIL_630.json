        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "A gente vai achar um tesouro gigante e vamo entrar de vez pra turma dos ricaços!"
