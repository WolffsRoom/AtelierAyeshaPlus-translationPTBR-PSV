    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "E aí! Fiquei sabendo que o Juris finalmente conseguiu."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, então você já sabe? Você recebe as informações rapidinho mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Não me subestime. Como dono dessa taverna, eu me orgulho de estar por dentro de tudo."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Mas eu nunca achei que ele seria capaz de matar aquele dragão..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "O Juris não veio te contar sobre isso?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Não. Ele é tímido assim mesmo. Não gosta de ficar tagarelando sobre si mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10c,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Embora eu entenda perfeitamente que ele não tá tentando parecer sem coração pros outros nem nada."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10e,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Mas, o que ele conseguiu é uma parada enorme. Eu preciso fazer uma festa pra ele."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Uma comemoração...?<CR>Hehehe, parece incrível."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17d,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Não parece?<CR>Então, tenho um favor pra te pedir."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17e,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Você pode arrastar o Juris pra cá?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17e,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "O super tímido Juris nunca viria aqui se a gente contasse que ia fazer uma comemoração pra ele."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Entendi.<CR>Deixa comigo."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x182,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "É. Tô contando com você. Vou deixar todos os preparativos prontos. Boa sorte!"
        }
    ]
}