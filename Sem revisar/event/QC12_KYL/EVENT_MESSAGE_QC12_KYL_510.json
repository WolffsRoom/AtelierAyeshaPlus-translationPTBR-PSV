{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC12_KYL_510.ebm",
    "nb_messages": 0x2a,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Mix Master, então qual é esse problema que você queria falar comigo...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa2,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "Hmm, bom, não é bem um problema...<CR>Só queria que você me escutasse."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa8,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Não sei por onde começar...<CR>Então acho que vou começar por isso..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa9,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "Pensando bem, minha vida toda até agora tem sido uma luta difícil contra esse cara..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "O álcool? Você não acha que tá exagerando...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa9,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Não tô exagerando. Por causa desse cara, eu passei por uns bocados bem difíceis."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa9,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "É estranho pro dono de uma taverna não conseguir beber nem uma gota..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa9,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Eu já me esforcei mais do que a conta pra conseguir beber."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xaa,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Eu me submeti várias vezes a um treinamento infernal que eu não quero nem lembrar..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Várias vezes...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10c,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Sim, e... ainda não consigo beber nem um pouquinho."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xb,
            "msg_string": "Entendo..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10f,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Bom, não conseguir beber é um talento natural. Pelo menos, eu decidi pensar desse jeito."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Mas... bom, não vejo por que não pode ter um dono de taverna que não pode beber."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x113,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Ayesha, você é tão legal, mas o mundo simplesmente não funciona assim."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10e,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Um dono de taverna que não bebe...<CR>A vida de um homem rotulado<CR>assim é cruel e sombria."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17d,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Porém, isso me fez pensar...<CR>Se tá todo mundo bebendo álcool,<CR>então eu só preciso comer mais comida!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Ah, entendi!<CR>...Ué?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17e,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "E quando os bêbados começarem a ficar barulhentos, aí é a minha deixa."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17e,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Não é querendo me gabar, mas sou muito bom em ser barulhento, mesmo quando não tô bêbado."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17e,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Aposto que ninguém ganha de mim quando o assunto é esse!"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x182,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Então, dito isso, eu superei com sucesso minha fraqueza de não conseguir beber."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "N-Não sei se isso é superar... Mas afinal, sobre o que você queria falar comigo?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa2,
            "expr_id": 0x3,
            "msg_id": 0x17,
            "msg_string": "É. Eu tô chegando no xis da questão. É sobre o Juris."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x18,
            "msg_string": "Ele anda muito convencido ultimamente, só porque sabe beber."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "A-Ah, sei... Convencido..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x1a,
            "msg_string": "Mas o Juris parece um pouco mais brincalhão quando tá com você..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa8,
            "expr_id": 0x3,
            "msg_id": 0x1b,
            "msg_string": "Ele é exibido, mas na real,<CR>ainda é bem infantil."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xab,
            "expr_id": 0x3,
            "msg_id": 0x1c,
            "msg_string": "E eu, sendo o cara legal que sou, aceito ele desse jeito. Mas...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x1d,
            "msg_string": "Ele passou dos limites dessa vez...<CR>Preciso dar uma lição nele."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x1e,
            "msg_string": "Essa é a questão principal. Quando a gente tava comendo juntos uns dias atrás..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x1f,
            "msg_string": "Ele misturou álcool na minha bebida de fininho!"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x20,
            "msg_string": "Vê se pode!? É por isso que..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa6,
            "expr_id": 0x3,
            "msg_id": 0x21,
            "msg_string": "Eu decidi que preciso ter a minha vingança definitiva contra aquele moleque travesso!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x22,
            "msg_string": "M-Mix Master, você tá com uma cara de travesso agora..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x23,
            "msg_string": "É porque é olho por olho, e bebida por bebida! Então..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa4,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Vou esconder um sabor de adulto que o Juris odeia na comida dele!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Como vocês dois são adultos... não tenho certeza se esse é mesmo o jeito certo de lidar com isso..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x26,
            "msg_string": "De qualquer forma, era só isso que eu queria te contar. Cara, mal posso esperar pra ver a cara dele!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "E-Eu realmente acho que você não precisava me contar isso..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x28,
            "msg_string": "Bom, é só aguardar. Te conto como foi da próxima vez."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x29,
            "msg_string": "(Os garotos são tão... Ah, eu quase pensei numa coisa que não deveria dizer nunca...)"
        }
    ]
}