        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Já sei... Eu devia anotar tudo isso<CR>num diário e organizar as coisas.<CR>Mas primeiro, preciso me acalmar."
