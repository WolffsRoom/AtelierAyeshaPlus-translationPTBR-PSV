{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS03_120.ebm",
    "nb_messages": 0x2f,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hmm, eu quero aquele ali.<CR>E esse de cerâmica aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, é raro te ver fazendo compras, Marietta."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Esse bazar é a única chance que eu tenho de ficar do lado do comprador."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2e,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Eu tô sempre vendendo os itens, mas eu adoro fazer umas comprinhas."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2f,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "É uma ótima oportunidade, então tenho que me divertir."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "E aí? Bora fazer compras juntas?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Parece divertido! Eu adoraria ir com você."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Ah, aquela pessoa é...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Ah, é o Sr. Keith. Será que ele veio atrás de algum achado?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Ele tá tão charmoso, rústico e maravilhoso como sempre..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "(Será que o Sr. Keith faz o tipo<CR>da Marietta...?)"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "Essa é uma boa chance.<CR>Eu quero conversar um pouco com ele."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Ayesha, cê pode me apresentar pra ele?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Ah, t-tá bom... Mas por quê?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Eu tenho umas perguntas que eu queria fazer pra ele... Tipo, se ele tá saindo com alguém no momento."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Ué!? E-Eu tenho certeza que você vai conseguir conversar com ele, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "Beleza. Já que você tá de boa com isso,<CR>então vamo logo!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Ahn, com licença."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Hm?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Ah, Marietta. Você quer alguma coisa comigo?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x14,
            "msg_string": "Eita, Chefe!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Digo... Chefe, o que o senhor tá fazendo aqui?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Não dá pra ver? Tô de patrulha. Tô conferindo por mim mesmo se o bazar tá rolando tranquilo."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "O que você tá fazendo aqui?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a7,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Ah, nada não. Bom, eu tenho que ir nessa... Tchauzinho."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "*ufa* *ufa* Ai, que susto.<CR>Quando será que eles trocaram de lugar...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Acho que perdemos ele de vista na multidão..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Acho que o Sr. Keith e o Sr. Harry se parecem um pouquinho."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf9,
            "expr_id": 0x4,
            "msg_id": 0x1c,
            "msg_string": "COMO ASSIM!? Caramba, mesmo os dois sendo tiozões de bigode, eles são completamente diferentes."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xfa,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "Eu jurava que eu ia me reencontrar com aquele cavalheiro de bigode..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xfb,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Ai... pra onde será que aquele homem esplêndido foi...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Ah, ele tá bem ali."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x20,
            "msg_string": "Hã? Onde!? Ah, cê tem razão!<CR>Beleza, agora vai!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x21,
            "msg_string": "V-Você vai atrás dele de novo?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x7a,
            "expr_id": 0x3,
            "msg_id": 0x22,
            "msg_string": "Claro que vou. Eu vou falar com ele,<CR>custe o que custar."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x7c,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Ayesha, vem comigo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x123,
            "expr_id": 0x4,
            "msg_id": 0x24,
            "msg_string": "O quê-hã!? Tá bom!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Ahn, boa tarde."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Hm?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Ah, são vocês de novo. Até que eu esbarrei bastante com vocês hoje..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x28,
            "msg_string": "O quê, de novo!? Por quê!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "Essa é a minha pergunta. Será que vocês tão me seguindo?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "N-Não. Bom, tchau..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0x2b,
            "msg_string": "Ufa... Ahhh, essa me pegou de surpresa..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2c,
            "msg_string": "O que a gente faz? Você ainda quer procurar o Sr. Keith?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0x2d,
            "msg_string": "Não, eu tô de boa... Tenho certeza que não importa quantas vezes eu vá, ele só vai continuar se transformando no Chefe."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0x2e,
            "msg_string": "Hoje é só um dia ruim..."
        }
    ]
}