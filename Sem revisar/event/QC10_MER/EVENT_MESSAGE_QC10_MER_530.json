        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Digo, hum, nossa, então...<CR>Eu não acho... que eu seja assim tão..."
