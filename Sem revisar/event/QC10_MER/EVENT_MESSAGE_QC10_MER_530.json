            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "(Poxa, aposto que a Marietta tá só tirando<CR>uma com a minha cara.)"
