        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Hahahaha, disso que eu gosto!<CR>Vai fazer isso na frente daquele cara também!"
