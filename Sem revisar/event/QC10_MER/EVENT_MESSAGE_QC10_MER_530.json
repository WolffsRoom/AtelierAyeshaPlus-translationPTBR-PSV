            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "msg_string": "(É só eu ir fazer síntese, jantar, tomar um banho, dormir, acordar e esquecer que tudo isso aconteceu...)"
