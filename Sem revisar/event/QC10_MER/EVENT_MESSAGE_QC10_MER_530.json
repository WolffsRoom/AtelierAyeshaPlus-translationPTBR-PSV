        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "Não. Ele tem um fraco por garotas bonitas.<CR>Hehe, então eu acertei na mosca!"
