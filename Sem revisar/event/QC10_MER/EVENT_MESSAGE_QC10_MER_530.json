        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a9,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Que mentira. Aquele cara tem fama de ser super antipático."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2f,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Maaas, ele tem uma fraqueza. Que é..."
