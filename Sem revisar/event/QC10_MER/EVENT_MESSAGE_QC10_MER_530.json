        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "Mas que tipo de pergunta é essa?<CR>Bom, pra dizer o mínimo..."
