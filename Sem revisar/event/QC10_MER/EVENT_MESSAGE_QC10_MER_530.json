        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "Até que você demorou pra ficar corada!<CR>...Bom, acho isso bem fofo também."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x39,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Hyaaah, não zomba de mim..."
