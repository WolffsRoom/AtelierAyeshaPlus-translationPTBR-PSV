{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC03_LIN_640.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Algo que combine com a Linca...<CR>O que será que pode ser...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Eu nunca fiz ou sequer pensei em fazer outra coisa além de usar a minha espada."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Talvez eu só tenha a minha espada, no fim das contas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Tudo bem também, se isso não for o seu objetivo, mas sim o seu meio, como a Ayesha disse."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, isso me lembra, o que rolou com aquele plano de derrotar um dragão que eu ouvi outro dia?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Sim. A Ayesha disse que me levaria com ela, então eu tenho esperado por ela desde então."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Hmm, entendi. Ir enfrentar um dragão... Parece que só os preparativos já dariam um trabalhão."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "(Matar o dragão...?<CR>Aah, eu tinha esquecido totalmente!)"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Ah, Ayesha. Você veio aqui pra passar um tempo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Será que você finalmente tá pronta pra matar o dragão?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ah, não. Tem um monte de coisas que ainda precisam ser ajeitadas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Entendi. Bem, eu tenho certeza que matar um dragão é uma baita tarefa, então dê o seu melhor."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Eu vou ficar esperando você me chamar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "S-Sim. Vou dar o meu melhor. Ah, eu lembrei do nada que tenho que fazer uma coisa, então já vou indo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "(O-O-O-O que eu faço!? Não posso simplesmente dizer pra ela que eu esqueci dela!)"
        }
    ]
}