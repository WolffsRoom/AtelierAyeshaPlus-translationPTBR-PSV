        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Beleza, pra liberar minha agenda, eu tenho que ralar muito nos meus trabalhos!"
