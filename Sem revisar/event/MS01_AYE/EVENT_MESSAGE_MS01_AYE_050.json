{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS01_AYE_050.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Uau... Tem tanta gente..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Olá, Ayesha! Tá curtindo o bazar?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ah, Sr. Harry, na verdade eu acabei de chegar."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x3c,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x1,
            "msg_string": "Vem dar uma olhada. Peguei uns peixes bons hoje! Você não vai ver um grandão assim com frequência."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x3d,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x1,
            "msg_string": "Vegetais da montanha fresquinhos!<CR>Só tem mais dois.<CR>Melhor correr antes que acabem!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x3e,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x1,
            "msg_string": "Eeei, tem uns tecidos fofos ali."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x3f,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "Ah, é mesmo?"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x40,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x1,
            "msg_string": "Mãããe, o-onde você tá?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "É tão animado... Não tem nada a ver com como a rua é normalmente."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x1,
            "msg_string": "Hahaha, todo mundo fala isso. E aí, o que acha? Tá gostando?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "Sim! É muito divertido. Nunca fui num festival tão animado antes."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "Com tanta gente assim... tô começando a ficar um pouco tonta."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Hahaha, com esse tanto de gente, pode ser meio complicado até você se acostumar."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "Aliás, festival? Hahaha, acho que é tipo um festival mesmo..."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "Esse \"festival\" se tornou vital pro desenvolvimento da economia de Vierzeberg e pra circulação de mercadorias e dinheiro."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "A gente faz esse bazar todo mês.<CR>Fica à vontade pra se divertir!"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Um bazar ou mercado acontece periodicamente em Vierzeberg."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "No bazar, várias pessoas abrem lojas que só funcionam durante essa época, então é uma boa chance de conseguir itens raros."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "O bazar rola todo mês, do dia 10 ao dia 19. Vai ser bom visitar Vierzeberg nesses dias."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Algumas das pessoas que abrem lojas podem virar seus amigos. Você pode ter a chance de promover amizades."
        }
    ]
}