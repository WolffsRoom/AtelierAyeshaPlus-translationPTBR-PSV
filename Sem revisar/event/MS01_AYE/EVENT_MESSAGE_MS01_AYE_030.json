{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS01_AYE_030.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "unknown2": 0x1,
            "msg_string": "Hrmm. O clima tá tão bom e quentinho hoje. *bocejo* Hmm..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x1,
            "msg_string": "Acho que comi demais no almoço."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "Tá tão bom e quentinho, e eu tô tão cheia... Tô ficando com son-zzz..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Então, como eu ia dizendo, eu queria exibir vários itens da minha preciosa coleção nas prateleiras da loja."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Mas Senhor Dono, a gente não tem nenhuma prateleira sobrando pra algo tão inútil assim, sabe?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "O quê!? \"Inútil\"...?<CR>Qual é, só um espacinho."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Mesmo sendo uma ordem do dono, é impossível."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Como a pessoa que ficou responsável por essa loja, eu preciso dar prioridade pras vendas... Ah!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Essa garota é impossível. Pra uma menina em idade de casar dormir num lugar desses..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Ela parece tão calma e feliz. Pensando bem, acho que a Ayesha sempre é assim..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Será que eu devia acordar ela..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ei, Marietta, não muda de assunto."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Primeiro de tudo, meus itens preciosos não são objetos inúteis."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1e,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Mesmo que eles não ajudem nas vendas, tenho certeza de que um cliente de bom olho vai aparecer uma hora ou outra, e..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Quando exatamente é \"uma hora ou outra\"? Você precisa me dar uma projeção detalhada."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x24,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Argh, isso é..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Ah, Ayesha! E aí!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "Zzz zzz..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "Eeei! Ayesha!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Hrmm... hmhmhm, não pode. Se você comer demais, vai ficar gorda, Bell..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x82,
            "expr_id": 0x3,
            "msg_id": 0x14,
            "msg_string": "Hmph, mas que sonho mais mal-educado você tá tendo, hein!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x84,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Tinha uma coisa que eu queria falar com você, mas acho que pode esperar."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Nossa, dormindo num lugar desses...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Ela parece estar num sono profundo.<CR>Será que eu acordo ela?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Hmm, deixa ela quieta. O sol ainda tá alto, e esse lugar é seguro."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Verdade. Cochilar no começo da tarde é difícil de resistir, não importa pra quem seja."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Quando a gente voltar, se ela ainda estiver dormindo, aí a gente acorda ela."
