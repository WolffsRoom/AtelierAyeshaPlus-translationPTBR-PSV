{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_HAR_010.ebm",
    "nb_messages": 0x28,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x58,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ora, ora, espero não ter feito vocês esperarem demais. Sabe como é, sou um cara ocupado..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "(Nossa, ele é bem... extravagante.)"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x58,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Eu sou o Vice-Diretor Assistente da Associação Comercial e Industrial, Presidente do Governo de Riesengang..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x58,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Presidente da Sociedade de Entusiastas de Itens Raros Ocasionais, e organizador do Concurso Emocionante de Tesouros..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x22,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Sim. Eu sou o famoso Harry Olson!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Bom, quando você é tão famoso quanto eu, parece que os fãs chegam até a invadir a sua casa..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x56,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "Que chato. Mas mesmo assim, prometo não tratar vocês mal."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x5e,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "Dou um autógrafo pra vocês com o maior prazer. Afinal, faz parte da minha missão."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "É, hum... muito obrigada."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Pera aí, não é nada disso. A gente veio te fazer uma pergunta."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ayesha, se você não quer o autógrafo, tem que falar na lata pra ele."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Enfim, a gente tem uma pergunta pra você. Harry, você manja de umas coisas estranhas, né?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Essa garota aqui tá procurando umas flores raras. Sabe de alguma coisa sobre isso?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x57,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Hum, flores, você disse!? Flores são minha especialidade. Bom, pra falar a verdade, sou especialista em tudo."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x58,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Vamos lá, podem perguntar o que quiserem."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a5,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Tá bom. Hum, é sobre essa flor aqui. Por acaso você sabe alguma coisa sobre ela?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Ooh, isso é... hum...<CR>Hrmh... A-a-ah sim, tô vendo..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "...Já sei!<CR>Essa flor é... aquela!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Você sabe de alguma coisa!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x161,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Hmhmhm, como eu disse antes, meu conhecimento no campo da ciência é vasto e profundo."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Não existe absolutamente nada que eu não saiba. Mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "Tá bem na ponta da língua,<CR>mas o nome me fugiu. Acho que tô sofrendo de um... famoso lapso de memória."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Isso me parece muuuito suspeito... Harry, você tá suando a bessa."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xb6,
            "expr_id": 0x3,
            "msg_id": 0x17,
            "msg_string": "O-O quê? Tá me chamando de mentiroso? Para de me olhar como se não acreditasse em mim."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xb2,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Desculpa, mas vocês poderiam me dar um tempinho? Vou tentar lembrar o nome."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Então você tá só tentando ganhar tempo, e planeja fazer uma pesquisa desesperada pra descobrir?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x141,
            "expr_id": 0x4,
            "msg_id": 0x1a,
            "msg_string": "C-C-Claro que não! Já falei, não tem nada que eu não saiba."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Bom, seja como for, por mim tudo bem. A gente volta depois."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x143,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Desculpa. Não é exatamente pra compensar isso..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Mas vocês podem ficar à vontade pra usar um quarto de hóspedes enquanto esperam."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x1e,
            "msg_string": "A gente agradece, mas... quantos dias você acha que vai demorar pra lembrar?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Hã? Ah, um ou dois dias...<CR>Ou então, uma ou duas semanas...<CR>Ou isso, ou..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd3,
            "expr_id": 0x4,
            "msg_id": 0x20,
            "msg_string": "Tá, tá bom, faz o possível aí pra lembrar ou pesquisar de alguma forma."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd5,
            "expr_id": 0x4,
            "msg_id": 0x21,
            "msg_string": "A gente tá contando com você."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Deixa comigo. Sou um homem que nunca decepciona as expectativas. Agora..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x21,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Que tal eu já ir levando vocês pro quarto que vão usar durante a estadia?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Ah, tem certeza? Mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "É melhor você aceitar essa oferta. Ficar numa pousada vai sair caro."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Ajudar e cuidar das pessoas é o ponto forte do Harry."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Tá bom. Então eu aceito a oferta."
        }
    ]
}