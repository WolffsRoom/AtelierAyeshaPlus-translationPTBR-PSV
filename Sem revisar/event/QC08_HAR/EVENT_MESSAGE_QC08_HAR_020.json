{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_HAR_020.ebm",
    "nb_messages": 0x1b,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hum? Essas são todas as inscrições para as barracas?"
        },
        {
            "type": 0x4,
            "voice_id": 0x21b,
            "name_id": 0x32,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x1,
            "msg_string": "Sim, Mestre. Tudo tá indo da melhor forma possível."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hum, com certeza aumentaram, bem do jeito que eu planejei."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Não querendo me gabar do meu próprio sucesso, mas isso com certeza é prova do meu espírito inovador."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Hum?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x56,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Nossa senhora, tenho andado tão ocupado com os preparativos! Hã? Olha só, se não é a Ayesha...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x57,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "Como pode ver, tô correndo que nem um louco pra ajeitar todos esses preparativos. Minha nossa."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "H-Hum. Vai começar alguma coisa?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x5e,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Ah, que bom que você perguntou. A gente tá no meio dos preparativos pro bazar!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Bazar? Nunca ouvi falar...<CR>Parece algo meio bizarro."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x58,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "É tipo um mercado de pulgas que rola todo mês. E pra ser bem sincero com você, a ideia foi minha."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Todo mês, por uns dias, a gente abre um mercado onde qualquer um pode vir vender suas mercadorias."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Vários itens são reunidos dos quatro cantos do mundo."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Vai ter vendedores de lugares tão distantes que você provavelmente nunca viu, e a participação só continua a crescer."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1e,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "O negócio já alcançou muita fama e sucesso. É uma vitória pra minha habilidade de planejamento!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Uau, parece divertido...!<CR>É quase como um festival!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Isso mesmo, não deixa de ser um festival. Eu mesmo fico impressionado com o meu próprio talento para negócios!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x22,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "O bazar começa todo dia dez do mês. Não deixe de dar uma passadinha."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x23,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Você pode até acabar esbarrando nuns achados inesperados."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Beleza, eu adoraria participar!"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Em Vierzeberg, um mercado chamado de bazar será realizado periodicamente."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Várias pessoas vão montar barraquinhas no bazar. Algumas lojinhas só abrem nessa época. Você pode achar uns itens bem raros."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "O bazar vai acontecer todo mês entre os dias 10 e 19. É uma boa ideia ficar em Vierzeberg durante esse período."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Seus amigos também podem abrir umas lojinhas. Pode ser uma ótima chance de fortalecer suas amizades."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Agora você pode usar os atalhos.<CR>Aperte <IM15> pra escolher onde ir e você será teleportado pra lá."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode usar a função de atalhos para voltar para o mapa mundi."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Se viajar entre as áreas não consumir tempo, você pode usar atalhos."
        }
    ]
}