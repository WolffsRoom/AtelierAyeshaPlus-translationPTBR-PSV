{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_HAR_060.ebm",
    "nb_messages": 0x26,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Com licença. A Ayesha tá aí?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, Sr. Harry. É raro você me visitar aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Sim. Eu tinha uns assuntos formais que eu queria falar com você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "(Ué? Sinto que o Sr. Harry tá meio diferente do normal...)"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Tô questionando o sentido da minha vida agora."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "E como resultado do meu monólogo, tem uma coisa que eu tinha que te contar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "*gulp* O-O que foi?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Decidi me aposentar como colecionador e passar as rédeas pra próxima geração."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hã? Então você vai parar de coletar itens raros? M-Mas por quê?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "Tô honestamente surpreso com os seus resultados no concurso."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xb2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Eu me gabo de ser um colecionador de tesouros raros."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Achei que tinha usado todo o conhecimento e a experiência que consegui com o passar dos anos no último concurso..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Mas cada rastro do meu esforço e glória virou coisa do passado, graças a uma garota."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Sua habilidade de fazer escolhas ousadas sobre qualidade e raridade... é inacreditável pra uma novata..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Eu nunca vi um item tão magnífico. Você é... uma garota e tanto."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "E-Eu!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Sim. E eu pensei comigo mesmo que a minha missão talvez tenha chegado ao fim."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "msg_string": "(Será que... o Sr. Harry tá<CR>deprimido?)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "M-Mas, eu achei que o seu item era incrível também!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "...Hm? Não, não, eu não preciso ser consolado. Foi uma derrota minha, não importa como."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Não, eu acho os seus itens maravilhosos!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Porque, eu sempre achei que você tem tantas coisas que eu nunca ia conseguir pegar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Por pura sorte, eu ganhei da última vez, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Acho que com certeza você ganha o próximo concurso!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "...Então tá querendo dizer que a minha missão ainda não acabou?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Isso. Sr. Harry, você é a única pessoa que pode coletar itens raros."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Você pode ter razão. Não, deve ser isso mesmo!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0x1b,
            "msg_string": "Fiquei deprimido por causa de uma ou duas derrotas..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0x1c,
            "msg_string": "Mas tem muito mais tesouro descansando nesse mundo chamando por mim. Eu tinha me esquecido disso..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf9,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "Beleza então, a partir de hoje, vou jogar fora todo meu orgulho de campeão..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xfb,
            "expr_id": 0x4,
            "msg_id": 0x1e,
            "msg_string": "E declarar que eu virei seu rival pra vida toda!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Ué... hã? Pra vida toda...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "A \"Surpresa! Exposição de Tesouros Leste-Oeste!\" Ah, essa é minha ideia pro subtítulo do próximo concurso..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x22,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Então no próximo concurso, vou te derrubar com um golpe fatal! Porque eu vou ser o seu desafiante!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x25,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Ah, mas é claro, isso é só uma expressão metafórica. Não vou te bater de verdade, não se preocupe."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Bom, a gente se vê no próximo concurso. Vou ficar na expectativa!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Lá vai ele... Acho que ele voltou a ser o mesmo Sr. Harry de sempre."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x25,
            "msg_string": "Eu acho que... isso é bom, né?"
        }
    ]
}