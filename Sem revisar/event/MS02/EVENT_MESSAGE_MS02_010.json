{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS02_010.ebm",
    "nb_messages": 0x12,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x206,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "Opa, bem-vinda! Veio usar o Serviço de Balões do Toby?"
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "É só um palpite, mas... moça, essa é sua primeira vez num balão de ar quente?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ah, sim. É tão... grande quando se vê de perto..."
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x20c,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "Pois é, ele aguenta um monte de gente de uma vez. E aí, quer subir a bordo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Eh, eu tô interessada, mas acho que por enquanto vou ficar só olhando..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Não tô preparada mentalmente pra isso..."
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "Haha, imagino que qualquer um que nunca voou antes ficaria confuso se do nada dissessem que tem que voar."
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "Tenho muito orgulho dos meus balões. Fica à vontade pra olhar o quanto quiser, só não vai furar nenhum."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "São balões magníficos mesmo.<CR>Será que algo desse tamanho voa de verdade...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "msg_string": "Que foi, moça? Então você quer dar uma volta num deles?"
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x20c,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "Pode subir! Fica com vergonha não. Só que eu tenho que cobrar uma taxinha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Uma jornada pelo céu num balão... Quanto custa?"
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "msg_string": "Não esquenta, não é absurdamente caro! Me orgulho de manter meus preços justos."
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "Vem falar comigo quando quiser andar de balão."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Agora você pode ir para o Deserto de Sal e para a Cidade dos Homúnculos."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Depois de falar com o Toby, você pode escolher pra qual destino ir."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Porém, pra usar esse serviço, você vai precisar de 100 Cole para uma viagem de ida e volta."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode falar com o Toby pra voltar pra Hornheim."
        }
    ]
}