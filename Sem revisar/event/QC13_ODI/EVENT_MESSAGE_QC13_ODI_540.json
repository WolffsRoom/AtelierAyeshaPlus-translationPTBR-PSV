            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Sim, eu tava esperando achar alguma pista sobre a minha irmã."
