            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ahn, o que você tá fazendo aqui, Senhor Keith? Digo, a entrada tava bloqueada..."
