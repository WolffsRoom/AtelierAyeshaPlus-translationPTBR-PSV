        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x11,
            "msg_string": "\"Enciclopédia de Grama Selvagem Comestível\", e \"As Propriedades Medicinais de Ervas Venenosas\"..."
