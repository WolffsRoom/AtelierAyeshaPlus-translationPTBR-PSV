        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x12,
            "msg_string": "Tem tantos livros que são só de plantas. É impossível pra mim ler todos eles... O que eu deveria fazer?"
