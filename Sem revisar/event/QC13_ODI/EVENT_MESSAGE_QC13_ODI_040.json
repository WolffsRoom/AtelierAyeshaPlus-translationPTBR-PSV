{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC13_ODI_040.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Você conseguiu encontrar o livro que estava procurando?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hum, acho que sim. Eu tenho permissão pra pegar livros emprestados daqui?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x197,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Claro. Esta instalação existe exatamente para esse propósito."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Agora, vou seguir com os procedimentos. Seu nome, por favor, para fins de registro."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, é Ayesha. Ayesha Altugle."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Senhorita Ayesha Altugle. Por favor, aguarde enquanto concluo o registro."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Beleza."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x186,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Ocorreu um problema na transmissão. Forçando o encerramento da operação."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hmm, eu já imaginava que tinha alguma coisa errada..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Não consegui registrá-la no sistema de empréstimos, mas vou me lembrar de você."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x31,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "O limite de tempo para o empréstimo é de um ano. Se você não devolver o item dentro desse prazo, faremos uma visita para lembrá-la."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xb,
            "msg_string": "Eu posso pegar emprestado por um ano? Tô sentindo que vou esquecer de devolver..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x33,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ayesha Altugle, não há nenhum problema com devoluções antecipadas."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Pode me chamar só de Ayesha. Falar meu nome e o sobrenome fica meio longo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Ah, já sei. Se não se importar, posso perguntar qual é o seu nome?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "...Odelia. Foi assim que meu pai me chamou."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Srta. Odelia... Prazer em conhecê-la!"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x197,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Sim. Por favor, me avise se tiver alguma dúvida."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Esta instalação não tem visitantes, e eu estou entediada..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Hehehe, beleza, eu venho de novo!"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Odelia agora pode entrar no seu grupo."
        }
    ]
}