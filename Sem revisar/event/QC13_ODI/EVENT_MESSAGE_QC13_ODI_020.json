{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC13_ODI_020.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x4,
            "voice_id": 0x223,
            "name_id": 0x53,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "unknown2": 0x1,
            "msg_string": "Vur."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hum, os slags daqui são dóceis, né?<CR>Eu não queria incomodar."
        },
        {
            "type": 0x4,
            "voice_id": 0x223,
            "name_id": 0x53,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "Vur! Vur! Vur!<CR>Vur! Vur! Vur!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Ué? Ele parece meio bravo...<CR>E-Espera um pouquinho!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc7,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "O que mais me assustou foi que ele<CR>simplesmente me atacou do nada.<CR>Será que eu fiz alguma coisa de errado..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc9,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Ah é, a gente tem que ficar em silêncio na biblioteca. Talvez eu tenha feito muito barulho..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Não. Não há nenhum erro nas suas ações."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Eita, você me assustou!"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Atualmente, esta instalação está apresentando falhas em várias de suas operações."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Isso pode causar alguns transtornos para os visitantes, mas pedimos a sua compreensão e colaboração."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Entendi. Essa é uma instalação antiga. Tenho que ficar de guarda alta, que nem quando eu tô investigando uma ruína."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Além disso, algumas estantes caíram no outro dia, bloqueando a passagem para o andar inferior."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ahh, então acho que não posso continuar..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Agora, por favor, aproveite o resto da sua visita."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "(Uma biblioteca onde não sei quando vou ser atacada... Pelo jeito não vou conseguir ler um livro em paz.)"
        }
    ]
}