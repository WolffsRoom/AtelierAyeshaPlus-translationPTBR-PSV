{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC16_RAN_100.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ayesha, você tem um minutinho?<CR>Tenho grandes novidades."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Tinha uma vila perto de Vierzeberg onde todos os aldeões desapareceram da noite pro dia..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Mas recentemente, todos esses aldeões voltaram!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Parece que sim. Eu também ouvi falar sobre isso."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Então você já sabia?<CR>Bom, isso deu o que falar mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x4e,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Mas as histórias desses aldeões são muito interessantes. Eu tenho visitado aquela vila com frequência agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x4f,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "Aldeões que sumiram e aí de repente reapareceram..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x50,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Esse é o assunto perfeito pra uma música que será passada adiante como tradição."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Ranun, você estaria escrevendo uma música sobre isso?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Exatamente. Quero ensinar às pessoas sobre o que aconteceu naquela vila através da música."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Esse é o meu objetivo agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Quando eu desaparecer desse mundo, alguém vai tocar a melodia que eu tiver deixado pra trás..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18e,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "É aí que todo o meu esforço vai valer a pena."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Ranun, não sabia que você pensava nessas coisas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Em um mundo, daqui a cem anos... vai ser incrível se a sua música ainda estiver sendo tocada."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x4e,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Né? Mesmo que meu nome seja esquecido,<CR>se a minha música ainda existir... então vou<CR>estar satisfeito."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x4f,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Vai ser a prova de que nós vivemos nessa era."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Prova... Poder deixar uma prova pra trás... a música é incrível!"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x52,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Hmhm, vou me certificar de criar uma música assim. Eu prometo isso às estrelas brilhantes nos meus olhos!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x35,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Você consegue! Se tiver qualquer coisa em que eu puder te ajudar, eu faço com prazer!"
        }
    ]
}