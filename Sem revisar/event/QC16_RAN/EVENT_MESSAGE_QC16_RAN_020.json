{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC16_RAN_020.ebm",
    "nb_messages": 0x1f,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "*arf* *arf* Essas escadas são de matar, não importa quantas vezes eu suba elas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Essas escadas são osso duro.<CR>Finalmente consegui..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Nossa, aquele corpo desmaiado ali me parece familiar..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Eu sabia... É o Ranun."
        },
        {
            "type": 0x4,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x1,
            "msg_string": "O pessoal dessa cidade é muito cruel. Tem uma pessoa desmaiada no chão, mas ninguém nem parou pra ajudar..."
        },
        {
            "type": 0x4,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x1,
            "msg_string": "Você é a primeira pessoa a falar comigo, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x6,
            "msg_string": "Ranun! Você desmaiou de fome de novo foi?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Hahaha, não, não. Ainda tenho comida pra forrar o estômago."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x188,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Até eu sei que não dá pra passar fome no meio da cidade."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18b,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Eu só tava olhando pro céu. A vista daqui é sensacional."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0xa,
            "msg_string": "Eu nunca ia adivinhar. Se você quer ver o céu, não dava só pra olhar pra cima...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18e,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Você ainda é tão ingênua... Ficar só olhando pra cima tem limite, por causa do quanto você consegue virar o pescoço pra trás."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Eu não queria que tivesse mais nada no meu campo de visão além do céu."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Mesmo assim..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Bom, pelo menos essa era a ideia nos primeiros minutos, mas aí cansei de ficar de pé, e..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe2,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Pelo visto, subir essas escadas sugou mais energia de mim do que eu esperava."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Então, não consegui mais sair do lugar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "Então você desmaiou sim!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Hmm, se quiser descansar, tem um banco bem ali..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x4e,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Haha, você tem razão. Eu tava tão focado no céu que nem reparei."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x50,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Vou descansar minhas asas no banco da próxima vez."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "É uma boa ideia. É meio estranho falar com você deitado no chão..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x188,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Hmm, você se apega demais aos detalhes. Eu não acho que faça tanta diferença assim."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18b,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Descansar as costas na mãe terra e olhar pra esse céu infinito... Isso não é a coisa mais espetacular do mundo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18d,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Fazendo isso, eu realmente começo a sentir que tô totalmente sozinho."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18d,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Mas essa solidão até que é boa também. Me dá uma ótima oportunidade pra refletir sobre a vida."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18e,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Que tal? Por que você não tenta também?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x1b,
            "msg_string": "Hmm, eu passo."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Hahaha, bom, você não é uma poetisa, então acho que não precisa ficar olhando pro céu..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Agora que já apreciei essa vista gloriosa, vou indo nessa..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Se a gente se esbarrar de novo por aí, não hesita em me dar um oi. Até mais."
        }
    ]
}