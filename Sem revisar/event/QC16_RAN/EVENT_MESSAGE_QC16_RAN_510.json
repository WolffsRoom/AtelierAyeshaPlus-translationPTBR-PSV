{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC16_RAN_510.ebm",
    "nb_messages": 0x29,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ah, oi, Ranun."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Olá, Ayesha. Você tá tão cheia de energia como sempre."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x4e,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Sinto que até me encho de energia só de olhar pra você."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x50,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Você provavelmente é abençoada pelo<CR>deus do sol e dos sorrisos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x4,
            "msg_string": "S-Sério? Eu não tenho tanta certeza..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "De qualquer forma, Ranun, você vai tocar a sua música aqui hoje?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Não. Tô esperando pelo vento."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x7,
            "msg_string": "Ah, o vento...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Você já se questionou?<CR>Sobre pra onde vai o vento que corre<CR>pelo mundo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Não, nunca pensei nisso. Ranun, você sabe a resposta?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Sei. O vento tá... correndo na direção da pessoa que deve recebê-lo."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18d,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "O vento sopra na direção de uma certa pessoa, por um certo momento, em um certo lugar, que vai recebê-lo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I-Isso parece tão complicado.<CR>Eu acho que não entendi direito..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "De qualquer forma, eu tava esperando ouvir a sua música..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18e,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Ah, me sinto honrado. Porém, nunca pensei que você seria a pessoa a dizer isso."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Hmhm, talvez eu e você estejamos na mesma sintonia..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Mas, hoje eu não posso. No momento, eu perdi o som de vista..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x11,
            "msg_string": "O som...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe2,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Se você não tem novas inspirações continuamente, você não consegue criar os sons."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Quero que você se lembre da história que acabei de contar. Lembra da história sobre o vento?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "O vento vai trazer novos sons com ele. É por isso que estou esperando aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "O vento é essencial para mim."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "(...A música é tão complicada.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x51,
            "expr_id": 0x2,
            "msg_id": 0x17,
            "msg_string": "Haha, embora seja um pouco chato. Mas, é preciso ter paciência para tocar música."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x54,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Mas só ficar esperando está... como eu posso dizer... me dando fome."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Não é surpresa. Sinto que é uma baita perda de tempo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Por que você não tenta trabalhar ou fazer alguma coisa enquanto espera?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x157,
            "expr_id": 0x4,
            "msg_id": 0x1b,
            "msg_string": "T...ra...ba...lhar?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "T-Tem algo de errado?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x159,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Ayesha, você teve uma ideia interessante. Sim... muito interessante."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "msg_string": "(S-Sério...?)"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x1f,
            "msg_string": "Mas eu tenho uma relação bem fraca com essa palavra."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe6,
            "expr_id": 0x4,
            "msg_id": 0x20,
            "msg_string": "Agradeço o seu conselho, mas acho que vou preferir seguir com o meu próprio plano."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Vou esperar até o momento em que o vento trouxer novos sons para mim."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "msg_string": "(I-Isso parece meio legal, mas ao mesmo tempo meio que não parece...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Quer dizer, se não for hoje, sempre tem o amanhã. Se não for amanhã, sempre tem o depois de amanhã."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "O dia prometido chegará depois de superar muitas dificuldades."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Mas eu sinto que você não tá superando nada... Não, nadinha."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Os novos sons estão logo ali na esquina. Sim, eles têm que estar lá..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x27,
            "msg_string": "Mas, mesmo assim... tô ficando com fome..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0xffffffff,
            "msg_id": 0x28,
            "msg_string": "(Queria saber por que minha cabeça começa a doer toda vez que eu falo com o Ranun...)"
        }
    ]
}