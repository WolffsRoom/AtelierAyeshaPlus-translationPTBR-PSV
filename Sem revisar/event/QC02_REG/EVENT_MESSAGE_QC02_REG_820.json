{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_820.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Regina... então, sobre o que a gente tava conversando antes, aconteceu alguma coisa de lá pra cá?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Antes...? Ah, você quer dizer sobre<CR>se eu vou largar meu emprego ou não?<CR>Pois é, tá horrível!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Ainda não decidi nada,<CR>mas meus pais não param de falar nisso."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Tipo, \"Seu quarto tá aqui te esperando,\" ou \"tem um cara bom na área procurando esposa,\" e por aí vai."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Nossa... Eles são bem rápidos nos preparativos. Parece que tão te deixando sem saída..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "É. Era inevitável, então me decidi."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Fui falar pro Chefe que vou sair logo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Entendi... Já tô começando a ficar triste."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "É, eu também. Desculpa, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Quando chega a hora de realmente sair,<CR>você começa a pensar em coisas que<CR>normalmente não pensaria."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Tipo, se consegui deixar algo pra trás com esse trabalho, ou se conquistei algo muito incrível..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x10,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ou tipo... quero fazer alguma coisa bem no final. Eu sei que não é a minha cara agir assim..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "É. Pro meu último trabalho como prospectora, quero deixar algo pra trás."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Bom, se tiver qualquer coisa que eu possa fazer,<CR>eu quero ajudar!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "...Sério?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "Sim. Super sério! Seja caçando tesouros ou caçando marido!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x49,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Hahaha, Ayesha, você é muito fofa!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x4b,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "...Se você vai me ajudar, então só tem uma coisa que quero fazer."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Certo, decidi! Eu vou fazer isso!!!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Quero te contar mais sobre, então pode vir comigo até o túnel?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "O túnel? Claro, eu vou com você."
        }
    ]
}