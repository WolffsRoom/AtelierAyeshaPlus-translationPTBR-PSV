{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_040.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ei Ayesha, vem aqui um instante."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Você sabe o que é isso?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Uau, isso é... um tipo maior daqueles redondinhos que ficam por aqui?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Aham. É a pele trocada do slag chefe daqui. Não é gigante?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Com certeza. Eu nem conseguiria dizer que é da mesma espécie dos outros."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Né? Vai todo mundo ficar de cara quando ver isso!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Se os pequenos crescem até ficarem desse tamanho, ou se existiam esses grandões no passado..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Não tenho certeza, mas é de cair o queixo."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd5,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Embora me dê calafrios só de imaginar uns bichos desses ficando agitados."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Essa casca parece muito dura.<CR>Acho que eu não conseguiria nem arranhar<CR>ela batendo com o meu cajado..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Isso não é nada. Ferramentas feitas pra cortar pedra não fazem nem um arranhãozinho."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Se tivesse um jeito de cortar e levar isso daqui, a gente ia ganhar uma boa grana..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ah, já sei. Faz um tempo desde a última vez, então talvez eu devesse tentar de novo... Hi-yah!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Aiiiiiii!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Eita! V-Você tá bem!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Tô bem. Já tentei isso umas duas vezes..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Mas acho que ainda não rola.<CR>Que droga!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Não faz nada muito imprudente.<CR>Não quero que você se machuque."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Eu seeeei. Ayesha, você é tão cuidadosa."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "Enfim! Um dia desses eu vou te cortar e te transformar em dinheiro, então se prepara!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "(Nossa... A Regina é tão forte...)"
        }
    ]
}