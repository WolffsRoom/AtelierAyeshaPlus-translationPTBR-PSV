            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Eu dei sorte na ruína uns dias atrás, e quero levar o que eu achei pra Vierzberg."
