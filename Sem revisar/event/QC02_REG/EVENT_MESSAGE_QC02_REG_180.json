            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "É, mas sei lá, um quarto limpo assim dá uma certa solidão."
