            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xcc,
            "msg_string": "Hehehe, eu andei pensando umas coisas, e decidi partir numa pequena jornada."
