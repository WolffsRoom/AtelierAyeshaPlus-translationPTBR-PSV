{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_150.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ah, Ayesha! O-Oiii!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, Tanya, você tá cheia de energia como sempre!"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hahaha, faz tempo que não vejo outras pessoas. Além disso, vi você com a sua amiga."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Eu não consegui me conter de empolgação quando comecei a pensar de qual cidade ela seria."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Por favor, me fala da sua cidade.<CR>O que tá em alta por lá agora?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hmm, deixa eu pensar... Riesengang é bem rural, então não tem nada de tão especial pra te contar."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "O simples fato de ter muita gente por lá já deixa tudo interessante pra mim."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Ah, essa picareta...!<CR>Você veio aqui pra cavar também?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hm? Esse lugar não parece ter nenhum ponto bom pra cavar..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Ah, então você não tá aqui pra minerar sal?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Minerar... sal? Que parada misteriosa é essa que você tá falando?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Bom, o chão por aqui é todinho feito de sal."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x122,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Sério!? Até aqui mesmo onde eu tô pisando!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Sim. E cavar isso é o trabalho da minha família."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x126,
            "expr_id": 0x3,
            "msg_id": 0xe,
            "msg_string": "Caramba, eu nunca ia imaginar...<CR>Cavar sal..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "A Tanya é tão nova, mas trabalha duro todo dia."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Aahh, que impressionante.<CR>Então ela é que nem eu."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Acho que eu tinha mais ou menos a sua idade quando comecei a trabalhar."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Naquela época, a picareta que me jogava de um lado pro outro. Foi tenso..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Aham, lembrar dos bons e velhos tempos, quando eu era tão novinha, dá a maior nostalgia."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Entendi. Então a gente é parecida!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "É. Então o sal que a gente usa todo dia é minerado aqui...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Sal não pode faltar nas bebidas e nos acompanhamentos. Que nem picles!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Sou muito grata a você e ao seu sal... Posso tentar cavar um pouquinho?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Claro! Eu te ensino todos os segredinhos pra fazer isso."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x19,
            "msg_string": "Beleza, agora eu empolguei!<CR>Bora cavar um pouco pra levar de lembrancinha!"
        }
    ]
}