        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Ah, verdade. Bom, então fica sendo a colina!<CR>Se você se perder, é só lembrar de continuar subindo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x19a,
            "expr_id": 0x0,
