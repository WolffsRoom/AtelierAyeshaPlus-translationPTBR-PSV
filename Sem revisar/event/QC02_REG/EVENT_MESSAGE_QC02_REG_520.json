            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Uau! Então essa é Vierzeberg!<CR>Tem tantas pontes<CR>magníficas, é incrível!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Bom, a gente se separa por aqui. Tenho uma entrega pra fazer."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Tá bom... O que eu faço agora?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "É uma boa oportunidade pra você dar uma volta."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Tenho certeza que tem um monte de coisa nessa cidade que você nunca viu."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Dar uma voltinha... Parece divertido mesmo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "A loja da minha amiga fica ali no alto da ladeira, então a gente se encontra lá."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x10,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Foi mal te deixar esperando,<CR>mas eu vou te apresentar a<CR>pessoa que eu te falei!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "A colina... Como eu chego lá?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Se você descer a rua que vai ver quando entrar na cidade e só continuar em frente, não tem erro."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0xa,
            "msg_string": "Hahaha, eu ainda tô bem confiante de que consigo me perder."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Você vai ficar bem. Mas se der algo errado, a gente se encontra nessa ponte."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0x5,
            "msg_id": 0xc,
            "msg_string": "Umm, mesmo com esse plano B, tem tantas pontes..."
