{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_720.ebm",
    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "(Isso mesmo, acho que vou perguntar sobre o tecido que a Regina tava procurando...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Entendi, um tecido para o forro...<CR>A circulação desse tipo de mercadoria<CR>deu uma caída ultimamente."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Como parece ser um presente importante, eu queria muito ajudar ela..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Deixa comigo! Ela é sua amiga,<CR>então vou fazer o que eu puder."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Pode demorar um pouco, mas se você me passar o endereço dela, eu entrego pra ela direto."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Uau, você é o cara, Ernie!<CR>Dá pra contar sempre com você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Parando pra pensar, acho que nunca teve um item que você não conseguisse encontrar..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Não importa os meios que eu use, eu quero atender aos pedidos dos meus clientes. Esse é meu lema."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "(Eu fico me perguntando de que tipos de meios ele tá falando...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Além do mais, eu não faço roupas, mas adoro fazer laços e outras coisinhas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Então, como alguém que adora costurar,<CR>eu faço questão de ajudar ela."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ah, como eu te pago?<CR>Quer que eu te pague agora?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Fica tranquila quanto a isso. Só dê o seu melhor na próxima vez que eu tiver um trabalho pra você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Então é meio que uma troca de favores...<CR>Isso me ajuda também. Sendo assim, vou aceitar a sua oferta."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Então, tem algum problema se eu mesmo escolher a estampa e a cor?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Pode escolher sim, por favor."
        }
    ]
}