    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Ayesha, valeu! A encomenda chegou!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "A enco...? Ahhh, você diz o tecido? Conseguiu encontrar uma estampa que você curtiu?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Demais! Tive até que parar pra pensar, já que ele tem um bom gosto incrível pra tecidos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, eu não esperava menos do Ernie."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ai ai, o Ernie... Ele é um garoto tão tranquilo e fofinho."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x5,
            "msg_string": "Mas, acho que ele ainda é bem mais velho que você..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Sério? Não parece nada...<CR>Apesar de que ele parece ter<CR>um senso de responsabilidade bem forte."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Não importa a profissão, é sempre bom demais ver um mestre em ação."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Mudando de assunto, eu já fui lá e fiz as<CR>roupas, mas fiquei tão empolgada,<CR>que acabei fazendo coisa demais."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Eu tava querendo que ele provasse um pouco pra eu poder ajustar a medida..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ele? Você tá falando do Ernie?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Não, não, o Juris. O porte físico dele é bem parecido com o do meu irmão."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Da próxima vez que você tiver a chance,<CR>tem como trazer ele aqui?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Se você fizer isso, eu pago um almoço delicioso pra você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Beleza! Vou ficar de olho nisso."
        }
    ]
}