            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Se a gente demorar demais, os outros podem ganhar a bebida especial do Chefe."
