            "name_id": 0x12,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x1,
            "msg_string": "Eu sou aquele que protege a semente.<CR>Eu só existo pra cumprir o meu dever."
