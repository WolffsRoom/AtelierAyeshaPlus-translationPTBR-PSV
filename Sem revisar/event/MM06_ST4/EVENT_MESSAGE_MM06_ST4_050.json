            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "Eu sabia! Então esse é o berço...<CR>Sendo assim, não posso recuar...!"
