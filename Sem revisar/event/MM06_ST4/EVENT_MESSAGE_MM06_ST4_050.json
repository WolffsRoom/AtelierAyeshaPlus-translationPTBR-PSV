            "type": 0x4,
            "voice_id": 0x3e,
            "name_id": 0x12,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "Como protetor da semente, não tenho vontade de matar por matar. Mas..."
