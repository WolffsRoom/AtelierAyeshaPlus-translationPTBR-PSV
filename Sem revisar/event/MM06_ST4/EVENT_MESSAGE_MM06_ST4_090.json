{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM06_ST4_090.ebm",
    "nb_messages": 0x25,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "H-Hã...? A gente tá no jardim de ervas atrás do ateliê!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Por que será... Eu achei que a gente ia estar muito mais longe..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Depois de enfrentar aquela batalha, eu sabia que ia ser difícil fazer todo o caminho de volta."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Então, eu conectei a saída aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Então foi por isso...<CR>Na real, tô exausta, então ainda bem..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Não tinha outro jeito de salvar a Nio, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Você não tomou nenhuma decisão errada. Ele já tava quebrado pra começo de conversa."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Pelo menos, essa é a minha opinião,<CR>mas você não parece convencida."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc5,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "É... Ele só tava cumprindo a vontade de um alquimista do passado."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc5,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Ele só tava fazendo o dever dele fielmente, e a gente destruiu ele."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc5,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "É como se a gente tivesse apagado o desejo do criador dele, e..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x91,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "Os desastres do passado já ficaram pra trás faz tempo. A ameaça da qual ele ia nos salvar nem existe mais."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x92,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Por mais que a gente possa estar à beira do fim da história humana..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x92,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "Mesmo assim, ainda é muito cedo pra gente precisar dos cuidados dele."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x93,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Existe mais de uma solução, e eu tô procurando um caminho diferente."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Um caminho diferente...!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Sim, e a melhor coisa que você pode fazer por ele seria encontrar a sua própria solução, uma mais adequada."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Acho que não vou conseguir achar uma solução clara logo de cara, mas vou ficar de olho no que posso fazer."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Ei vocês dois, o papo parece tá sério."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Então... do que vocês tão falando?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "...Hmhm. Tá vendo? Agora você tá com a sua irmã de novo. Isso já não seria a sua resposta?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Tem razão. Não importa o que acontecesse, eu ia trazer a Nio de volta de qualquer jeito."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Isso é bom. Nunca se arrependa do que fez..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Porque você é uma alquimista."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "...Sim."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Você provavelmente tem muita coisa pra pensar e fazer, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Por hoje, descansem bem. Vai ser bom vocês passarem um tempo juntas, só as duas irmãs."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Depois disso, se ainda tiver algo faltando, você pode voltar à ativa."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Sr. Keith..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Bom, eu vou indo nessa. Até mais."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Sr. Keith... ahn... muito obrigada por tudo."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Aquele homem parecia ser uma pessoa legal.<CR>Você conhece ele?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Aham. Ele é meio que o meu professor de síntese. Mas é..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Eu acho que o Sr. Keith é uma pessoa legal também."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x22,
            "msg_string": "Mas eu sinto que ele passou por uma experiência bem triste..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Hum... entendi. Acho que o papo tava sério mesmo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Hmhm, bom, a gente devia ir pra casa. Pro ateliê! A Pana tá esperando a gente também!"
        }
    ]
}