{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_NIO_100.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Na verdade, Senhor Keith... eu ainda não te agradeci."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Enquanto eu tava capturada, você me chamou várias vezes."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Foi bem reconfortante.<CR>Muito obrigada mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, então você escutou aquilo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Sim. Eu tava sozinha e triste, mas eu tava num lugar onde eu nem conseguia chorar..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Eu queria chorar, mas não conseguia.<CR>E aí eu escutei a sua voz gentil."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Então, mesmo estando toda sozinha,<CR>eu consegui aguentar firme."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Senhor Keith, então você tava fazendo isso por nós também...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Bom, você sabe... só enquanto eu tava investigando."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe6,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Eu só tava tentando fazer contato usando um jeito diferente do seu."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "O que você tava dizendo pra ela?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Eu esqueci. Não é nada importante."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ah, mas eu lembro. Hmm, era tipo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "\"Só tenha mais um pouquinho de paciência. Logo, a sua irmã vai vir te salvar...\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Uau, o Senhor Keith falou coisas tão legais assim...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x130,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "E-Eu só achei que seria mais eficiente."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x132,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Nio, você não precisa falar informações tão inúteis assim."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Ué? Mas não foi inútil de jeito nenhum.<CR>Eu só consegui chegar até aqui..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Graças a você, Senhor Keith!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Tá bom, eu entendi. Agora vamos encerrar essa conversa."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe6,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Enfim, a gente devia ir.<CR>Não sou muito fã de perder tempo."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "Você não precisa ficar com tanta vergonha assim..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe6,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Vou dizer isso em defesa da minha honra.<CR>Eu, de jeito nenhum, tô com vergonha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "(Senhor Keith, eu suuuper sei que você é uma pessoa gentil!)"
        }
    ]
}