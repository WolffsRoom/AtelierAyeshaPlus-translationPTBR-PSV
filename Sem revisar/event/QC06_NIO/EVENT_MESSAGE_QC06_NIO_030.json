{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_NIO_030.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "A noite hoje tá linda.<CR>A lua cheia tá tão bonita."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "*bocejo*"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Boa noite, Mana.<CR>Acooorda!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Hrrmm, Nio? Se for vir, eu prefiro que você venha um pouco mais cedo."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Eu tava passeando por aí e perdi a noção do tempo. Essa cidade é grande, então tem muita coisa pra ver."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Ahhh, Nio! Outras pessoas te viram!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Isso causou a maior confusão ultimamente. O pessoal tá falando que viu um fantasma."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x138,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Quê? Sério?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "Você não pode sair por aí arrumando confusão com quem não conhece... senão eu vou ficar brava!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13a,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Fiquei mal quando assustei um moço que eu nem conhecia..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13c,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Mas é que eu não conhecia o lugar onde eu apareci, e tava tentando entender onde eu tava..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13d,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Aí o cara tomou um susto do nada."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Entendi.<CR>Então não foi por mal?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13e,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Tentei pedir desculpas, mas ele ficou com mais medo ainda e nem quis me escutar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Então foi isso que rolou...<CR>Bom, toma cuidado da próxima vez."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Tá bom. Não vou fazer nada pra te botar em encrenca."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Ah, acho que deu a hora.<CR>Tenho que voltar agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Beleza. Toma cuidado, que já tá escuro."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Taaá bom. Até logo, Mana."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x4c,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Kyaaah!<CR>Um f-fogo-fátuo!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "Heh, foooi mal, mas eu não sou um fantasma."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x4c,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "T-Tá falando.<CR>S-Socoorro!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "Ei, escuta aqui!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x4d,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "O quê!? Um f-fantasma!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "unknown2": 0x1,
            "msg_string": "...Se não quer escutar, beleza. Eu tenho outro plano."
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "unknown2": 0x1,
            "msg_string": "Roaaarrr!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x4d,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Waaahhh, eu não tenho um gosto bom,<CR>então não me devora!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "Mwahahaha, eu vooou te devorar!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x1c,
            "msg_string": "Niooo..."
        }
    ]
