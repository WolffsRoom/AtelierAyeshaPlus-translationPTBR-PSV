        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Mas por quê...? Ela sorriu pra mim agora pouco..."
