        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Então, será que esses são mesmo os fantasmas vingativos que a Marion tava falando? *calafrio*"
