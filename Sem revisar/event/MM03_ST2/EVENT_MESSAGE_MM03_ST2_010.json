        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "O-Oi, meu nome é Ayesha."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x3b,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
