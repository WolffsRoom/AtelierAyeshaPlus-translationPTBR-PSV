        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Nio, sou eu! Não tá me reconhecendo? Olha pra mim!"
