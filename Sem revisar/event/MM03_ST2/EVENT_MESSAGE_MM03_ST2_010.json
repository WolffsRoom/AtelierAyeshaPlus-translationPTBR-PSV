            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x123,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "H-Humanos não podem simplesmente evaporar desse jeito..."
