        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Fiquei sabendo de uns relatos de pessoas desaparecendo. Pode me contar alguma coisa sobre isso?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "E-Eita! Eles sumiram...!"
