            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x4,
            "msg_string": "Mesmo quando eu uso elas pra sintetizar, elas viram umas coisas que eu nunca vi na vida..."
