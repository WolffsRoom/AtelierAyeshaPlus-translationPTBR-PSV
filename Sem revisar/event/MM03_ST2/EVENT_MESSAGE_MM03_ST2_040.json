        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x3,
            "msg_string": "Mas o que será que eu devia fazer com essas flores...? Não tem nada sobre elas nos livros..."
