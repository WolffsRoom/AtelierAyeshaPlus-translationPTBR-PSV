            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x1,
            "msg_string": "Elas parecem ser completamente diferentes das ervas medicinais que eu uso normalmente."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x2,
            "msg_string": "Que nem o Sr. Keith falou, as flores e a Nio... talvez elas tenham alguma ligação..."
