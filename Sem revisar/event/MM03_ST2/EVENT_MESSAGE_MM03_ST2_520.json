    "nb_messages": 0xc,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ah, lá está ela. Bell, eu quero te perguntar uma coisa."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hm? Tá, o que é?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Sabe aquele livro de alquimia que você me deu? Bom, aquele livro tinha um monte de informação boa."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Mas, eu já terminei de ler. Por acaso você não teria mais nenhum outro livro de alquimia?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, sim, aquele. Ééé, eu só tinha aquele livro de alquimia mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Eu sou uma bruxa, então não preciso muito de livros de alquimia."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Entendi. O livro até parecia ser valioso..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Mas eu peguei aquele livro na cidade. É, aquele cara esquisito com bigodinho fino‐"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x8,
            "msg_string": "Cara esquisito com bigodinho fino...? Você tá falando do Sr. Harry?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Isso, esse mesmo. Ele me empurrou o livro, dizendo alguma coisa sobre aprofundar a compreensão da civilização antiga."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Talvez aquele cara tenha outros livros..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0xb,
            "msg_string": "Sr. Harry... É, acho que eu devia ir perguntar pra ele."
        }
    ]
}