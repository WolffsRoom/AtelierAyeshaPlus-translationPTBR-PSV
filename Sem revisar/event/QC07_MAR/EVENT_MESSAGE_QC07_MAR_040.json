{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_MAR_040.ebm",
    "nb_messages": 0x27,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ayesha, você tá aí?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, oi Marion. Você tá aqui por causa de outra investigação?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hahaha... Parece que eu só ligo pra trabalho, é?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "D-Desculpa. É que eu nunca te vi sem estar trabalhando."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "E-Entendi. Isso é um problema sério...<CR>Pareço uma mulher que só vive<CR>pro trabalho..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Não, não acho que você \"só\" vive pro trabalho... Eu acho."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Além disso, mulheres trabalhadoras são muito legais!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "...Deixa eu te contar uma história antiga.<CR>Eu tinha uma chefe que eu admirava<CR>no mesmo departamento."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Ela encontrou seu propósito de vida no trabalho, não demonstrava interesse em relacionamentos e continuou trabalhando."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "E graças a isso, ela tem o melhor desempenho do departamento dela."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Que história legal. Tipo, se você trabalhar duro, você consegue alcançar seus objetivos..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Não, ainda não acabou. Ela me disse,<CR>\"Eu devia ter me casado.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "A-Ah, entendi..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "E me falou várias e várias vezes pra não seguir o mesmo caminho que ela."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xe9,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Isso provavelmente quer dizer que eu não deveria ficar só trabalhando tanto assim."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Hã, sei lá. Não tenho certeza se eu entendi muito bem..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xec,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Eu ainda tô de boa. Ainda tenho chance... Vai dar tudo certo."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xed,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "...Ah, é verdade. Eu vim aqui pra ver como você tava hoje."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "E aí, como foi? O livro que eu te dei foi útil?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Sim, muito! Sinto que entendo um pouquinho mais de alquimia agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Entendi. Que incrível. Conseguir ler um livro tão difícil assim..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Eu não consegui entender nadinha naquele livro."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Ele tava escrito numa língua antiga, então seria difícil pra qualquer um ler de primeira."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Meu avô me ensinou a ler aquela língua antiga."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Entendi. Será que o seu avô era um alquimista experiente..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Não sei. Ele me dizia que era um boticário..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "De qualquer forma, Marion, o livro que você me deu ajudou muito."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x1b,
            "msg_string": "Eu não sei muito sobre alquimia,<CR>mas teve uma pessoa que me mandou estudar mais sobre isso... Ah!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "O q-que foi?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Sobre essa pessoa que você tá procurando, eu... eu encontrei com ele..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x99,
            "expr_id": 0x3,
            "msg_id": 0x1e,
            "msg_string": "Sério!? O-Onde?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Na ruína atrás da minha oficina.<CR>Ele parecia estar investigando o lugar."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x9b,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Hã, naquela ruína? Eu devia ter ido lá antes..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Hã, essa pessoa... o que ele fez?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Escavação ilegal de uma ruína do governo, dano à propriedade, invasão de instalações do governo, e muito mais."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Ayesha, se você vir esse cara de novo,<CR>não deveria chegar muito perto."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Tenho certeza que ele não faria mal a pessoas comuns, mas isso não muda o fato de que ele é perigoso."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "msg_string": "(Hmm, mas ele não me pareceu uma pessoa tão ruim assim... eu acho...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x26,
            "msg_string": "(E a Marion tá pensando em trabalho de novo...)"
        }
    ]
}