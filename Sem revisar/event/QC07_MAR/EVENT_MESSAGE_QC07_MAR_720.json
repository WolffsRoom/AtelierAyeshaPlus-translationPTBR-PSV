            "name_id": 0x24,
            "extra_id": 0x1fe,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "msg_string": "Sabe, qual é o nome dela?<CR>Aquela mocinha de cabelo preto que é<CR>cheia de energia."
