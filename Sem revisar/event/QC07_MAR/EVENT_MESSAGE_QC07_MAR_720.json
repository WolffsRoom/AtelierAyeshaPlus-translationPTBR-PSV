            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x1f9,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "É por isso que os jovens de hoje em dia não dão conta do recado. *resmunga* *resmunga*"
