        {
            "type": 0x4,
            "voice_id": 0x218,
            "name_id": 0x2f,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x1,
            "msg_string": "Ah, é mesmo, não tenho visto ela por aqui ultimamente."
        },
        {
            "type": 0x4,
            "voice_id": 0x218,
            "name_id": 0x2f,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x1,
            "msg_string": "Talvez ela tenha desistido, já que você vivia enxotando ela?"
