        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x1f9,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "O quê? Ela já desistiu? Depois de ouvir não só algumas vezes...? Que frouxa."
