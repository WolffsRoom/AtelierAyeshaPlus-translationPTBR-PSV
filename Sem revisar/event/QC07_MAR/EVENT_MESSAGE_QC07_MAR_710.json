{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_MAR_710.ebm",
    "nb_messages": 0x2b,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x1f8,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "Caramba, não importa quantas vezes você venha, um não ainda é um não!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Se você mostrasse um pingo de boa vontade pra gente chegar num acordo, eu agradeceria."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hã? Essa voz é..."
        },
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x1f9,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "Não posso deixar alguém de fora entrar.<CR>E além do mais, você é amadora<CR>e mulher."
        },
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x1f9,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "O canteiro tem regras. Agora vai pra casa!"
        },
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x1fe,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "Sério, quantas vezes já te falei isso? Você não desiste, né?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Eu queria te dizer exatamente a mesma coisa."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "...Tá bom. Vou pra casa hoje,<CR>mas eu volto, não importa quantas<CR>vezes for preciso!"
        },
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x204,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "Heh, só dá o fora daqui!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Nossa... que cara teimoso!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Você parece estar passando por um aperto, Marion."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ah... bem, é o mesmo de sempre,<CR>então já tô acostumada."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Pelo visto você viu todos os meus momentos vergonhosos..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Não, não é verdade... Não acho... que isso foi vergonhoso..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Você tá aguentando firme.<CR>O Chefe é cabeça dura, então quando ele fica<CR>assim, não cede um milímetro."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Eu sei que é parte do seu trampo, mas talvez cê devesse desistir."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Não vou perder no quesito cabeça dura.<CR>Isso virou um teste de resistência."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x99,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "Vou continuar vindo fazer visitas até me deixarem entrar!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Hmm, isso vai ser difícil. O Chefe já não curte deixar mulheres entrarem na obra logo de cara..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x9b,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Mas você pode entrar de boa..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Acho que ele não me trata como mulher. Hahaha... *suspiro*"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Mas o Chefe tem razão.<CR>É bem perigoso lá dentro da ruína."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Eu entendo super isso, e se eu me machucar, a culpa é toda minha."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Entendi. Então de repente você vai ter que entrar de fininho."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Se você for de noite, certeza que ninguém vai notar. Não tem vigia e a entrada fica aberta."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Se quiser, eu posso ser sua guia.<CR>E aí, o que me diz?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Valeu pela oferta, mas vou ter que recusar."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Meu trampo não é só investigar, mas também criar boas relações com a galera daqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Quando a equipe de investigação vier,<CR>eles vão precisar de uma relação de confiança<CR>pras coisas fluírem bem."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Não posso entrar sem permissão e perder a confiança do seu chefe."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Tem que pensar em tudo isso pra fazer o seu trabalho? Ser uma oficial deve ser muito osso..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Então cê vai continuar tentando até conseguir a permissão oficial? Que barra."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Mas agora eu entendo o seu lado. Vou tentar dar um toque no Chefe pra você."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Vou falar pra ele ouvir melhor o que cê tem a dizer."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Regina... valeu mesmo. Por favor."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Mas, não sei o quanto ele vai escutar o que eu vou falar."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Eu simplesmente tô sem sorte nenhuma."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x25,
            "msg_string": "Hmm... esse é um problema e tanto..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0x5,
            "msg_id": 0x26,
            "msg_string": "Eu entendo o que o seu chefe tá tentando dizer, mas você também tem o seu trabalho..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Mas eu também saco que entrar na ruína a trabalho ainda é perigoso..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "Mas, mas, você vai estar com a Linca, então acho que pode ficar de boa..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "Hahaha, Ayesha, você não precisa ficar com essa cara de tão preocupada."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "Obrigada, Ayesha. Desculpa te fazer se preocupar."
        }
    ]
}