{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_MAR_730.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hum, hmm... Que que eu faço...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Marion? Oiii... ué?<CR>Rolou algum problema?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Sim. É sobre o chefe de Riesengang..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Eu tava pensando em como tentar convencer ele na próxima vez."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, sobre isso... Ele falou um negócio sobre você."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hã? Sério?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Sim. Ele disse algo do tipo de como aquela mocinha cheia de energia sumiu ultimamente, e tava se perguntando sobre você."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Ah, foi? Será que ele tá preocupado comigo...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xe9,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Meus outros trampos aqui tiveram o cronograma adiantado, então não deu pra eu ir, mas isso pode ser uma boa chance."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xec,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Não, eu devia dizer que provavelmente teria sido uma boa chance..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xea,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Se eu não tivesse esse outro trampo agora..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Você não pode ir pra Riesengang hoje?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xed,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Não. Eu tenho que ir pra Hornheim pegar um pacote. É urgente."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Se não se importar, eu posso ir pegar o pacote pra você."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Na verdade, eu mesma tenho que ir lá pessoalmente emitir um certificado."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Se eu não tivesse que fazer isso, eu até tava pensando em mandar a Linca ir."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x99,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "Que saco, queria que tivessem duas de mim!"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Se você conseguisse aprender... a técnica de clonagem das sombras, isso seria possível."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x9a,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "Você fala como se fosse fácil.<CR>Você consegue?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Eu tô me esforçando de verdade!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x9b,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Tá bom, tá bom."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Bom, sinto que só falta mais um empurrãozinho, mas hoje tenho que priorizar o pacote."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Vou pedir desculpas pro chefe por carta. Ayesha, obrigada por avisar."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Vou encarar isso como uma estratégia do tipo \"se não dá pra insistir, é melhor recuar\"."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "msg_string": "(A Marion tá sempre ocupada com alguma coisa mesmo.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "msg_string": "(Aposto que ser uma oficial é mais difícil do que eu imagino.)"
        }
    ]
}