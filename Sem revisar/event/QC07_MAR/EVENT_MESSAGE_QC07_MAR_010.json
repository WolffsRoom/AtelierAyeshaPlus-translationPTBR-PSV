        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "Ahhh, me desculpa mesmo!<CR>Eu vou tirar ela já, já!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7a,
            "expr_id": 0x3,
            "msg_id": 0x14,
            "msg_string": "Ei, Pana! Você tem que sair do caminho!"
