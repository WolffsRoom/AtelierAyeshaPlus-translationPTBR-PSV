        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x12,
            "extra_id": 0x122,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "Kyah! O-O que é que tem essa vaca!?"
