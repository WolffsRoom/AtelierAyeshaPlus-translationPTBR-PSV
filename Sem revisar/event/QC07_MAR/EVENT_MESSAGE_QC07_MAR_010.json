        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x21c,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "munch munch munch<CR>...Muuuu!"
