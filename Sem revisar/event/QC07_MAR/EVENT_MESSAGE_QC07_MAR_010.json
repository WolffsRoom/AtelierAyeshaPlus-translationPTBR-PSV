        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x12,
            "extra_id": 0x126,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "Acho que eu nunca vou entrar na ruína desse jeito..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Me desculpa. A Pana gosta muito de grama deliciosa..."
