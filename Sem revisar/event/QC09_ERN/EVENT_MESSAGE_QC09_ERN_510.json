{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_ERN_510.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Bom, acho que vou dar uma pauzinha. Quero almoçar também."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oi, Ayesha. Hmm... você tem um tempinho livre?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ah, claro. Eu tava mesmo prestes a dar uma pausa."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Que bom. Eu trouxe uns doces hoje..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Uau, doces! Então bora comer com um pouco de chá."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ah, tava uma delícia. Tô com energia de sobra pra trabalhar mais um pouco agora!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ah, Ernie, você queria falar comigo sobre alguma coisa?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Ué, como você sabia? Eu nem disse nada..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Dá pra perceber só de olhar pra você. A gente se conhece faz tempo."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x126,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "Saquei. É, bem, eu vim aqui hoje porque tenho um favor pra te pedir."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x127,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "Não queria pedir, já que é por motivos bem egoístas meus, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x127,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "Eu preciso muito do seu remédio."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Meu remédio? Não precisa de tanto mistério. Claro que tudo bem."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Se é pra você, fico mais do que feliz em ajudar. Além do mais, você tá sempre cuidando de mim."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Sério? Tem certeza?<CR>Tudo bem pra você mesmo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Claro! Eu posso sintetizar no meu tempo livre."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5f,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Obrigado, Ayesha! Isso vai ajudar muito!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x61,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Tenho um cliente importante que parece gostar muito do seu remédio."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Mas acabaram todos os remédios dele, então ele implorou pra eu conseguir mais pra ele."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Tenho um negócio grande vindo aí com ele, então não pude dizer não. Acha que consegue preparar o remédio?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Com certeza. Sem problemas!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Obrigado! Isso vai quebrar um galhão, Ayesha!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x102,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Desculpa por te pedir um favor pra me ajudar por motivos pessoais meus."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "(O Ernie sempre cuida de mim!<CR>Essa tarefa vai ser moleza.)"
        }
    ]
}