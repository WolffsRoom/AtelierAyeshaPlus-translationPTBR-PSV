{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_ERN_610.ebm",
    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ah, oi, Ayesha. Tem um minutinho?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "O Ernie tá agindo meio estranho ultimamente... Você sabe de alguma coisa?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "O Ernie, que tá sempre com um sorriso no rosto, parecia meio deprimido..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Tenho certeza que tem a ver com os negócios dele, mas eu sinto que não devia perguntar demais..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "(É porque o acordo importante dele não saiu como o planejado. Eu me sinto responsável também...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hum, o Ernie tava tão deprimido assim?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a6,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Sim. Era como se o sorriso dele não tivesse energia nenhuma, e a aura de mercador dele parecia ter sumido."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Como eu faço negócios com ele, eu também vou me dar mal se ele não se animar logo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Acho que eu sei o motivo... Bom, tenho quase certeza de que é esse o motivo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Mas eu acho que não devia sair falando disso com os outros pelas costas dele..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "...Ayesha, você é uma menina tão boa. É, acho que você tem razão."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Eu pergunto pra ele pessoalmente da próxima vez que a gente se ver. A gente já era amigo muito antes de ser parceiro de negócio."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "msg_string": "(O que será que o Ernie anda fazendo desde então... Eu queria muito saber.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "(Eu devia ir ver como ele tá. Só que eu não tenho certeza de onde posso achar ele.)"
        }
    ]
}