{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_ERN_120.ebm",
    "nb_messages": 0x19,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ah, ótima hora. Tenho uma coisa especial pra você, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ta-da. Dá uma olhada nisso!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "I-Isso é... uau, o quê!? Onde você conseguiu isso!? Meu Deus, ela é tão fofa!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5f,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "Né!? Sabia que você ia falar isso!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Onde você conseguiu ela!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x60,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Ela é um bicho de pelúcia que eu peguei de lembrancinha enquanto tava lá pro leste."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x63,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "Foi tipo amor à primeira vista!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x65,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Quando vi, já tinha comprado todas que tinham na loja."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Depois que me acalmei, fui checar e vi que tinha comprado dez delas."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x9,
            "msg_string": "Dez iguazinhas...? Ernie, você devia estar bem empolgado."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Não consegui me segurar. Eu nunca fiz nada parecido antes."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Mas dez é muita coisa, então tô tentando achar gente pra adotar elas."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Dito isso, essa daqui é sua. Cuida bem dela."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Hã, s-sério!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Claro. Tenho certeza que ela vai ficar feliz se ficar com você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x37,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Muito obrigada mesmo. Vou dar um nome pra ela e cuidar muito bem dela!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Ela já tem nome. É Josette."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "A Josette é um pouco tímida e na dela, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Tenho certeza que ela vai te mostrar um sorriso lindo assim que te conhecer melhor..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x39,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Hmhmhm, entendi. Não precisa ter vergonha, não dou medo nenhum."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Ela fica solitária bem fácil, então não esquece de dormir com ela de noite."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Sou muito boa em dormir com bichos de pelúcia, então deixa comigo."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Eu sou a Josette. Prazer em te conhecer, Ayesha!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Hmhm, prazer em te conhecer também, Josette!"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você conseguiu um Animal Meigo."
        }
    ]
}