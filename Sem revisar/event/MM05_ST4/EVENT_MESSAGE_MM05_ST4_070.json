            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Nossa, que teimosia. Apesar de que, pessoalmente, eu sinto uma certa afinidade."
