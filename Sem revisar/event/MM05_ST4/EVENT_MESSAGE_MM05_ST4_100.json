{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM05_ST4_100.ebm",
    "nb_messages": 0x22,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Isso traz tantas memórias...<CR>A vista não mudou nadinha..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Mesmo que a mana e a Pana tenham crescido tanto."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Nio, você tá aí. Vamos tomar café da manhã."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, desculpa mana. Eu nem ajudei."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Não se preocupa, você ficou fora por um bom tempo. É bem nostálgico, né?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Sim. Ela também cresceu. Antes ela era só um bezerrinho..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Você ficou sumida de 4 a 5 anos.<CR>Ela cresceu bastante agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Ela é forte e confiável também, né?"
        },
        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x217,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "Oink muu!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Eu aprendi a fazer mais sínteses,<CR>e conheci mais pessoas também."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Entendi. Parece que eu fui a única que ficou pra trás..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Isso não é verdade. Nio, você vai crescer de agora em diante."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Você vai conhecer um montão de gente e ver um monte de coisas... O seu tempo começa agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Um montão de gente? Isso parece... empolgante."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Posso te pedir uma coisa? Quero que você me apresente pros seus amigos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Hehe, claro."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x138,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "O quêêê!? Eu tenho que ficar em casa!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Foi mal, tem tanta coisa que eu preciso fazer..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Pra compensar, eu trago uma lembrancinha pra você. Tá bom?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13a,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Nããão! Eu quero ficar com você!<CR>Eu quero ir também!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Mas, tipo, eu vou voltar de vez em quando. Então... beleza?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "Nããão!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x16,
            "msg_string": "Hmm, isso não é bom, mas acho que ficar aqui sozinha ia ser solitário."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Então, que tal isso? Eu não posso fazer isso toda hora, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "De vez em quando, quando eu não estiver muito ocupada com o trabalho, eu te levo junto também. Que tal?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "...Se eu dissesse não, isso ia te atrapalhar?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Haha, talvez só um pouquinho..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Então, vou me contentar com isso. Não quero deixar as coisas mais difíceis pra você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Nio..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Em troca, você tem que voltar pra casa todo dia que puder..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "E me apresentar pra todos os seus amigos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Nio... Beleza, é uma promessa!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "msg_string": "(Que bom que a Nio entendeu. Agora, preciso voltar pro meu trabalho de hoje!)"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "A Nio agora pode entrar na sua equipe."
        }
    ]
}