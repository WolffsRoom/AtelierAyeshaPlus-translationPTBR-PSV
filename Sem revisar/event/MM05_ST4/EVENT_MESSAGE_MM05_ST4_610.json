{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM05_ST4_610.ebm",
    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Desculpa fazer você esperar, Sr. Keith."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Então você já se acalmou?<CR>Então vamos nessa."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Voltei. Odelia, você tá por aí?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, bem-vindo de volta. Você voltou cedo dessa vez."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Quando eu me atraso, você sempre fica de mau humor. Embora esse não seja o motivo de eu ter voltado cedo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "(Eu não reparei que a biblioteca agora é tipo a casa do Sr. Keith...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Prepare um lugar. Precisamos ter uma conversa bem longa."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Claro. Por favor, aguarde um momento."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Agora, por que você não me conta as suas ideias sobre a localização daquela coisa?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Não é como se eu conhecesse o lugar de cara. Na verdade, não faço ideia de onde seja..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Não só isso, mas um monte de coisas misteriosas aconteceram enquanto eu tava procurando a Nio."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Coisas misteriosas...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Até os fenômenos que parecem estar além da compreensão humana à primeira vista podem ser descobertos pelo que realmente são."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Vamos. Comece me contando sobre isso."
        }
    ]
}