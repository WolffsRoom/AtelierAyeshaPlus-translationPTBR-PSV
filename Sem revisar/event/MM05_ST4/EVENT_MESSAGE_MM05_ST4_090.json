{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM05_ST4_090.ebm",
    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "H-Hã...? A gente tá no jardim de ervas atrás do ateliê!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Por que será... Eu achei que a gente ia estar muito mais longe..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Depois de enfrentar aquela batalha, eu sabia que ia ser difícil fazer todo o caminho de volta."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Então, eu conectei a saída aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Sr. Keith, no final, o que era aquela coisa de guardião?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Eu só tirei uma conclusão básica, mas... não é nada que você precise se preocupar."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "A alquimia criou muitas coisas desse tipo no passado, só isso."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Por enquanto, só descanse. Você provavelmente ainda tem muito a fazer, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1cb,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "Por um tempo, não faria mal só passar um tempinho com a sua irmã."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Sr. Keith, muito obrigada por tudo."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1cf,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Por sorte, isso coincidiu com os meus próprios planos. Não precisa agradecer."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1d0,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Eu já vou indo. Adeus."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Aquele homem parecia ser uma pessoa legal.<CR>Você conhece ele?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Aham. Ele é meio que o meu professor de síntese. Mas é..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Eu acho que o Sr. Keith é uma pessoa legal também."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Bom, a gente devia ir pra casa. Pro ateliê! A Pana tá esperando pela gente também!"
        }
    ]
}