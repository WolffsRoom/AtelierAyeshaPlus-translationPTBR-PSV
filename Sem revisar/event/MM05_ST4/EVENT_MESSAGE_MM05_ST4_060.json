        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Foge daqui. Eu vou ficar bem."
