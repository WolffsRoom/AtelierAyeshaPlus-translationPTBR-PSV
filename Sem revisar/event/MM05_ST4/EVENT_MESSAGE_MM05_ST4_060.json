            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Mana! Você veio mesmo me buscar!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Sim. Nio, você foi muito bem aguentando firme até agora. Vamos voltar juntas pro ateliê...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Acho que não consigo... A pessoa daqui tá muito brava, e ele não vai me deixar sair daqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Se for só por um tempinho, acho que consigo segurar ele. Então, mana..."
