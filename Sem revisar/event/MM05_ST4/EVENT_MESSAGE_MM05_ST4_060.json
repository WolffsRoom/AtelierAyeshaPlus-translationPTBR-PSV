            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Já é o bastante você ter vindo até aqui por mim!"
