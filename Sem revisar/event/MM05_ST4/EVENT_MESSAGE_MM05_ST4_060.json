            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hmm... Você é bem valente. O completo oposto do que você costuma ser."
