            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7a,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "Como irmã mais velha, é aqui que eu tenho que me manter firme."
