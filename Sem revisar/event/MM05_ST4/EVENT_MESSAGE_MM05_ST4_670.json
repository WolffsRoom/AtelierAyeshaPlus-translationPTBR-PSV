{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM05_ST4_670.ebm",
    "nb_messages": 0x29,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Mana, mana... Acorda, mana...!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "unknown2": 0x1,
            "msg_string": "Hrmm, só mais cinco minutinhos...<CR>Nãão, na verdade mais dez minutinhos..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Caramba, você ainda é tão ruim de acordar de manhã... Acorda logooo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Hã...? Nio!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x138,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Wah! Não acorda tão de repente assim!<CR>Você me assustou!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ah, desculpa. Eu fiquei te esperando me visitar por tanto tempo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Eu tô tão feliz. Pensei que talvez não fosse mais conseguir te ver."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13a,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Nossa, faz tanto tempo assim? Eu fiquei dormindo o tempo todo, então nem notei."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Mesmo quando eu acordava de vez em quando, tava tudo escuro e eu não conseguia achar a saída..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Eu não conseguia saber onde você tava."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Era como se eu estivesse trancada em algum lugar."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Mas, tô feliz que pude te ver de novo, mana."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Hehe, eu também. Tô tão feliz de ver seu rosto..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Ah, é mesmo! Eu fiz isso pra você, Nio. Viu, não é fofo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Então, mesmo que a gente esteja longe, ainda vamos sentir que estamos pertinho."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Você... fez isso?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Sim! Eu dei um duro danado nisso!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Oba! Obrigada, mana!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Hmhmhm, é muito fofo! Como será que eu devo chamar..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Você fica tão fofa segurando um bichinho de pelúcia!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "A sua ideia do que é fofo nem sempre é muito confiável..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Você diz que tudo que eu visto ou tenho é fofo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "É que... realmente é tudo fofo.<CR>Não tô mentindo pra você."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Hehe, mas essa pelúcia é fofa mesmo. Obrigada, mana."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "Sinto que você vai estar perto de mim a partir de agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x19,
            "msg_string": "Vou cuidar muito bem dele."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Ei, acorda. Até quando você planeja cobiçar esse sono?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "Hrmm, a Nio é tão fofa...<CR>Ela parece uma fadinha...<CR>Zzz zzz..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Você não pode se esconder atrás dessa<CR>cara de sono estúpida pra sempre.<CR>Tô mandando você acordar!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "*bocejo* ...Ah, Sr. Keith. Bom dia."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "É verdade. Eu tava dando a pelúcia pra Nio..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Pelo visto, parece que você conseguiu entregar pra ela."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Onde ele tá agora?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "A agulha tá apontando... pro nordeste daqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x91,
            "expr_id": 0x3,
            "msg_id": 0x22,
            "msg_string": "Eu lembro que não tinha nada nessa área... Acho que era tudo um truque."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Primeiro, acho que vou lá dar uma olhada. Vai que eu consigo ver a Nio!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x93,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Ótimo. Do jeito que as coisas tão indo, quanto mais cedo você agir, melhor. Porém..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Ele não parece ligar pra machucar os humanos."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Com tudo o que você passou,<CR>eu sei que não vai cair fácil,<CR>mas garanta que esteja totalmente preparada."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Se for necessário, eu vou com você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "Muito obrigada. Vou me preparar agora mesmo!"
        }
    ]
}