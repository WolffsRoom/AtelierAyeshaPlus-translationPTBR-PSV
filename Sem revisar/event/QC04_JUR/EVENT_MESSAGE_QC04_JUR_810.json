{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_810.ebm",
    "nb_messages": 0x1e,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ayesha, tem uma coisa que eu gostaria de falar com você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, Juris, o que foi? Você tá com uma expressão mais séria que o normal..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Já faz um bom tempo desde que comecei a viajar com você..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "E ultimamente, sinto que minhas habilidades melhoraram."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Agora mesmo, tanto a minha força física quanto a minha energia tão no auge."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "E por isso, comecei a pensar em testar minhas habilidades."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Testar... suas habilidades...?<CR>Você quer dizer...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "É. Finalmente, eu vou... derrotar o dragão."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Um dragão!? Você diz aquele gigantão, né!? Isso é impossível, Juris, até pra você!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "É, provavelmente é impossível eu fazer isso sozinho. Então... eu quero que você venha comigo."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Eu preciso de você.<CR>...Eu preciso do seu poder."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "O-O jeito que você falou isso... me deixou morrendo de vergonha..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Mas, como assim você precisa do meu poder?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Quero dizer que preciso que você venha comigo pra caçar o dragão."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Ehhh, você quer a m-mim!? P-P-Por quê?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Porque você é uma guerreira forte."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "msg_string": "(Guerreira forte...? Mas eu sou uma garota. Isso é meio chato...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Apesar de você parecer estar sempre no mundo da lua, e de eu não conseguir dizer se você tá dormindo ou acordada..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Hmm, eu tô acordada..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "...Mas suas habilidades de combate, e, acima de tudo, sua força mental..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Eu não conheço nenhum outro guerreiro como você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc5,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Mas eu não sou uma guerreira, sou uma boticária..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x49,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "Eu confio no seu poder.<CR>Acredite em si mesma!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Mesmo você dizendo isso... eu não acho que vou dar conta de lutar contra um dragão."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x4b,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "Eu tenho uma boa ideia de onde fica o ninho dele."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Fica em algum lugar no deserto a oeste. Por favor, se prepare."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x1a,
            "msg_string": "No deserto a oeste...?<CR>É uma área muito vasta."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Pera aí, Juris, eu ainda não disse que vou fazer isso!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Lá vai ele... será que isso significa que vou ter que me juntar a ele nessa caçada ao dragão?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc7,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "Aaaaarrrgh. Não, não, com certeza é impossível pra mim..."
        }
    ]
}