        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Preso desse jeito... Fico com pena..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xdb,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "...Ele causou um monte de problemas.<CR>Não tem nada que a gente possa fazer."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xe0,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Mas, o que machucaria o orgulho dele mais que isso...?"
