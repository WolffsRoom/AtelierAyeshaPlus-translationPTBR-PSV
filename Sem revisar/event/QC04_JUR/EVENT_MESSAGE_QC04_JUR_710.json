        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa8,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Enfim, ele é grandão mesmo. Agora sei por que tava todo mundo falando dele."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Ele é sim. Mas, o que um lobo tá fazendo num lugar desses?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa9,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "Já que ele tem um pelo tão bonito, acho que ele vai ficar em exibição por um tempo."
