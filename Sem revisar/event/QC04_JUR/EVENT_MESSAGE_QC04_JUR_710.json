        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xaa,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "É perigoso chegar muito perto.<CR>Ele poderia arrancar seu braço fininho<CR>num piscar de olhos."
