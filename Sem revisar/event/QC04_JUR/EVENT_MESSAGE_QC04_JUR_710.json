        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Entendi... Que pena.<CR>Bom, deixando isso de lado..."
