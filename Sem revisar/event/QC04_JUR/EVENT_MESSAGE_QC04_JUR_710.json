        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hmm, tá tão cheio de gente lá. Por que será..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Uau, tem um lobo gigante...!<CR>O que ele tá fazendo aqui...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ele é o líder da alcatéia de lobos que anda causando problemas nos pastos daqui."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ele é muito esperto, mas finalmente pegamos ele."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, Mix Master, você tá dando uma volta?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa2,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Fiquei sabendo que o lobo tava na cidade e vim ver. Mas não achei que fosse te ver aqui também."
