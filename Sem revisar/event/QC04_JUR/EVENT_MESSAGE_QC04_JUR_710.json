        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "E-Eu tô de boa. Ele tá numa jaula..."
