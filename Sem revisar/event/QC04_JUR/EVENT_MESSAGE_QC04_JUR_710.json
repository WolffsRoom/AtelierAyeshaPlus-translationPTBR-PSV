            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Onde você tava, me enfiando atrás daquele balcão minúsculo..."
