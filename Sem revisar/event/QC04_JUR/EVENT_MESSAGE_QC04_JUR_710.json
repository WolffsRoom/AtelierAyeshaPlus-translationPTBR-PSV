        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Se ficar com medo, pode pular nos meus braços quando quiser."
