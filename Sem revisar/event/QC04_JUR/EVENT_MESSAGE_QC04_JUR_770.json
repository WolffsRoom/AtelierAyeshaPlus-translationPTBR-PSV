{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_770.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Ufa, c-conseguimos..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xda,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Ayesha, me desculpa por te envolver nisso."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc5,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Não, tudo bem. Acho que era inevitável, dadas as circunstâncias."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "É que eu fico com um pouco de dó do lobo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xdc,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Esse era o único caminho dele na vida.<CR>Não precisa sentir pena."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "E agora, o que a gente faz com ele? Normalmente, eu pegaria a pele pra vender, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "O que foi, Ayesha?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hmm, você pode deixar esse lobo comigo...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Acho que tá bom. Acredito que o lobo pode descansar em paz agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xda,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Nem uma lápide nem nada...<CR>É um túmulo um tanto solitário."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xdb,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Mas quem tiver atrás da pele dele não vai saber que ele tá aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xdc,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ainda assim, essa é minha primeira vez fazendo um túmulo pra minha presa."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Não é o tipo de ideia que um caçador<CR>teria, mas isso pode ser uma boa,<CR>do jeito que tá."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Juris, você me disse pra não sentir pena dele, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Meu coração aperta quando eu penso nos sentimentos desse lobo."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Nessa terra, com poucos recursos, é difícil pra humanos e feras se darem bem."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Sentir pena toda vez faria a gente passar fome."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "É assim... que funciona?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Mesmo assim, ele pôde morrer como alguém que caça, não como alguém que é caçado."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Ele pode não concordar ou não ficar satisfeito... Mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Vamos escolher acreditar que, pelo menos, ele não teve arrependimentos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Tem razão... Ou eu acho que não me resta outra escolha além de pensar assim."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "É isso aí. Agora, vamos voltar pra cidade e contar pro Kyle."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "É. Tenho certeza que ele também tá preocupado com a gente."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Sei não... Conhecendo ele, talvez já tenha até esquecido do lobo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Bom, falar com aquele tagarela vai espalhar rapidinho que o lobo foi exterminado."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Muito provavelmente. A gente precisa tranquilizar o pessoal da cidade!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "(Tenho sentimentos mistos, mas... acho que foi melhor assim...)"
        }
    ]
}