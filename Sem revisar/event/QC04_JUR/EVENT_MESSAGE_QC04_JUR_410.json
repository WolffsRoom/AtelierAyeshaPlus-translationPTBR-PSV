            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xda,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Mas, minhas vendas não tão indo muito bem. Se você puder parar e dar uma olhadinha, eu ficaria grato."
