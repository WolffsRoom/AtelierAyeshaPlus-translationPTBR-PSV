{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_120.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "O sol vai se pôr logo.<CR>A gente devia acampar aqui esta noite."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Concordo. Então eu vou preparar nossa comida..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Não. A gente não vai conseguir manter a energia só com ração de viagem."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Eu não vou demorar, então me espera aqui um pouco."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Uau. Então, vou deixar uma sopa quentinha te esperando quando você voltar!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Sopa quentinha...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Qual é o problema? Você preferia uma sopa fria?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Não... Só lembrei que minha mãe e meu pai tinham conversas tipo essa..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Ah, agora que você tocou no assunto, parece mesmo um papo de marido e mulher..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "O seu pai também era caçador?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Sim. Ele era o caçador mais habilidoso da nossa família. Sempre que ele saía pra caçar, voltava pra casa com uma grande presa."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ele era meu herói e meu objetivo era alcançar o nível dele algum dia. Porém..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ele faleceu há alguns anos. Ele saiu pra caçar um dia e nunca mais voltou."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Entendo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Os caçadores ganham a vida tirando a vida das feras. Não sei se teve algo a ver com isso, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Poucos de nós morrem de velhice."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Dizem que a vida circula e passa pra próxima vida."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Bom, esse trabalho tá sempre cercado de perigos. É tipo uma superstição."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Juris. Hmm, por favor, volta a salvo."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Eu não pretendo caçar nada perigoso agora, então não precisa se preocupar."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x19e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Bom, eu vou indo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "(A esposa de um caçador... Tenho certeza que ela ficaria super preocupada até o marido voltar pra casa...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "(Peraí, no que é que eu tô pensando...?)"
        }
    ]
}