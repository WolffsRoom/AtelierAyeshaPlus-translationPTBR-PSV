{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_630.ebm",
    "nb_messages": 0x17,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Juris, essa cama já tá boa pra você?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Tá sim. Eu consigo dormir em qualquer lugar, desde que eu tenha um cobertor."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Você não pode fazer isso. Fica frio de noite, você pode ficar doente."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Cê deveria pegar esse cobertor sobrando também."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, parece que eles tão no meio de alguma coisa... Vocês tão ocupados?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Bom, já que os bezerros tão grandinhos agora,<CR>e eu me viro bem sozinha..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Eu tava pensando em voltar a caçar."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Eu sempre arrumo as coisas pro meu irmão. Se eu não fizesse isso, ele só levaria o básico do básico."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Foi mal, Ayesha, mas eu falo com você depois."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "...É verdade. Ayesha, tem uma coisa que eu preciso te falar..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Fiquei sabendo que você ajudou a Nanaca com o bezerro dela antes."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Acho que a gente nunca te pagou por isso."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "O quê? Não precisa me pagar. Eu não posso aceitar dinheiro por uma coisinha dessas."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Além disso, a Nanaca é minha amiga."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Eu imaginei que você diria isso,<CR>mas eu não posso deixar por isso mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "É costume na minha família agradecer, e não só com palavras, mas com atitudes também."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Mas eu realmente não posso aceitar dinheiro.<CR>Eu me sentiria super mal depois."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Hmm, entendi... Então que tal isso?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Eu já caço faz um bom tempo.<CR>Eu me considero bem treinado nas<CR>habilidades necessárias pra me proteger."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Se você precisar da minha ajuda, é só vir falar comigo. Eu vou te emprestar minha força como pagamento."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x14,
            "msg_string": "Ah, sério? Isso vai me ajudar bastante."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "(Ter o Juris comigo seria muito bom. Talvez eu devesse pedir ajuda pra ele qualquer hora.)"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Juris agora pode entrar na sua equipe."
        }
    ]
}