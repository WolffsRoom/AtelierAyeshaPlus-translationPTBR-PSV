{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM09_ED2_030.ebm",
    "nb_messages": 0x3e,
    "messages": [
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "unknown2": 0x1,
            "msg_string": "Visitantes de um país distante.<CR>A interação delas com Ayesha começou<CR>com o menor dos eventos."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x1,
            "msg_string": "As duas tinham uma relação interessante,<CR>e antes que percebesse, Ayesha se viu<CR>profundamente intrigada por isso."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "Porém, essas visitantes eventualmente tiveram<CR>que partir. Ao irem embora, Marion e<CR>Linca fizeram uma proposta inesperada."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x1,
            "msg_string": "Ayesha, obrigada por tudo. Finalmente consegui cumprir minha missão..."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x1,
            "msg_string": "E é tudo graças à sua ajuda.<CR>Muito obrigada por tudo que você<CR>fez até agora."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x1,
            "msg_string": "Então vocês têm que ir pra casa... Pensar que vocês duas vão embora..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "Me deixa tão triste..."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x1,
            "msg_string": "Não faça essa cara.<CR>Ficar triste... é o mesmo pra nós também."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "Numa terra onde nunca estivemos antes, conhecendo e interagindo com pessoas que nunca tínhamos visto..."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x1,
            "msg_string": "Conseguimos nos adaptar tranquilo a essa vida logo de cara graças a você, Ayesha."
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "Por sua causa, não pulamos nenhuma refeição. É tudo graças a você, Ayesha."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "Tá bem... *snif* Hmm, será que vou ver vocês duas de novo?"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Claro! ...É o que eu gostaria de dizer, mas a verdade é que não tenho certeza."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "Tudo depende dos chefões se vamos ou não ser incluídas na próxima equipe de expedição que for enviada..."
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "Ayesha, ser a faz-tudo é osso..."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "Esse lugar é muito longe pra eu visitar na minha folga..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "O quê...? Então eu posso mesmo nunca mais ver vocês...? *snif*"
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "Sobre isso, Ayesha... A Marion tem uma coisa pra falar com você."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x1,
            "msg_string": "*snif* *snif* ...Hã? Uma coisa pra falar comigo?"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "É. Eu tava debatendo se devia ou não te contar isso, mas..."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "A gente também não quer que esse seja o nosso adeus."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "Mas não queremos te pressionar.<CR>Queremos que você pense por<CR>conta própria e tome a sua própria decisão."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "T-Tá... O que é...?"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "Vamos voltar pro centro. Não é igual a aqui, mas não é um lugar ruim."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "unknown2": 0x1,
            "msg_string": "Pra nossa terra... você gostaria de...?"
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "unknown2": 0x1,
            "msg_string": "Você gostaria de vir com a gente, Ayesha!?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Hã‐eu...? Pra cidade de vocês...?"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "Mais do que uma cidade, é administrada como uma nação."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "unknown2": 0x1,
            "msg_string": "Nossa nação oferece bastante apoio aos alquimistas. Temos vários alquimistas como você também."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "unknown2": 0x1,
            "msg_string": "Quero muito que você pense no assunto. É uma decisão que vai mudar muito a sua vida."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "unknown2": 0x1,
            "msg_string": "Mas se der vontade de vir com a gente..."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "unknown2": 0x1,
            "msg_string": "Vamos te ajudar quando chegarmos lá, do mesmo jeito que você ajudou a gente."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "unknown2": 0x1,
            "msg_string": "Né, Linca?"
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "unknown2": 0x1,
            "msg_string": "Claro. A Ayesha é nossa companheira,<CR>nossa parça, nossa amigona."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "unknown2": 0x1,
            "msg_string": "Marion, Linca... muito obrigada."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "unknown2": 0x1,
            "msg_string": "Eu...!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x24,
            "unknown2": 0x1,
            "msg_string": "...Foi uma história tão emocionante.<CR>Então como é que viemos parar nessa situação?"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "unknown2": 0x1,
            "msg_string": "Foi mal por isso. Eu não achei que a gente ia receber ordens de transferência na viagem de barco pra casa."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x26,
            "unknown2": 0x1,
            "msg_string": "Aquilo foi totalmente inesperado... *suspiro*"
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x27,
            "unknown2": 0x1,
            "msg_string": "Marion... tá calor. Solicitando permissão pra cortar meu cabelo."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x28,
            "unknown2": 0x1,
            "msg_string": "Não, de jeito nenhum!"
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x29,
            "unknown2": 0x1,
            "msg_string": "Então, solicitando permissão pra tirar minhas roupas..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2a,
            "unknown2": 0x1,
            "msg_string": "O quê!? De jeito nenhum também!"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2b,
            "unknown2": 0x1,
            "msg_string": "Além disso, faz um frio absurdo de noite. Então é só esperar até lá."
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2c,
            "unknown2": 0x1,
            "msg_string": "Poxa..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2d,
            "unknown2": 0x1,
            "msg_string": "*arf* *arf* Ah, Marion! Tem água ali!"
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2e,
            "unknown2": 0x1,
            "msg_string": "*arf* *arf* Á-Água gelada!"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2f,
            "unknown2": 0x1,
            "msg_string": "Hã? Eu te garanto, não tem água nenhuma por aqui."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x30,
            "unknown2": 0x1,
            "msg_string": "É só uma miragem.<CR>Não perca tempo correndo atrás dela."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x31,
            "unknown2": 0x1,
            "msg_string": "O q-que é uma miragem...?"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x32,
            "unknown2": 0x1,
            "msg_string": "Uma ilusão que te faz ver água num dia quente."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x33,
            "unknown2": 0x1,
            "msg_string": "Você vai ter que esperar a gente voltar pro centro pra tomar água gelada."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x34,
            "unknown2": 0x1,
            "msg_string": "E quando isso vai acontecer...?"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x35,
            "unknown2": 0x1,
            "msg_string": "Vai saber. Pode levar três ciclos completos de estações."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x36,
            "unknown2": 0x1,
            "msg_string": "O quê!? Você quer dizer três anos!?<CR>Não pode ser..."
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x37,
            "unknown2": 0x1,
            "msg_string": "Isso é tudo porque a Marion é uma faz-tudo..."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x38,
            "unknown2": 0x1,
            "msg_string": "O que você disse!? Não é como se eu tivesse pedido pra ser transferida!"
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x39,
            "unknown2": 0x1,
            "msg_string": "Ugh, que seja, então! Já cheguei até aqui,<CR>então vamos acabar logo com isso!"
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3a,
            "unknown2": 0x1,
            "msg_string": "Ayesha, o que a Marion tá querendo dizer é que a vida é cheia de incertezas que apontam pra um futuro sombrio."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3b,
            "unknown2": 0x1,
            "msg_string": "Gaaahhh. Mas se for sombrio, pode ser que esfrie as coisas..."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3c,
            "unknown2": 0x1,
            "msg_string": "Ei, vocês aí, parem de bater papo. Só vão fazer a garganta de vocês secar."
        },
        {
            "type": 0x4,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3d,
            "unknown2": 0x1,
            "msg_string": "Agora, ruína antiga que dorme nas areias do deserto, me aguarde!"
        }
    ]
}