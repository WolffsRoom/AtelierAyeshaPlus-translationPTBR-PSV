{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM09_ED2_040.ebm",
    "nb_messages": 0x24,
    "messages": [
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "unknown2": 0x1,
            "msg_string": "Enquanto Juris e Ayesha continuavam a viajar<CR>juntos, eles passaram a aceitar que<CR>sempre cuidariam das costas um do outro."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x1,
            "msg_string": "A ambição do Juris de matar o dragão...<CR>O sucesso dessa batalha heroica<CR>foi só o prólogo da história dele."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "Desejando um oponente forte...<CR>Hoje, a jornada deles continua..."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x1,
            "msg_string": "Ayesha, de acordo com a informação, nosso alvo dessa vez tem a cabeça de um gato, as patas dianteiras de um urso..."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x1,
            "msg_string": "As asas de um morcego, e tem até uma centopeia no lugar do rabo."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x1,
            "msg_string": "Hmm, parece que esse alvo não tem uma identidade específica..."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "É tão grande que tem quase a altura daquele dragão que derrotamos um tempo atrás."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x1,
            "msg_string": "E a selvageria dele é ainda maior que o próprio tamanho."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "Entendi. Vai ser um inimigo formidável. Ah, mas..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x1,
            "msg_string": "Se tem cabeça de gato, então deve ser vulnerável a cascas de laranja."
        },
        {
            "type": 0x4,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "Quer dizer, não a casca em si, mas o líquido que sai quando você espreme a laranja, né?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "É, é, isso mesmo!"
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Bom... nosso alvo simplesmente se parece com um gato..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "E isso não significa necessariamente que laranjas vão ser o ponto fraco dele...?"
        },
        {
            "type": 0x4,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "O queee!? Mas, a gente nunca vai ter certeza se não tentar."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "Concordo. Então, vamos até a cidade comprar umas laranjas..."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "Peraí. Não sabemos quando ele vai passar por aqui."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "Talvez você não volte a tempo se for fazer compras agora."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x1,
            "msg_string": "Ah, é verdade. Hmm, que droga..."
        },
        {
            "type": 0x4,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Ah, peraí! Pensando bem, eu tenho algumas laranjas comigo!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "Uau! Nanaca, você tá super preparada!"
        },
        {
            "type": 0x4,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "Hehehe, elas pareciam tão gostosas.<CR>Toma, Ayesha, essa é pra você."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "Valeu, Nanaca. Parece tão gostosa!"
        },
        {
            "type": 0x4,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "Toma, e essa aqui é pra você."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "unknown2": 0x1,
            "msg_string": "...Como que eu vou usar isso?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "unknown2": 0x1,
            "msg_string": "Ah, tá tão azedinha e doce e deliciosa! Tá super madura."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Por que vocês tão comendo agora? Vocês duas, escutem, caçar é‐"
        },
        {
            "type": 0x4,
            "voice_id": 0x233,
            "name_id": 0x55,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "*squeeeak*"
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "unknown2": 0x1,
            "msg_string": "Oh."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "unknown2": 0x1,
            "msg_string": "Ohh."
        },
        {
            "type": 0x4,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "unknown2": 0x1,
            "msg_string": "Ohhh..."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "unknown2": 0x1,
            "msg_string": "Ah droga, ele passou batido!<CR>Vamos atrás dele, Ayesha!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "unknown2": 0x1,
            "msg_string": "Hã? Mas eu ainda tô comendo a minha laranja, e..."
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "unknown2": 0x1,
            "msg_string": "Agora não é hora pra isso...!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "unknown2": 0x1,
            "msg_string": "A-Acho que você tem razão.<CR>V-Vamos atrás dele."
        },
        {
            "type": 0x4,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "unknown2": 0x1,
            "msg_string": "Boa sorte pra vocês. Se cuidem."
        }
    ]
