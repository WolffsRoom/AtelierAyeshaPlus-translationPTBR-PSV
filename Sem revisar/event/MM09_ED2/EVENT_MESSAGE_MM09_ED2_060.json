{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM09_ED2_060.ebm",
    "nb_messages": 0x28,
    "messages": [
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "unknown2": 0x1,
            "msg_string": "Por sua própria natureza, a Ayesha dava duro<CR>em tudo que fazia e ficou<CR>craque em trabalhar pra quem entendia das coisas."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x1,
            "msg_string": "Nenhum trabalho é pequeno ou difícil demais pra Ayesha...<CR>Esse boato se espalhou por toda parte, e os pedidos<CR>de trabalho chegavam até do outro lado das montanhas."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "Hoje, uma montanha de pedidos de trabalho foi entregue pra Ayesha, de novo..."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x1,
            "msg_string": "Hum, como você me falou, eu saí logo pra pegar os pedidos de remédio, mas..."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x1,
            "msg_string": "Acho que eu peguei até demais..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x1,
            "msg_string": "Pera um segundo. Deixa eu ver..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "860 frascos de pomada, 360 frascos<CR>de remédio pra resfriado, 500 dias<CR>de analgésicos, 4 barris de tônico..."
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x1,
            "msg_string": "Uau... nunca vi um barril como unidade de pedido..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "Hmm, barril...<CR>E logo quatro barris...!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x1,
            "msg_string": "Aham. São barris. Q-u-a-t-r-o barris."
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "Hehehe, barril, barril, quatro barris!"
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "É. Tudo isso, e o prazo de entrega é daqui a um mês... Acho que me empolguei um pouco."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Como eu imaginava, acho que isso nem se qualifica só como \"muito\"."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "Se precisar, posso negociar pra adiar o prazo de entrega..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "Não, tá tudo bem! Recentemente eu pensei num jeito bom de fazer isso!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "Um jeito de fazer um monte de remédio, tudo de uma vez! Usando essa técnica, acho que consigo dar conta em um mês."
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "Mas maninha... você não tá preocupada de não ter ingredientes suficientes pra tudo isso?"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "A gente não tem tantas ervas medicinais assim no estoque, né?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x1,
            "msg_string": "*suspiro*"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Se a gente colher tudo por aqui, vamos esgotar o estoque e elas não vão crescer de novo."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "Ai, o que eu faço...?"
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "Será que eu mudo o prazo então?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "Não... Eu não posso fazer isso perto da oficina, mas se eu for pra outro lugar..."
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "Se eu me lembro bem, tinha um matagal perto de Hornheim!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "unknown2": 0x1,
            "msg_string": "Ernie, é isso. A gente vai dar conta!"
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "unknown2": 0x1,
            "msg_string": "Beleza. Então, deixo com você."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Aham. Mas pra fazer isso..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "Quero que você leve a Nio pra Hornheim o mais rápido possível..."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "unknown2": 0x1,
            "msg_string": "O quê? Mas a Nio sozinha?<CR>Tem certeza...?"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "unknown2": 0x1,
            "msg_string": "Eu vou ficar bem. Fiquei vagando sozinha por um tempão num lugar que eu nem entendo direito!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "unknown2": 0x1,
            "msg_string": "Comparado com isso, fazer uma entrega é moleza."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "unknown2": 0x1,
            "msg_string": "Entendi. Então vamos juntos, Nio."
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "unknown2": 0x1,
            "msg_string": "Valeu por me levar, Ernie!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "unknown2": 0x1,
            "msg_string": "Maninha, eu vou cumprir minha missão, e vou ficar maravilhosa fazendo isso!"
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "unknown2": 0x1,
            "msg_string": "Certo então, Ayesha, vamos dar um pulo rápido em Hornheim!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "unknown2": 0x1,
            "msg_string": "Tá bom. Boa sorte!"
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x24,
            "unknown2": 0x1,
            "msg_string": "Hmhmhm, vocês estão cheias de energia mesmo."
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "unknown2": 0x1,
            "msg_string": "Essa é a nossa melhor qualidade."
        },
        {
            "type": 0x4,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x26,
            "unknown2": 0x1,
            "msg_string": "Vocês estão me dando energia também.<CR>Beleza, vamos lá!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x27,
            "unknown2": 0x1,
            "msg_string": "Uhuu!"
        }
    ]
}