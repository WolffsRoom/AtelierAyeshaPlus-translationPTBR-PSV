{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM09_ED2_010.ebm",
    "nb_messages": 0x1e,
    "messages": [
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "unknown2": 0x1,
            "msg_string": "A garota que usa magia e é um pouco atrevida,<CR>imprudente e cheia de energia. Talvez essa<CR>garota tenha lembrado Ayesha de sua irmã."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x1,
            "msg_string": "Magia e alquimia... suas ocupações que parecem<CR>tão iguais, mas são bem diferentes,<CR>podem ter aproximado as duas."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "Apenas alguns anos depois de se conhecerem, Wilbell<CR>e Ayesha se tornaram inseparáveis.<CR>Sua história sem fim começa agora..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x1,
            "msg_string": "Kyah! Bell, voa um pouco mais devagar!"
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x1,
            "msg_string": "Nem pensar. Se eu voar mais devagar, já vai tá de noite quando a gente chegar."
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x1,
            "msg_string": "A gente tem que perguntar pra minha tataravó se nós duas podemos abrir uma loja juntas..."
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "Temos que chegar lá no horário combinado!"
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x1,
            "msg_string": "Uma bruxa nunca pode se atrasar pra um compromisso!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "Hurgh, pode até ser, mas mesmo assim... você tá indo rápido demais!"
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x1,
            "msg_string": "Tudo bem, a gente tá no céu."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "Bell, se você não tivesse errado o bolo tantas vezes..."
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "Você prometeu que não ia falar disso! O último que assei ficou ótimo, não se preocupa!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Fui eu que assei o último, praticamente..."
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "Você prometeu que não ia falar disso também!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "Uau! Acho que eu preferia ter feito uma viagem tranquila de carruagem..."
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "...Ayesha, tá pronta? Manobras evasivas!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "Kyaaah!"
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "E agora um looping!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x1,
            "msg_string": "Uyaaah! Paaaaaara!"
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Hehe, não é muito esperto irritar uma bruxa quando você tá no céu."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "Só voa reto. O vento tá levantando minha saia..."
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "Sem crise! Dessa altura, ninguém consegue ver!"
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "Dá sorte de tá na vassoura da Senhorita Wilbell. Não esquenta com os detalhes."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "Nossa. Bell, você é tão mandona..."
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "unknown2": 0x1,
            "msg_string": "Hmhm, não importa o que você diga, enquanto a gente tiver voando-! Ah, olha, Ayesha!"
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "unknown2": 0x1,
            "msg_string": "Olha o oceano!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Uaaau, é tão grande! Eu nunca tinha visto o oceano antes!"
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "Minha casa fica a um pulinho daqui!"
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "unknown2": 0x1,
            "msg_string": "Agora, reta final! Segura firme, porque agora a gente vai voar com vontade!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "unknown2": 0x1,
            "msg_string": "Ahhh! Pera aí, mais devagar por favor! Tem que ter pressa, mas devagar..."
        }
    ]
}