            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "É pra mim? Nossa, muito obrigada!"
