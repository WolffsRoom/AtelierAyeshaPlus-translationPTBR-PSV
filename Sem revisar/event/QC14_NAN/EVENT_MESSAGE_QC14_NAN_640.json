{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC14_NAN_640.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Eu achei a Poro, mas perdi ela de vista..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Entendi. Obrigada por avisar, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc5,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Que isso, me desculpa por não conseguir trazer ela de volta."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Não se desculpe. O caminho das estrelas decidiu o destino dela."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "A-As estrelas?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "No céu noturno. Sabe como as estrelas fazem movimentos complicados? Igual uma engrenagem."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Todo ser vivo nesse mundo tem uma estrela, e..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "O movimento das estrelas decide o nosso destino, ou pelo menos é o que dizem."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Então não é culpa sua a Poro ter sumido."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Entendo..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "Além disso, fico feliz em saber que ela parecia tá bem sozinha."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Eu tava tão preocupada em deixar ela sozinha, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Se a sua irmã vai estar do lado dela, fico mais tranquila."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Obrigada por se preocupar com a Poro, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "(Ela tá tentando ser entusiasmada, mas acho que ainda tá pra baixo...)"
        }
    ]
}