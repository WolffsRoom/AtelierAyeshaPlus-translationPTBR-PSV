{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC14_NAN_090.ebm",
    "nb_messages": 0x20,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x0,
            "msg_string": "Hmm, tô meio entediada..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x1,
            "msg_string": "Tô muito longe pra ir na casa de alguma amiga..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x2,
            "msg_string": "Eu me pergunto... onde a Nanaca deve estar agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15d,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "(Espera, sempre que eu penso na Nanaca, ela sempre...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, sim. Tô indo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "(Será que...?)"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Oi, Ayesha. Vim te visitar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Uau, eu sabia! Falando no anjo, a Nanaca!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Hehehe, eu queria te fazer uma surpresa. Funcionou?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Bom, eu meio que tive um pressentimento que podia ser você."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "O quê!? Como?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Porque sempre que eu penso em como você deve estar, você sempre aparece."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Enfim, entra, por favor. Vou te servir um chá!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x141,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Uau, então esse é o seu ateliê?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x143,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Ah, espero não estar atrapalhando nada."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Imagina! Eu tô muito feliz que você veio."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Eu tava bem pensando que seria ótimo se você viesse me visitar."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Ahh, então talvez os insetos tenham nos juntado."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "I-Insetos?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Insetos que dizem viver junto com os humanos. Eles têm o poder de ler os sentimentos das pessoas."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x186,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Eles pegam os desejos subconscientes e contam pra outra pessoa."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Bom, eu tava realmente pensando que queria te ver..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Eu também. Quando cheguei por aqui, de repente comecei a pensar em você."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x17,
            "msg_string": "Hmhmhm, então os insetos devem ter contado pra gente."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Nanaca, você é tão misteriosa. Fico surpresa que tenha conseguido encontrar o meu ateliê."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Eu só achei que podia ser por aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Eu ia só encontrar o ateliê e ir embora, mas aí vi a Pana..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Então bati na porta, pensando que talvez você tivesse aqui também."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Embora eu achasse que podia estar te incomodando vindo sem avisar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "De jeito nenhum! Tô feliz que minha amiga veio me visitar!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Eu tenho um mooonte de coisas que quero falar com você!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "msg_string": "(Eu nunca pensei que conseguiria conversar com a Nanaca no meu ateliê. Hoje vai ser um bom dia.)"
        }
    ]
}