{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC14_NAN_020.ebm",
    "nb_messages": 0x1b,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ei, obedeçam minhas ordens!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x125,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Ai, desculpa.<CR>...Hã?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Essa voz brava, mas tão mansa...<CR>Nanaca?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, é a Ayesha. Oi."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Sabia! Que coincidência te encontrar num lugar desses!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Tem razão. Talvez seja o destino que o deus dos nômades nos deu..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Deus dos nômades... Não sabia que existia um deus assim."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Ah, não existe mesmo. Só acho que seria legal se existisse."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "A-Ah, entendi..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Nessa época do ano, acho que geralmente tô ali por Vierzeberg."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Não é muito, mas ainda tem um pouco de grama pras vacas comerem."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Entendi. Mas essa área não é perigosa com os cães selvagens e tudo mais?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Não esquenta, eu evito as áreas perigosas. Além disso, qualquer coisa, eu tenho o meu irmão..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "O seu irmão, Juris? Ele realmente parece bem confiável."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "(Urgh... tive a sensação de que alguém tá<CR>me vigiando. Talvez tenha sido só<CR>impressão minha...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "msg_string": "(Será que eu devia dar oi...?)"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Não se preocupa, meu irmão só tem cara de emburrado. Ele não tá bravo nem nada."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "As pessoas sempre ficam com medo dele da primeira vez que o veem."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Ah, tá. Que bom que ele não tá bravo."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Nanaca, a gente devia ir logo."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Ah, beleza. Até mais, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Sim! Espero te ver de novo em algum lugar!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Com certeza a gente vai, desde que você continue na sua jornada e eu na minha vida nômade..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Porque o destino dá voltas. Tenho certeza que nossos destinos vão se cruzar de novo."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Bom, até mais."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "msg_string": "(A Nanaca tem uma aura bem misteriosa. É meio mística e quase relaxante...)"
        }
    ]
}