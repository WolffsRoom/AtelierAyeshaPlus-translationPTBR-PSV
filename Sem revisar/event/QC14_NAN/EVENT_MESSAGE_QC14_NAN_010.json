        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x134,
            "msg_string": "Você... também gosta de vacas?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x135,
            "msg_string": "Vacas...? Hmm, nunca parei pra pensar nisso, mas acho que sim..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x136,
            "msg_string": "A Pana também sempre me ajuda.<CR>Ela é da família pra mim."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4a,
            "expr_id": 0x2,
            "msg_id": 0x137,
            "msg_string": "Ah, então o nome dela é Pana? Hmhm, é o nome perfeito pra ela."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4b,
            "expr_id": 0x2,
            "msg_id": 0x138,
            "msg_string": "Ela é tão forte, carregando toda essa bagagem. Bem impressionante..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x139,
            "msg_string": "Haha... Ela é forte e dócil, mas também é muito gulosa."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0x13a,
            "msg_string": "Uma vaca que come muito é uma vaca boa. Por favor, continue cuidando bem dela."
        },
        {
            "type": 0x1,
            "voice_id": 0x20d,
            "name_id": 0x23,
            "extra_id": 0x216,
            "expr_id": 0xffffffff,
            "msg_id": 0x13b,
            "msg_string": "Oink muu!"
