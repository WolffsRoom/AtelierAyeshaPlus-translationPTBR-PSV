            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x148,
            "msg_string": "Ahhh, desculpa. Eu sou a Ayesha, uma boticária."
