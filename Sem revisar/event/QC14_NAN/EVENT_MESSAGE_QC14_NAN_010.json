        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x140,
            "msg_string": "Hmhmhm, parece que a Pana quer ficar aqui mais um pouquinho..."
