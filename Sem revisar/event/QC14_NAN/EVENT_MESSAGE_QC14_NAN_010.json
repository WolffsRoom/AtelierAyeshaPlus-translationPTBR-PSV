        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0x143,
            "msg_string": "Pra onde os ventos soprarem, pra onde as vacas forem. Pra onde eu vou depende do rebanho."
