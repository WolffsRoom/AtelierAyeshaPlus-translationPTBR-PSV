        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x131,
            "msg_string": "Hehehe, mas elas são tão fofas."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x132,
            "msg_string": "A grama daqui é de ótima qualidade, e as vacas adoram esse lugar."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x133,
            "msg_string": "Hehehe, obrigada por dizer que minhas vacas são fofas."
