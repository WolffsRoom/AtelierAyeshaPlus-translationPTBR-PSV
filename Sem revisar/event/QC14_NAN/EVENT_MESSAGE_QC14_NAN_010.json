        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x13c,
            "msg_string": "Opa, preciso ir nessa. Se eu não me apressar, vai escurecer..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3548,
            "msg_string": "Ah, nós também temos que ir.<CR>Bora, Pana, tamo de saída."
