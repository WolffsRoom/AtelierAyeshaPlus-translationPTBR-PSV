            "expr_id": 0x0,
            "msg_id": 0x12e,
            "msg_string": "Uau, tem tantas vacas!"
        },
        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x216,
            "expr_id": 0xffffffff,
            "msg_id": 0x12f,
            "msg_string": "Oink muu!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x130,
            "msg_string": "Não acho que são vacas selvagens...<CR>Será que alguém trouxe elas<CR>pra pastar...?"
