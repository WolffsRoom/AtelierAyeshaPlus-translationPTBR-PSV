        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x144,
            "msg_string": "Mas primeiro, a gente vai passar pelos túneis. Depois disso, eu deixo com elas."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x145,
            "msg_string": "Simbora, pessoal! A gente tem que ir logo!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x146,
            "msg_string": "Com licença...<CR>Espero que a gente se encontre de novo... Hmm..."
