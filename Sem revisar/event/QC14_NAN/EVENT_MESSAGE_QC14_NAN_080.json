        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Tá bem, digam obrigado pra Ayesha por ter cuidado de vocês."
