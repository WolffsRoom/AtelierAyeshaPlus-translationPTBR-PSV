            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Eles são idênticos. Quanto mais eu olho pra eles, menos diferenças eu vejo..."
