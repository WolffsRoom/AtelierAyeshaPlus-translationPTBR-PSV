            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2e,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Eu nem sabia se a gente ia ter gente suficiente pra abrir o concurso, mas agora temos. Vá se arrumar agora mesmo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Quê‐!? Tipo, agora, agorinha mesmo?"
