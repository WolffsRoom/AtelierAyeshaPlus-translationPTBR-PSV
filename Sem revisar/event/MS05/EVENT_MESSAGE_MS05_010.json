            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Opa, vejo que você tá bem animada!<CR>Então, deixa eu te inscrever."
