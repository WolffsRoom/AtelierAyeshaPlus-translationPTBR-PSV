{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC15_TAN_530.ebm",
    "nb_messages": 0x1b,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Tanya, eu trouxe uma lembrancinha da cidade como prometi."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x129,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Uau, sério!<CR>Muito obrigada!"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hum, tudo bem se eu abrir...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Claro. A moça da loja me ajudou a escolher, então espero que você goste."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Uau, que lenço mais lindo! *sniff* *sniff* ...E tem um cheiro muito bom também!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ele é perfumado. E também achei que o bordado combina muito com você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "O que achou?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "Eu amei! Muito obrigada mesmo!"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Ah, quanto eu te devo...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Então, sobre isso..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "O lenço é um presente de outra pessoa, então você não me deve nada."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Mas, eu não posso simplesmente aceitar um presente de alguém que eu não conheço..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Hmhmhm, você pode não ter conhecido essa pessoa, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Você já a conhece há um bom tempo."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Q-Quem é ela...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "A pessoa que te deu esse presente é de uma loja pra quem você vende sal."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "O nome dela é Marietta, e eu tenho uma mensagem pra você."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Ela disse: \"Obrigada por todo o sal.<CR>Eu uso ele o tempo todo.\""
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Entendo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Então, acho que não tem problema você aceitar esse lenço sem hesitar."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Tá bom. Embora eu nem tivesse percebido, acho que fiz conexões com um monte de gente..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "É verdade. Ninguém consegue viver totalmente separado de todo mundo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Todo mundo tá conectado a alguém, em algum lugar."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Conectada a alguém... Gostei disso."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "Então, toda vez que eu usar esse<CR>lenço..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x19,
            "msg_string": "Vou sempre pensar em você e na pessoa que me mandou. Muito obrigada."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Hmhmhm, de nada. Cuide bem dele."
        }
    ]
}