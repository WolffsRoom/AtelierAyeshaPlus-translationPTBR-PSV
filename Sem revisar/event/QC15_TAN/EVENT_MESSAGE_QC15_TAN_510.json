{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC15_TAN_510.ebm",
    "nb_messages": 0x25,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ayesha, você pode me contar da cidade de novo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Claro. Tanya, você é muito curiosa sobre a cidade, né?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Sim. Fiquei mais curiosa ainda desde que comecei a ouvir suas histórias."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Tanya, você já foi pra Hornheim...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Nãão, nunca. Ouvi falar que é uma cidade no litoral..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Beleza, então eu vou te contar sobre Hornheim. Vejamos..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Hornheim é uma cidade portuária que vive de comércio. Vários itens e pessoas de todos os lugares do mundo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Viajam pra lá de balão ou carroça. O seu sal também é entregue lá."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Os itens que chegam em Hornheim são comprados pelos mercadores, e..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "De lá, são entregues pra outras cidades."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Entendi... então tem um monte de outras cidades... Hmm, tem umas cinco?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xb,
            "msg_string": "Eu não tenho certeza, mas acho que tem mais."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Mas das que eu já vi, Vierzeberg é a maior."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Vários amigos meus moram lá,<CR>e tem muita gente mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Ah, você me falou de Vierzeberg da última vez, e que é uma cidade grande."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Aham. Eu morava totalmente sozinha no leste de Vierzeberg..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Então quando eu cheguei lá pela primeira vez, fiquei surpresa. Tem pontes enormes e é cercada por muros altos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Tem muitos prédios, também. Tem um monte de lojinhas nas ruas que vendem várias coisas diferentes."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Mas mesmo com tudo isso, a coisa mais legal de lá é o bazar."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "O que é um bazar...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Acontece uma vez por mês, e quem normalmente não tem uma loja pode abrir uma lá."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "E vem gente de toda a região pra procurar achados raros."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Acho que dá pra achar alguns itens bem raros por lá."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Dizem que não tem nada que você não ache no bazar."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "Caramba, parece incrível...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x19,
            "msg_string": "Que bom que deu pra ouvir mais uma das suas histórias. Muito obrigada."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Todas as suas histórias parecem incríveis, mas essa do bazar foi a melhor até agora!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Eu sei que é meio longe, mas você devia ir ver algum dia."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Hmm, será...?<CR>Será que eu conseguiria mesmo ir lá...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Ah, e eu... tenho mais um favor pra te pedir..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Hã? O que foi? Fica tímida não, pode me pedir qualquer coisa."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x1f,
            "msg_string": "Bom, eu não ligo pro que for, mas eu queria muito alguma coisa da cidade."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd5,
            "expr_id": 0x4,
            "msg_id": 0x20,
            "msg_string": "Mas como eu não posso ir pra cidade,<CR>eu queria ver se você não podia me comprar<CR>alguma coisa..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Ah, pode ser quando você tiver tempo. Não posso pagar nada caro..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Claro. Eu vou procurar alguma coisa que você possa gostar."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x43,
            "expr_id": 0x2,
            "msg_id": 0x23,
            "msg_string": "Uau! Muito obrigada!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x24,
            "msg_string": "(Beleza, eu tenho que procurar alguma coisa da próxima vez que eu for em Vierzeberg.)"
        }
    ]
}