            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "O quê!? Tanya, pra onde você tá olhando? Não olha praí!"
