{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC15_TAN_070.ebm",
    "nb_messages": 0x1c,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x0,
            "msg_string": "Pra mim, o Lago de Sal é um lugar bem curioso, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x1,
            "msg_string": "Esse lugar é especialmente interessante."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Esse lugar se chama Cemitério dos Slags."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Dizem que há muito tempo atrás, os slags gastaram toda a força deles pra purificar o veneno que foi solto por um demônio..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ou que, quando os slags percebem que vão morrer, eles vêm pra cá..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ou que isso aqui foi o campo de batalha onde um monte de slags bons e ruins lutaram. Tem um bocado de lendas sobre isso."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Mas ninguém sabe com certeza, já que isso aconteceu há tanto tempo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Pelo tanto de ferrugem, parece que faz pelo menos umas centenas de anos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Fico imaginando que tipo de coisas existiam no mundo naquela época... Dá um pouco de medo só de pensar."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Sério? Na verdade isso me deixa até empolgada."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ué? E por que?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "A história é muito interessante. Ninguém sabe o que aconteceu por aqui..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Mas todo mundo sabe que *alguma coisa* aconteceu. A prova tá por todo lado em volta da gente."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Acho que ficar pensando no que é essa \"alguma coisa\"... dá um pouco de medo."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Mas tudo isso ficou no passado."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xf,
            "msg_string": "A história é interessante... Acho que dá pra ver por esse lado também."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Quer dizer, Tanya, você ainda é tão<CR>nova... mas já tá<CR>pensando como adulta..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Fico pensando que tipo de vida o pessoal levava no passado..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x12,
            "msg_string": "Hmm... talvez fosse bem mais próspera do que é agora..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Ué? Por que você diz isso?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Desde que comecei a ir em ruínas diferentes, essa é a impressão que dá."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Parece que eles também tinham uma tecnologia melhor."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Tenho certeza que essa tecnologia melhor trouxe uma vida mais próspera pra todo mundo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "(Mas, eu não quero pensar no motivo de terem sumido...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Muita gente deve ter morado ao redor desse lago também."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x186,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "O Lago Salgado cheio de gente...<CR>Mas agora só tem a minha família."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Aham. A história é mesmo interessante."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x1b,
            "msg_string": "Hahaha, agora eu também tô começando a ficar animada!"
        }
    ]
}