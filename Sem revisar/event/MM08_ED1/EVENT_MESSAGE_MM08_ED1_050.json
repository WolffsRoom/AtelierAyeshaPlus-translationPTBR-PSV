            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Quando vi, acabei me envolvendo com um monte de gente diferente, e tive várias experiências novas."
