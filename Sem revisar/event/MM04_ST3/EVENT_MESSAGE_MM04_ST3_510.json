        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x21c,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "Oink! *nhac* *nhac*<CR>...Muu!"
