        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1d3,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Ah, não... eu tô ficando com... muito... sono..."
