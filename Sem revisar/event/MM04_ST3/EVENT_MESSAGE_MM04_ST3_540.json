        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Você sabia que as flores desabrocharam? Dá pra ver esse lado daí de onde você tá?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Hmm, não sei dizer ao certo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1d2,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Além do mais... Mana... tô com soninho..."
