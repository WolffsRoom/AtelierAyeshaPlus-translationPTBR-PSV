        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "Espera! Eu ainda quero conversar com você! Nio, não vai!"
