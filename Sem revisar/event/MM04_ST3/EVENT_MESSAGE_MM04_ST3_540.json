        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1d3,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Hmm... tá tão quentinho e aconchegante aqui... hmm..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1d3,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Tá tão gostoso e quentinho, igual a luz do sol..."
