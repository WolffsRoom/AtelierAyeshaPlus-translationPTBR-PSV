        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, mana, o que você tá fazendo aqui?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Nio! Então você sabe quem eu sou!? Faz tantos anos que não ouço a sua voz!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ainda bem que eu acreditei em tudo<CR>que o Sr. Keith me disse..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Nio, eu tava te procurando!<CR>O que você tá fazendo aqui?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Bom, essas flores desabrocharam no<CR>Dry Valley, então eu vim dar uma olhada."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1d5,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Hmm... Mana, essas flores são tão lindas..."
