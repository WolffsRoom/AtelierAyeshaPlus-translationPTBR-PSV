{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM04_ST3_720.ebm",
    "nb_messages": 0x1e,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "O 11º dia do 11º mês...<CR>É hoje."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "O Ranun disse que ia ter um eclipse solar, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ah..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Tá tão escuro, mesmo ainda sendo de dia. Eu nunca vi nada assim antes."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Não que eu não acreditasse no Ranun, mas aconteceu mesmo hoje..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ah, não é hora de ficar de boca aberta.<CR>O sol não vai ficar tampado por muito tempo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Eu preciso me apressar e achar a flor que não desabrocha no sol...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Nio!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Ah, Mana! Você veio me buscar...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Aham. Sua irmã vai fazer o que for preciso pra te ver de novo, Nio."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "Hehe, obrigada. Mas parece que não vou poder falar muito tempo com você hoje."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Dá pra perceber que essas flores só vão desabrochar por uns minutinhos."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "É, mas eu já tô feliz só de poder te ver assim de novo, Nio."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Eu também. Você me animou."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Onde a gente tá? Estamos, tipo, entre o Vale Seco e aquele lago salgado de antes?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Estamos perto de Hornheim, então estamos mais ou menos por aí."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Como você sabia?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Quando eu rastreei de volta as localizações das flores de onde eu tava..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "O primeiro lugar foi perto do ateliê, então eu meio que usei isso pra descobrir onde é esse lugar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Entendi. O que será que isso quer dizer..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Tem caminhos que se conectam em todas as direções, e parece que eles se ramificam comigo no centro."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "A ruína perto do ateliê é a mais próxima. Parece até que tá logo ali."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Como se o mundo tivesse se sobrepondo...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x161,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Ahh, o sol tá voltando...<CR>Eu queria conversar mais com você."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Mana, quando eu vou poder te ver de novo...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Eu não sei... mas vou te ver de novo logo logo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x1a,
            "msg_string": "Sério? Hehe, vou ficar esperando..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "(Nio, eu vou descobrir onde você tá,<CR>custe o que custar.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "(Ah é, acho bom eu pegar uma dessas flores. Pode ser útil pra alguma pesquisa ou sei lá.)"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você obteve Pétalas do Eclipse."
        }
    ]
}