{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC11_FRE_090.ebm",
    "nb_messages": 0x17,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x26,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hmm... isso tem uma qualidade muito boa. Acho que é a melhor que vi até agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hmhm, você tem um olho bem clínico, Marietta. Na verdade, arrumei um cliente novo."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Fiquei sabendo que tiveram uma boa colheita de especiarias nas montanhas do norte esse ano..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Olá. Ah, Ernie, você vai fazer uma entrega pra Marietta hoje?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Sim, acabei de chegar faz uns minutinhos. Eu vim pelo caminho da montanha, então tô bem cansado..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5f,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Tive que abrir meu próprio caminho, então minha bunda tá bem dolorida..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x68,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "Eu escorreguei de um penhasco umas três vezes, então minhas costas também tão doendo. Hahaha..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Como você consegue ficar tão calmo com isso...? Você tá bem?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x60,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Eu sinto como se meu corpo todo tivesse apanhado! Mas eu passo uma pomada depois, então..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Ah, então deixa eu passar pra você.<CR>Tenho certeza que é difícil pra você alcançar<CR>suas costas e a bunda sozinho."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x68,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "É... hahaha. Vou passar essa.<CR>Tô numa idade sensível..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "Não precisa ficar com vergonha.<CR>Bora, tira a roupa.<CR>Eu cuido de você."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x61,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Eu não posso tirar minha roupa.<CR>Ayesha, para a Marietta pra mim."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Ayesha, você tem que ficar do meu lado nessa! Vamos tirar a roupa dele, nós duas!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hmhmhm, vocês dois são bem unidos mesmo."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Eu ia agradecer demais se você me desse uma mãozinha aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Só desiste logo. Você devia só aceitar a boa vontade das pessoas e... Ué?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Ah, Sr. Padeiro. Seja bem-vindo."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Me dá um minutinho. Depois que eu terminar de tirar a roupa do Ernie e passar a pomada..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Meu Deus, eu não posso tirar a roupa com gente me olhando..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x14,
            "msg_string": "Você não sabe quando desistir, né? O Sr. Padeiro tá te esperando, então desiste de uma vez."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Bom, eu vim aqui pelas especiarias, mas... eu lembrei de uma coisa urgente que tenho que fazer, então com licença!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "(...Ele foi embora? Mas o Sr. Fred parecia meio pálido...)"
        }
    ]
}