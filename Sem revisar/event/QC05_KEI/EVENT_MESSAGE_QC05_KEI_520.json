{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_520.ebm",
    "nb_messages": 0x2d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Sr. Keith, hum...<CR>Eu trouxe o item que pediu."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Então você veio. Você até que é bem determinada."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Agora, vamos ver o que você tem aí..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Aqui está. Eu posso não entender direito o que é a alquimia ainda..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Mas eu fiz isso com todas as minhas forças."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Dá pra ver. Tá bom, você passou."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Tá, por favor, não pega muito pesado comigo... Hã? O que você acabou de dizer?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Eu disse que você passou. Tá insatisfeita?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Não! É que, você nem olhou direito..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Uma coisa tão primitiva assim,<CR>eu consigo entender tudo só de<CR>bater o olho."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Por enquanto, só comemore que você passou."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Eu tô feliz, mas... deu um trabalhão fazer isso, e você só ignorou assim, do nada..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Tá bom então... Eu tenho mesmo que explicar tudo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Primeiro, pra saber se você é digna de ser uma alquimista, basta olhar pro seu ateliê."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "E sobre você ter talento pra ser uma alquimista... isso é ainda mais fácil de ver."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Um alquimista habilidoso encontra o caminho pra verdade com os sentidos, e não com a razão."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Você tem feito suas sínteses na base do \"mais ou menos\" e da intuição, não é?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Isso não é algo que qualquer um consegue fazer."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Na minha opinião, você tem muito talento pra alquimia."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Eu só te dei essa tarefa pra testar e confirmar as minhas suspeitas."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "A-Ah, entendi... Então você não tava só implicando comigo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x134,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Claro que não. Você achou mesmo que eu faria algo tão inútil?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "É, acho que não. Imagino que você diria que é uma perda de tempo."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x136,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Viu? Você entende sim. Agora, deixa eu te falar a minha conclusão."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Posso até ter sido eu quem te mostrou esse caminho, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "É bem provável que você chegaria na<CR>alquimia uma hora ou outra, mesmo se<CR>tivesse estudando por conta própria."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Continue se dedicando e não me decepcione."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "S-Sim, senhor. Muito obrigada."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "E, aproveitando que eu já tô agradecendo, eu tenho um favor pra te pedir..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x91,
            "expr_id": 0x3,
            "msg_id": 0x1d,
            "msg_string": "Eu recuso."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "E-Eu nem falei nada ainda!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x92,
            "expr_id": 0x3,
            "msg_id": 0x1f,
            "msg_string": "Eu já imagino o que você ia<CR>pedir. E não, eu não pretendo<CR>ser seu mestre."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x20,
            "msg_string": "Como você sabia? Bom, acho que seria melhor ter um mestre, em vez de tentar aprender tudo sozinha..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x93,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Eu não sou gente boa o bastante pra virar mestre de alguém. Mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Se você realmente se meter em problemas, venha me procurar. Isso já deve servir por enquanto."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Eu já tô super encrencada!<CR>Não sei se tem como eu arrumar mais<CR>problemas do que eu já tenho agora..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Só desiste... Agora, sobre a recompensa que eu te prometi... eu já te entreguei."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Hã? Mas eu não recebi nada de você..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Recebeu sim, quando te passei essa tarefa. É aquilo ali."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Ah, aquele recipiente estranho?<CR>E o que ele é, exatamente?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "Com certeza deve ser algo especial, mas parece ser tão comum..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "Daqui pra frente, você vai precisar dele pra conseguir entender as flores brilhantes. Não se esqueça disso."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "E isso é tudo. Até mais."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x2b,
            "msg_string": "(Lá vai ele... Indo embora do nada, como sempre...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x2c,
            "msg_string": "(Mas, eu tô meio feliz que ele me<CR>aprovou...)"
        }
    ]
}