{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_100.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Argh, isso é ruim. Que burrice a minha cometer um erro desses..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Aconteceu alguma coisa?<CR>É algo sério?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Não... não é nada. Só tô falando sozinho."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x3,
            "msg_string": "Mas me deixa nervosa ouvir você falando coisas tipo, \"Isso é ruim\", ou \"Que burrice a minha\"."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "...É que acabaram os cigarros que eu tinha aqui."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Sempre fui cuidadoso pra ter uns<CR>de reserva... mas acabei vacilando..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "É raro você vacilar desse jeito..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Mas, que bom. Pensei que fosse algo bem mais sério."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Essa é uma questão de vida ou morte pra mim. Sem eles, não consigo me concentrar em nada."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Se você tá precisando colocar alguma coisa na boca, que tal uma bala?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe2,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Não, não é como se só colocar alguma coisa na boca fosse resolver tudo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe4,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Além do mais, eu não gosto dessas coisas doces."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ah, tudo bem. Eu tenho umas balas que não são doces."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Tipo umas que aliviam a garganta,<CR>ou umas bem azedas que dão uma clareada<CR>na mente..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe8,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Esse não é o problema.<CR>Elas não substituem cigarros."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe2,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Bom, essa sensação é algo que nem dá pra descrever com palavras..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Fora que eu tenho o meu próprio estilo. Não consigo nem pensar em ficar comendo doces."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "É mesmo? Mas elas são tão gostosas...<CR>Não vou te obrigar a comer..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Desculpa, mas eu agradeço a oferta."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Vou lá comprar mais na vila aqui perto. Me espera aqui um pouco."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Ah, eu vou com você.<CR>Também tem uma coisa que eu tô querendo."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "Vamos fazer umas comprinhas juntos!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Não, eu preciso de um tempo. Vou sozinho."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Ué, mas por quê? Me espera, Sr. Keeeith!"
        }
    ]
}