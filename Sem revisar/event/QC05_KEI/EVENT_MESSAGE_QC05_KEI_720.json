{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_720.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x0,
            "msg_string": "Vim pra Hornheim por enquanto... mas como é que eu vou procurar aquele slag gigante...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0x5,
            "msg_id": 0x1,
            "msg_string": "Talvez eu devesse perguntar pra alguém...<CR>Uma boa fonte de informação seria..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Mix Master, você ouviu falar de alguém que tenha visto um slag gigante por aqui?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Um slag gigante? Nãaao, não ouvi, mas também não tem muita gente por aqui pra começo de conversa..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Esse slag que você tá falando,<CR>qual é o tamanho dele?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Deixa eu ver... Ele é mais ou menos do tamanho de uma montanha..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x140,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Uma montanha? Se um treco tão grande tivesse andando por aí, certeza que alguém ia notar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Mas ele voa, já que tem asas."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa2,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "Sério? Um slag do tamanho de uma montanha que voa...? Ah, será que é aquilo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "Provavelmente é! Por favor, me conta sobre isso."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xab,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "Um tempinho atrás, teve uns dias com uma neblina fora de época."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "Todos os voos normais de balão foram paralisados, mas o tempo de cancelamento dos voos tava tão longo..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Que um balão acabou voando no meio da neblina..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "O boato é que alguém disse ter visto um gigante nas nuvens."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa6,
            "expr_id": 0x3,
            "msg_id": 0xe,
            "msg_string": "Chegaram à conclusão de que devia ser só a sombra de uma ilha vista pela neblina, mas podia muito bem ser um slag voador."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Hmm, é possível mesmo.<CR>Você sabe onde foi?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa8,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "Não sei muito sobre isso,<CR>mas olhando daqui, dá pra dizer<CR>que foi lá na outra margem."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa9,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "Mas com a neblina densa e a distância, a história da testemunha foi bem vaga."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Beleza. Muito obrigada."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "msg_string": "(É, tem que ser isso. Vou dar uma procurada no outro lado do vale.)"
        }
    ]
}