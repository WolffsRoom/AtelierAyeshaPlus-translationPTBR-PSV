{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_660.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Mas você já deve ter entendido que o ego de uma pessoa sempre leva pra esse lado, afinal de contas."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "E a sua irmã muito provavelmente foi pega pela maldade dos tempos antigos, igualzinho a esse aí."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "A maldade dos tempos antigos...? Mas se for assim, o que eu faço?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Você tem mesmo que fugir da maldade? Só enfrenta de cara, que nem eu."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Entendi. Mas mesmo assim..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "O que foi?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "É... maldade mesmo?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "...Como assim?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc5,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "O bicho que pegou a Nio, fez isso por maldade?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Vai ver tinha algum outro motivo pra ter feito isso..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x130,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Que surpresa. Vai defender o ser que pegou sua irmã?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x133,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Pegar um humano vivo, absorver ele, e apagar sua presença do mundo..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x135,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Se isso não é maldade, então é o quê?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "...Eu não sei. Mas não consigo acreditar que o motivo seja apagar eles."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Porque a Nio ainda tá viva, e ainda consegue sorrir."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x136,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Hmm... É uma suposição bem curiosa, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Agora não é hora de ficar pensando nisso. Você tem que agir mais."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "É... verdade. Desculpa."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Não... A criatura que eu achei que era movida por maldade... Você tá dizendo que pode não ser..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Não sei qual de nós tá certo. Mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Ver com nossos próprios olhos pode nos dar a resposta."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Deve ter alguma coisa lá pra frente que possa nos levar até sua irmã. Vamos nos separar e procurar."
        }
    ]
}