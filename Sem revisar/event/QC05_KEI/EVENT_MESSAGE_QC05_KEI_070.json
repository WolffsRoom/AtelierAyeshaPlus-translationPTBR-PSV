{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_070.ebm",
    "nb_messages": 0x1f,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ah, é o Sr. Keith. Acho que ele tá fazendo uma pesquisa por aqui hoje."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Sr. Keeeit‐"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "msg_string": "(Ops. Eu não devia falar com ele quando ele tá focado desse jeito.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "(Vou me sentir mal por atrapalhar ele,<CR>então eu devia passar beeeem devagarinho por ele...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "(Devagaaarinho, beeem devagaaarinho...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Por que você tá andando na ponta dos pés?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Eita! E-Eu achei que era melhor não te atrapalhar..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Então eu tava tentando passar por você sem que você me notasse..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Isso foi surpreendentemente atencioso da sua parte. Eu agradeceria se você fosse sempre assim."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Mas tá, acabei de chegar numa parte onde posso fazer uma pausa. Se você tem algo pra perguntar, eu resolvo isso agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Na verdade, não tenho nada em especial que eu quisesse te perguntar."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ah, mas tô interessada no que você tá fazendo aqui hoje!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ah. Enquanto eu tava lendo a literatura na biblioteca, me deparei com algumas coisas que eu não sabia."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Então eu vim aqui investigar.<CR>Tipo um estudo de campo."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1ca,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "As ruínas e aquelas flores lindas também são bem interessantes pra mim."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Sobre as flores? Você também tava pesquisando pra encontrar a Nio...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Eu tenho até um certo interesse em como você vai resolver esse caso."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Nem mesmo eu sei de tudo. A conclusão que você vai acabar chegando..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1cf,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "Achei que eu chegaria nela também, do meu próprio jeito."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Muito obrigada! É muito reconfortante ter a sua ajuda."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Não entenda mal. Não pretendo fazer isso."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Buscar e saber é tão natural pra mim quanto simplesmente viver."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Sem falar que a alquimia não tem fim. Não importa o quão longe eu chegue, ainda não vai significar que dominei tudo."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "A verdade ainda tá bem longe. Depois de vir pra essa terra, sei disso agora mais do que nunca."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1d0,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Tenho que continuar estudando sem ficar convencido demais."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Então é assim até pro Sr. Keith. Sendo assim, eu ainda tenho um longo caminho pela frente..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Isso mesmo. Você não passa de um pintinho que acabou de sair do ovo."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Não é ruim você ter tanta ambição. Mas, isso não passa de um incômodo pra mim."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Só continue se dedicando. Isso provavelmente vai te levar a salvar a sua irmã."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Vou voltar agora. Até mais."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "msg_string": "(Preciso usar a atitude do Sr. Keith como exemplo, e dar o meu melhor...!)"
        }
    ]
}