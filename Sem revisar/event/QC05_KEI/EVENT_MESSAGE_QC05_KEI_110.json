{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_110.ebm",
    "nb_messages": 0x17,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hmm... você tá parecendo muito mais com uma alquimista."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Não só aqueles itens medicinais que você costuma fazer, mas conseguir lidar com ferramentas de ataque também..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Pensar que você progrediu tanto em tão pouco tempo, você foi bem até."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "...Hã? Sr. Keith, o que você acabou de falar?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Eu disse que você foi bem até.<CR>Você não conseguiu ouvir?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "...Nunca pensei que você fosse me elogiar,<CR>então eu só fiquei surpresa."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Eu tento reconhecer as pessoas quando elas se esforçam de verdade."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe6,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Não tem motivo pra ficar surpresa."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "E você também não sente que tá evoluindo todo dia como alquimista?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Sim. É divertido conseguir fazer coisas que eu não conseguia antes."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Mas ainda tenho umas preocupações. Será que tem problema eu criar certas coisas... Elas parecem tão perigosas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Elas podem até não estar alinhadas com o que você quer, mas as suas habilidades são algo pra se orgulhar."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Você tá trazendo de volta uma habilidade que tava<CR>perdida na nossa época, basicamente sendo<CR>autodidata."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Além disso, no seu nível atual, você não vai conseguir criar nada muito absurdo."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x91,
            "expr_id": 0x3,
            "msg_id": 0xe,
            "msg_string": "Distorcer o espaço-tempo, quebrar as leis da física, ou criar ouro usando terra... Esse é o auge da alquimia."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x93,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Quando você chegar nesse nível,<CR>você deveria se perguntar a mesma<CR>coisa mais uma vez."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Ainda é cedo demais pra você se preocupar com esse tipo de coisa."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Obrigada, Sr. Keith.<CR>Tô me sentindo um pouco melhor agora."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Se eu conseguir salvar a Nio, quero voltar a fazer remédios e viver uma vida tranquila."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Então você tá dizendo que vai continuar sendo uma boticária em vez de uma alquimista...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Bom, você devia fazer o que quiser.<CR>Não é da minha conta."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Primeiro de tudo, você deveria se focar em salvar a sua irmã."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Sim... Eu vou dar o meu melhor!"
        }
    ]
}