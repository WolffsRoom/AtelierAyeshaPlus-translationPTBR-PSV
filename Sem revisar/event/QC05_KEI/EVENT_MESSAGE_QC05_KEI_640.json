            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Depois de criados, eles são seres vivos de nível baixo que se multiplicam sozinhos, mas..."
