{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_040.ebm",
    "nb_messages": 0x22,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x16d,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Então, vou levar essas duas bolsinhas. E vou levar todas essas pedras que você tem."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Certo, obrigada pela preferência! Caramba, moço, você é muito generoso!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x172,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Tô comprando porque preciso delas. Não tem nada de mais nisso."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Claro. Mas as pedras da minha loja, normalmente o pessoal só compra uma como lembrancinha..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Então fico feliz que alguém como você apareceu."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x16e,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Bem, tenho certeza que a maioria das pessoas não tem uso pra elas."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ué? Regina e... Sr. Keith! Oi!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Bem-vinda, Ayesha. Você conhece esse cliente?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Sim. Esse é o meu professor, Sr. Keith!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x91,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "Eu deixei claro que não antes.<CR>A sua memória é tão ruim assim?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "É verdade. Ah, mas mesmo assim..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Eu só penso em você como meu professor no meu coração, então não deve te causar problema nenhum!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x93,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Esse é um pensamento sutilmente irritante...<CR>Sua autoafirmação é digna<CR>de elogios, de certo modo, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Cheguei até aqui sem ligar pro que os outros pensavam de mim e dos meus objetivos, mas..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Acho que o meu crédito finalmente acabou. Eu realmente colhi o que plantei."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Hum, aliás, o que você comprou?<CR>Coisas que você vai usar pra alquimia?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Sim, peguei umas ligas boas.<CR>Essa loja tem itens de qualidade."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Hehehe, eu dou duro pra escavar e achar isso tudo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Elas são bem úteis. Leva tempo pra conseguir itens desse tipo, seja fazendo ou coletando."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Ele é cliente fiel. Já comprou coisas de mim várias vezes."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Vou ficar agradecido se você conseguir as mesmas coisas da próxima vez também."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Beleza, vou deixar tudo preparado, então volte sempre!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "...Hum, Sr. Keith, não é?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "...Meu nome é Keithgriff. Pode me chamar só de Keith de agora em diante."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Ah, espera aí, por favor!<CR>Regina, a gente se vê mais tarde!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Essas pedras são tão raras assim?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Elas não são escassas. Você encontra em qualquer região."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "São úteis como ingredientes pra solventes líquidos, mas as pessoas comuns não têm muito uso pra elas."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Entendi... Isso ajuda bastante. Preciso anotar isso quando chegar em casa..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Você é bem apaixonada por isso. Eu também me lembro dessa época, porém..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Até quando você pretende me seguir? Você não tinha assunto naquela loja antes?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x1f,
            "msg_string": "Ah, é verdade! Ops, acabei me distraindo totalmente..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Vou voltar. Por favor me ensine mais coisas depois, Sr. Keith!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x21,
            "msg_string": "Minha nossa..."
        }
    ]
}