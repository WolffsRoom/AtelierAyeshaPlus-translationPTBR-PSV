{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_130.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Beleza, já pegamos nossos lanches,<CR>então vamboraaa! Qual é, Ayesha,<CR>você é muito lerda!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "E-Espeeeera! Bell, você tá bem elétrica como sempre hoje."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ei, quem é essa criança?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, a Bell é..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "Eiiiii! O que você acabou de falar é<CR>imperdoável!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7f,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Não chama a grande bruxa, Senhorita Wilbell, de \"criança\"!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "A grande bruxa? É você?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x82,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Isso mesmo. Quem mais seria?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Acho que a sua aparência até lembra um pouco uma, mas... não estamos saindo pra brincar. Vai pra casa."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x83,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "Que saco! Beleza, então eu vou te provar! Fica só olhando a minha magia incrível!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Eitaaa... Bell, se acalma.<CR>O Sr. Keith não disse por mal."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x83,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "Esse não é o problema!<CR>É sobre como eu tô me sentindo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x83,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Argh! Eu vou te dar uma prova de que sou uma grande bruxa!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x88,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "Grava bem isso na sua mente. Tyah!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Ooh..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "*arf* *arf* *arf*<CR>E aí?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Como assim, \"E aí?\"<CR>Você só deu uma voada por aí no céu."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Dá pra ver que você é uma bruxa, mas não a ponto de colocar \"grande\" na frente..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Bom, a Bell ainda tá em treinamento, e-"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "Ayesha, não fala coisas desnecessárias!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Mas é verdade que isso é interessante. Quero saber mais sobre os princípios dessa vassoura."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x82,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "Que saco! Não é a vassoura que é incrível, sou eu!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Tudo bem, que seja. Então que tipo de técnica você usa pra voar nessa vassoura?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x84,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Hã? Ah, isso é... como eu posso explicar? Você segura a vassoura bem forte e voa bem rápido."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Você não consegue voar muito bem se fizer tipo, \"Hiyaaah!\" Mas se fizer, \"Tryaaah,\" funciona bem melhor."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "Não faço a menor ideia do que você tá falando... Me explica isso de um jeito mais concreto."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x168,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "É mais um tryaaah, e não um hiyaaah! É facinho!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "...Tá bom. Eu te pergunto sobre a sua magia no caminho."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "(Hmm, por um momento não tive certeza se isso ia dar certo, mas até que parece que a gente vai ficar... bem...)"
        }
    ]
}