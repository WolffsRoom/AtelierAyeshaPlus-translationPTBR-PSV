{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS02_010.ebm",
    "nb_messages": 0x12,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x206,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "Hey, welcome! Here to use Toby's Balloon Service?"
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "This is just a guess, but...missy, is this your first time in a hot air balloon?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Oh, yes. It's so...big when you see it up close..."
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x20c,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "Yup, it can carry a lot of people at once. How about it, wanna come aboard?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Eh, I am interested, but I think I'll just look at it for now..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I'm not mentally prepared for it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "Haha, I guess anyone who's never flown before would be confused if they were suddenly told they had to fly."
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "I'm very proud of my balloons. Feel free to take a good look, but not to the point that you poke any holes."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "They're really magnificent balloons.<CR>Can something this big really fly...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "msg_string": "What's that, missy? So you do want to ride one?"
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x20c,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "Go ahead and hop on! Don't be shy. Though, I do have to charge you a small fee."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "A journey through the sky on a balloon... How much is it?"
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "msg_string": "Don't worry, it's not ridiculously expensive! I take pride in keeping my prices reasonable."
        },
        {
            "type": 0x1,
            "voice_id": 0x20f,
            "name_id": 0x25,
            "extra_id": 0x207,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "Come talk to me whenever you wanna ride a balloon."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can now to go to Salt Desert and Homunculus Town."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "After talking to Toby, you can choose which destination to go to."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "However, to use this service, you will need 100 Cole for a round trip."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can talk to Toby to return to Hornheim."
        }
    ]
}