            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "There are two modes of travel on the World Map: Standard Mode and Direct Mode."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "In Standard Mode, use the directional buttons to specify your path. It helps adjust your number of travel days."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "In Direct Mode, use the left stick to choose your destination. It helps take the shortest number of travel days."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "With either mode, press <IM02> while traveling<CR>to discontinue."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Days will pass when traveling on the World Map. If you travel randomly, your days will pass quickly, so be careful."
        }
    ]
}