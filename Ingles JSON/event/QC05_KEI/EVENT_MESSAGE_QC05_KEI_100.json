{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_100.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hrgh, this is bad. How stupid of me to make such a mistake..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Is something wrong?<CR>Is it something serious?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "No...it's nothing. I'm just talking to myself."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x3,
            "msg_string": "But, it makes me nervous to hear you say things like, \"This is bad,\" or \"How stupid of me.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "...I just ran out of the cigarettes I had on hand."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I've always been careful to have<CR>spares...but I got careless..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "It's rare for you to be careless..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "But, I'm glad. I thought it was something more serious."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "This is a matter of life or death for me. Without them, I can't concentrate on anything."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "If you feel the need to put something in your mouth, how about a candy instead?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe2,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "No, it's not like just putting something in my mouth will solve anything..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe4,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Besides, I don't like sweet things like that."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Oh, that's okay. I have candies that aren't sweet."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Like ones that'll soothe your throat,<CR>or ones that are sour and clear up<CR>your mind..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe8,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "That's not the problem.<CR>They can't replace cigarettes."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe2,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Well, this sensation is something that can't be described with words..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Plus, I have my own style. I can't even think about eating sweets."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Is that so? But they're delicious...<CR>I won't force you to eat them..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Sorry, but I appreciate your offer."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I'll go get some more from the village nearby. Wait here for a while."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Uh, I'll go with you.<CR>I have something I want as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "Let's go shopping together!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "No, I need a break. I'll go alone."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Eh, but why? Wait for me, Mr. Keeeith!"
        }
    ]
}