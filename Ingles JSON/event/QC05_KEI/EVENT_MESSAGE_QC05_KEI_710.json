{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_710.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "(Hrrmm, this is such nice weather.<CR>I think it's been a while since I<CR>took it easy like this.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "(Nio's back at the workshop...<CR>Hmhmhm, I'm so happy.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Oh, I wonder what I should do for dinner today..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "You have a stupid expression on your face again. Your mouth is open..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Mr. Keith! I was just thinking about today's dinner and Nio and..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Well, you have been dealing with a great amount of tension, day-after-day, for so long that I can understand."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "However, aren't you forgetting something?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x7,
            "msg_string": "Forgetting...? Umm, was there something? Did I promise to meet you somewhere?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "That's not it. But you did leave the big slag out in the wild..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Ohh, that's right. I completely forgot about that."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "We confronted it as soon as it woke up, but it escaped, and..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "It's saving up power somewhere. Do you realize what will happen if it regains its full power and capabilities?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xc,
            "msg_string": "Umm...I feel like something not-so-good would happen."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "That's right. If it wants to, it could bring disaster to this entire region."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Eh..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "If you really are an alchemist, you can't forget to deal with the repercussions of your actions."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "You're right! Now isn't the time to be gazing up at the sky..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Huh? But wasn't it you who woke it up...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "If you look up to me as your teacher, I thought I should do something like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe6,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "It'll be a test of your strength.<CR>You must go take care of this."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "It's currently roaming around west of Hornheim."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Okay. I'll try...! I can't just stay here and take it easy!"
        }
    ]
}