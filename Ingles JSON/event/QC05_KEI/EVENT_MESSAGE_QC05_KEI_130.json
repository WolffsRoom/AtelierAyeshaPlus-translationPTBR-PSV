{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_130.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Okay, we have our lunches packed,<CR>so let's gooo! C'mon, Ayesha,<CR>you're so slow!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "W-Waaait! Bell, you sure are as energetic as ever today."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hey, who is this child?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Oh, Bell is..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "Heeey! What you just said is<CR>inexcusable!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7f,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Don't call the great witch, Miss Wilbell, a \"child\"!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "The great witch? That's you?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x82,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "That's right. Who else would it be?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "I guess your appearance looks somewhat like one, but...we are not going out to play. Go home."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x83,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "Jeez! Fine, then I'll prove it to you! You just watch my great magic!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Whaaa... Bell, calm down.<CR>Mr. Keith doesn't mean any harm."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x83,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "That's not the problem!<CR>It's about how I feel!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x83,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Ugh! I'm gonna show you proof that I'm a great witch!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x88,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "Burn this into your mind. Tyah!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Ooh..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "*huff* *huff* *huff*<CR>So?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "What do you mean, \"So?\"<CR>You just flew around in the sky."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I can see that you're a witch, but not to the extent that you can put \"great\" in front of it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Well, Bell is still in training, and‐"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "Ayesha, don't say unnecessary things!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "However, it's true that it is interesting. I want to know more about the principles of that broom."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x82,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "Jeez! It's not the broom that's amazing, it's me!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "That's fine, too. Then what kind of technique do you use to fly on that broom?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x84,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Huh? Oh, that's, how can I explain it? You grip the broom tightly, and fly swiftly."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "You can't really fly well if you go, \"Hiyaaah!\" But if you go, \"Tryaaah,\" it works better."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "I have no idea what you're saying... Explain it to me more concretely."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x168,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "So more like tryaaah, and not hiyaaah! It's easy!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "...Fine. I'll ask you about your magic along the way."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "(Hmm, I wasn't sure for a moment if this would turn out okay, but it kinda seems like we'll be...okay...)"
        }
    ]
}