{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_680.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello. Welcome to the Zweiteturm."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ms. Odeliaaa! I have a question for you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x31,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "What is it? Oh, if you are looking for the restroom..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "That's not it. Ms. Odelia, do you know about \"the two cradles\"?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x33,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "\"The two cradles\"... Of course I am familiar with them."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hmm, well done. I was operating under the assumption that this information could have been lost."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0xad,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "I am the keeper of this place. I preserve various information."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Then, please tell me about the two cradles."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "What exactly are they? Where are they?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0xaf,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "That..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x117,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "...I cannot answer."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Huh? Wh-Why not?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "So it's not that you don't know,<CR>but you can't tell us?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x118,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "As you say, Keith, that information is classified top-secret."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x118,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "I cannot release it to the public."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "Please, Ms. Odelia! It might be very important information!"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x119,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "I cannot release it to the public."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "But..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "A serious problem has occurred, affecting the maintenance of this facility's confidential information."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "By Library Administration Agreement, Article 6, this facility is now closing."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "If you would please leave... Thank you very much for stopping by."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x91,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "Goodness, she's impossible. We have no choice, we have to go in after her."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "But from how she was acting, I don't think Ms. Odelia will tell us..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x93,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "From everything I've researched, this place has no information about the two cradles."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "If Odelia knows that information..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Then that means Odelia is the last book that I haven't looked through."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "I'm sure you're not going to give up on your sister, after coming this far, are you?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "That's... Yes, I'm gonna save Nio,<CR>no matter what!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Then we have to go after her. Let's go."
        }
    ]
}