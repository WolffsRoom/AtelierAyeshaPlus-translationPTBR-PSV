{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_KEI_010.ebm",
    "nb_messages": 0x19,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "You there. Sorry to bother you, but is this all the ore you have?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Yes, sir. I'll be right there."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Oh, yeah that's all we've got. The items in this corner have fluctuating availabilities."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Hmm, I see... I wanted to get a couple of the same ones, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Well, there's no helping it.<CR>Can you wrap that up for me?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6d,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Okay, thank you for your purchase. Mister, this is your first time coming to our store, correct?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yes, I'm in the middle of a journey.<CR>It hasn't been long since I arrived."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "But still, I was quite surprised to find a store that carries items like this."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Ohhh, that item was placed there more out of tribute to the owner's hobby."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "He stocks those items when he feels like it, so they aren't always available."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Well, it's better than nothing. Although, this rock is great for igniting things."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "It really should not be on bare display like this."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Uhh, is that so? I'll be more careful from now on!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Jeez, that carefree owner, always doing his job so randomly..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Did you say something?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Nooope, I'll wrap this up immediately."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x70,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Thank you so much. Please come again."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x15,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yes, I'll do that."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Oh, Ayesha, welcome!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Huh? That customer was..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "He was someone you don't normally see around here. He was quite rugged..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "He bought some weird rock that the owner stocked, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "I wonder if it was valuable ore or something..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Ooh, a rare ore..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "msg_string": "(It must be it. He's the spectacled man from before...!)"
        }
    ]
}