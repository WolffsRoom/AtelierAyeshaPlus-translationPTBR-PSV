{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC11_FRE_020.ebm",
    "nb_messages": 0x1e,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "(*sniff sniff* Something smells nice...<CR>Oh, the bakery opened!)"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "Welcome! Oh, hello miss, so you came!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yes. The aroma of the baking bread led me here."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "Haha! Freshly baked bread has the mysterious power to lure people in."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x4,
            "msg_string": "I have everything from freshly baked bread to bread that'll keep for a long time, so take your time and look around!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Okay! Wow, there's so many, I can't make up my mind."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "The kitty bread is so cute! Oh, and so is this teddy bear bread over here!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "It's so cute, I can't eat it."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Hahaha, eat without regrets. That's what the bread would want, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x44,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "By the way, the kitty is filled with jam, and the teddy bear is filled with custard cream."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "That's amazing...! Do you make all these cute kinds of bread, too?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Yup. I want my customers to feel the joy while they're eating."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x173,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "It may not seem like it, but the animal breads are quite difficult. You need to estimate how much the dough will rise."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x175,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Until I got the hang of it, all my animals turned out like monsters."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "I see. Now that I look at them closely, they all have slightly different expressions. Oh, this one is cute!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Hahaha, choose whichever one you like. I'm glad you're enjoying this."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Making bread that's fun to look at, and delicious to eat is my ultimate goal, and..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x37,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Ohhh, what should I do!?<CR>There are so many, I can't decide!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x39,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Hrgh, this is bad. There are so many that I wanna eat, I know I can't finish them all..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Hmhm, then let me choose. You're my first customer, so this one's on me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Huh? Really...!? But..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "This is how bakers greet people.<CR>Please don't hesitate to take it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Huh? But if you keep greeting people in town like that, it'll be a big problem for you."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x42,
            "expr_id": 0x2,
            "msg_id": 0x17,
            "msg_string": "Haha, if everyone eats my bread,<CR>that's enough for me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Th-Thank you so much. Then, I'll gladly accept your kind offer!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Umm, my name is Ayesha. I'm an apothecary... Although, I'm currently taking a break from that."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Hello, Ms. Ayesha, I'm Fred. I would love to have you as a customer from now on."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Yes. I'll stop by again!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "(I got free bread. I hope that's okay... It looks delicious!)"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can now go to Fred's Bakery."
        }
    ]
}