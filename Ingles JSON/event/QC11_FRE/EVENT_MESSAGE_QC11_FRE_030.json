{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC11_FRE_030.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ms. Ayesha, welcome. I just finished baking some bread."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hmhm, freshly baked bread is the best. Although, the bread you sell here is always delicious."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hahaha, that's a great compliment for a baker."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "It took me a long time to be able to open my own shop, but I'm so glad I kept working hard...! *sniff*"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Huh? Mr. Fred! Wh-What's wrong?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Someone else likes what I like.<CR>I couldn't ask for anything more..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I see. You really do like bread."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Yes, I love it! My history is basically the history of bread!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "And the history of bread is the history of humanity!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "H-Huh...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "By the time humans developed civilization, people were already eating bread!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "That's right! For thousands of years, humans have experienced many difficulties and hardships!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "And bread has always existed alongside those humans. Bread was the foundation that allowed them to stay alive!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "As a way to eat grains deliciously...<CR>As an easy way to provide a<CR>long-lasting, portable food..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "It is almighty! No other food is superior to this!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "And I shall continue to devote my life to baking bread!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "...I got a little too passionate there. Thank you for listening to my entire story."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "A-Amazing... I've never thought about bread to that extent before."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "It makes me feel weird to think that people in the past ate the same kind of bread as this."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Isn't it!? I think about that all the time."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x14,
            "msg_string": "I'm so lucky to be able to eat the bread that you bake, Mr. Fred."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "No. Having you and the other people of this town eat my bread is my greatest pleasure."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "I know! To thank you for all the happiness, let me throw in a bonus for you...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "No, that's okay. You've given me plenty of free bread before, so I'll pay for it myself!"
        }
    ]
}