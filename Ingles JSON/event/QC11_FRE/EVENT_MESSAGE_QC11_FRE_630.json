{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC11_FRE_630.ebm",
    "nb_messages": 0x23,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, Ayesha. I was in a state of perfect boredom. Welcome."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I came here to ask you for a favor.<CR>It won't be boring."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Can I trust your words? My heart gears are experiencing an upsurge in rotation from your confidence."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a4,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ta-da! Take a look at this! I brought you a very delicious looking piece of bread."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x117,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "...I cannot."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x5,
            "msg_string": "What's wrong, Ms. Odelia? Don't you like these kinds of things?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x118,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Ayesha, I cannot eat food.<CR>My teeth will hurt."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x118,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "I do not like hurting. I cannot eat sweets, either..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x8,
            "msg_string": "That's right, you got a cavity."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x119,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yes. I have been restored much sooner than I had expected, but that was a very bitter experience."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Don't worry. If you brush your teeth after you eat, you won't get cavities."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I love sweets, but I've never gotten a cavity before."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I did not know that.<CR>Then...I shall eat this bread."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Oh, hold on. I have one request."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I came here to ask for your opinion about the bread after you eat it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "So, I want you to take your time and savor it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x14e,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Is that an order?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Uh, no, it's nothing like that, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x150,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Only my master is allowed to give me orders. Otherwise, I will act according to my own discretion."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Therefore, I will eat it however I want to eat it."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x1b9,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "Now, if you will excuse me...<CR>*munch* *nom* *nom* *munch* *nom* *nom*"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Whoa, do you have to eat it so fast?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x1ba,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "Th-This is...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x1ba,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "This taste, this texture... It is not just sweet, but there is much depth to it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x1bb,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Its essence is not like that of ordinary bread, and a melody plays on my tongue, like a fine symphony."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "An essence that's not like ordinary bread and a melody... I see."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x73,
            "expr_id": 0x2,
            "msg_id": 0x1a,
            "msg_string": "It was constructed of many rare materials. It must have been hard to obtain everything."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "(I see... Huh? But isn't that...?)"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x74,
            "expr_id": 0x2,
            "msg_id": 0x1c,
            "msg_string": "This deserves to be labeled the finest gem. Ayesha, this is amazing bread."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x75,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Ayesha, I would like to ask for you to bring this bread again on your next visit."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "I don't know. If it's made from rare ingredients like you said, I don't know if the same thing can be made again..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x117,
            "expr_id": 0x4,
            "msg_id": 0x1f,
            "msg_string": "Hmm... Wh-Wh...<CR>What...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x118,
            "expr_id": 0x4,
            "msg_id": 0x20,
            "msg_string": "Never able to eat this bread again...? Can an ending as cruel as this be allowed to exist?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Oh, no...<CR>Umm, I'm so sorry!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "msg_string": "(I was able to make her happy, but then I made her sad... This is complicated.)"
        }
    ]
}