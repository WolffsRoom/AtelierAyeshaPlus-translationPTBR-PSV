{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC11_FRE_510.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello, Mr. Fred! I came here to buy some bread... Huh?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "*sigh* I just can't get into gear..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Wh-What's wrong, Mr. Fred!?<CR>Does your stomach hurt?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd3,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "No... If I had to put it into words,<CR>I'd say it's more like my heart's the<CR>one that's hurting..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd5,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "It's been a while since I opened my shop, so I was thinking about creating a new type of bread, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd7,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "It's not going as well as I had hoped."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Since you like my bread, maybe I should ask for your opinion..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "A new type of bread...? Let's see... Something sweet and something cute...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Haha, I'm sorry, I can't really explain it that well."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "No, it was an unreasonable thing for me to ask you. I'm not in a hurry, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x173,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "It's just that when Ms. Marietta stopped by few days ago, we started talking about it."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x177,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "She asked if I had anything new, and if possible, I want to make the kind of bread that she desires..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I see... Then why don't you ask Marietta directly?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x179,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I don't have that kind of courage..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xe,
            "msg_string": "Huh? Courage...?<CR>Do you really need courage?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x147,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Uh, well, I mean, I don't get too many opportunities to talk to Ms. Marietta."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "msg_string": "(But their stores are right across from each other... I'm sure he could ask her if he just walked over there...)"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x14a,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Ms. Ayesha, what kind of bread does she desire?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "W-Well...I wouldn't know. I'm sorry..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x176,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I see... I thought that maybe you might know, but I guess I was wrong..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x179,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "However, now I've reached an impasse…"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Ugh, this may be the end for me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "(Whoa... Mr. Fred got all depressed...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Umm, if you don't mind, do you want me to go ask Marietta?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "R-Really!? It'd be great if you could."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "And if possible, can you hide the fact that it's for me?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "What? Really? But why?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Th-That's...oh, I know! It's so that<CR>Ms. Marietta doesn't have to worry<CR>about a thing!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Okay, then I'll go ask her real quick!"
        }
    ]
}