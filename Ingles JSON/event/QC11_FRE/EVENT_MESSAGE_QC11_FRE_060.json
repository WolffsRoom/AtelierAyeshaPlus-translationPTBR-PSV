        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Yes. It's minced chicken meat, seasoned to be sweet and salty."
