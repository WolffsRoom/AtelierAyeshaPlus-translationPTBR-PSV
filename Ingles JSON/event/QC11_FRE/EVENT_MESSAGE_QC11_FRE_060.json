            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "No, wait! I need to consider the level of her eyesight."
