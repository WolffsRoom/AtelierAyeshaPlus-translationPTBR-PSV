            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x176,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Now...the new bread is finally ready. Now that its taste has been perfected, it is complete."
