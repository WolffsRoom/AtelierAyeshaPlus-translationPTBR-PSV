            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x173,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Do you think so? So, Ms. Marietta will be happy..."
