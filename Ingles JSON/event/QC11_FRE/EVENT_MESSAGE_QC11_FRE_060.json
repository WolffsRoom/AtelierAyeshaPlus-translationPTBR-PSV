        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x17a,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "If I talk to her... No, if it were that easy, I would've done it already."
