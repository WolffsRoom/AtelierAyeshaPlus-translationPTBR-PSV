        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x178,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Now all I need to do is figure out how to get Ms. Marietta to notice it..."
