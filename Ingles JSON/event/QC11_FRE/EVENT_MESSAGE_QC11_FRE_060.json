        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x175,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "First, I should put it in the most visible spot in the store... Here?"
