            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x175,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I see, so she'll be happy!<CR>I guess I did it...!"
