{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC11_FRE_610.ebm",
    "nb_messages": 0x2d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Mr. Fred... Hello..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Welcome!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Whoa, you scared me! You're full of energy today!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I must be. I feel like I've forgotten the spirit I had when I was still just a novice..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "The emotion that I felt when I was finally able to open my own shop... I want to bring it back."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "That's great... I'll support you!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Thank you. I finally remembered that my purpose in life is bread."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I won't be distracted by anything else. I want to knead the dough, leaven it, and..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Eventually...have everything disappear."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "H-Huh!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Oh, sorry... I want my worldly thoughts to disappear. Everything other than bread is useless to me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "msg_string": "(It seems like he's gotten really desperate...)"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "And this is the freshly baked ultimate bread that I've discovered after eliminating all my wicked thoughts...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Whoa, this color...this smell... Just looking at it is making me drool...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I'd love to get your opinion on it, since you love bread so much."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Now please! Could you eat this for me?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "*gulp* ...Are you sure? Are you okay with someone like me eating this...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Me, meee! I'll eat one, too!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Oh, Bell!? Why are you here...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I followed the delicious aroma. But that's not important now! I heard you're looking for people to sample this!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I nominate myself!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x173,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "You? But you only say \"it's good\" or \"I want more,\" no matter what you eat."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x174,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "That makes me happy, too, so I'll give you something else today, okay?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Whaaat!? No fair! But I guess I'll take it, as long as I can get it for free..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Th-Then, I'll be taking a bite...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "*gulp*<CR>H-How is it...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b4,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "msg_string": "It's fluffy, yet crispy...<CR>Crusty, yet chewy..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b5,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "The sweetness is perfect, and I could totally keep eating more of this!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b5,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "*munch* *munch* What I'm eating now is...bread, right? *munch*"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x177,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "I used the highest quality ingredients in existence, and I made it with every means available to me."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x179,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "I fully believe that I have crafted a masterpiece."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b5,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "msg_string": "Amazing... No, this is way too amazing! I'm starting to tear up for some reason! *munch* *munch*"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x20,
            "msg_string": "I see... I'm happy that you're praising me so much... But it's kind of embarrassing."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x21,
            "msg_string": "I would like to hear other people's opinions, but I don't know anyone else that would be good for this."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x44,
            "expr_id": 0x2,
            "msg_id": 0x22,
            "msg_string": "Do you have any friends who have sophisticated taste buds?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Here! Me!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "I want to have this ultimate bread evaluated. I'd like to get a professional's opinion."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b6,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Someone who can evaluate bread...<CR>Well, a few people do come to mind."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Thank you! I know it's a pushy request, but I'm counting on you."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x27,
            "msg_string": "Heeey! I told you that I'll eat it for you!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "I'm sorry, I couldn't make too many of these. Would you settle for this Ultimate Kitty Bread instead?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x80,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "Ultimate? Yay!<CR>I guess this'll have to do!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x2a,
            "msg_string": "(Hmm...someone I can ask to taste it...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x2b,
            "msg_string": "(Mr. Kyle knows a lot about food, so it might be good to ask him.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x2c,
            "msg_string": "(And, hmm, Ms. Odelia's obsession with sweets might be helpful, too...)"
        }
    ]
}