{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC11_FRE_110.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Well, it's become routine for me to eat bread from this bakery for lunch."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "I'm sure anyone would be so happy to eat your bread every day, for breakfast, lunch and dinner."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Well, as long as you're willing to come to my shop, I plan on offering my bread."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6d,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "Hmm, but that's too much work.<CR>I know, why don't I just take<CR>you to be my wife!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x144,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Uh...huh!? That's...well...<CR>M-Marri‐! *cough* *cough*"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "What's wrong? Why are you coughing all of a sudden?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x146,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I'm sorry, I'm fine now. But I'm a man, so I don't think I can be a bride..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "Hahaha, you're so earnest.<CR>That was just a joke."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "A joke...? Ah...haha...I guess. I see that you have a boyfriend, too."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Huh? I don't have a boyfriend..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "What...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I've been single for a while now.<CR>I'm so cute, but no one shows any<CR>interest in me..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I guess it doesn't help that I'm confined to my store all day because of my job..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I-I see... So, Ms. Marietta doesn't have a boyfriend..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hahaha, if you know anyone nice,<CR>please introduce me. See you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Mr. Fred, can I get a bread...? Huh?<CR>Did something good happen?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Huh? What are you talking about?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Well, you looked really happy, like spring has finally come."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Th-That's not true...I don't think..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Hehe, you're so easy to understand.<CR>But, well, I'm happy for you."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Huh? I-I don't know what you're talking about..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "It's pretty obvious, so I don't think you need to hide it. Right, Ayesha?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x16,
            "msg_string": "Huh? What are you talking about?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Ugh, I forgot how oblivious you are sometimes... Well, I guess I'll keep it to myself then."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "But in return, gimme a kitty bread!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "...Take as much as you want."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x1a,
            "msg_string": "Really!? Thanks! I won't mention anything about your feelings from now on!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x1b,
            "msg_string": "H-Hey! D-Don't say that out loud!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15d,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "(Mr. Fred looks so flustered...<CR>I wonder what this is about...)"
        }
    ]
}