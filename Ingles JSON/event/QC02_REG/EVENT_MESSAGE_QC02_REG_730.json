{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_730.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Ayesha, thanks! It was delivered!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "It...? Ohhh, you mean the cloth? Were you able to find a pattern you liked?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Perfectly! I even had to think it over since he had such great taste in cloth."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Oh, as I'd expect of Ernie, I guess."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "So, Ernie... He was an easygoing and cute boy."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x5,
            "msg_string": "But, I think he's still much older than you..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I see. He doesn't seem like it...<CR>Although, he does seem to have a<CR>strong sense of responsibility."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "No matter the occupation, it's always refreshing to see a master at work."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Anyway, I went ahead and made the<CR>clothes, but I was so excited,<CR>I ended up making too many."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "I was hoping I could get him to try them on so I can adjust the length..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "He? Do you mean Ernie?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "No, no, Juris. That boy's stature is similar to my brother's."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "The next time you get the chance,<CR>can you bring him over?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "If you do, I'll treat you to a delicious meal."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Okay! I'll keep that in mind."
        }
    ]
}