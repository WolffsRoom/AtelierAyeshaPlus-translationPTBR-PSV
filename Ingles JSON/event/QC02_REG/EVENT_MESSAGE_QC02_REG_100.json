{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_100.ebm",
    "nb_messages": 0x25,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hmm...this area is suspicious..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Huh, is something weird? It looks the same as everywhere else to me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "My long honed intuition is whispering to me that something's here."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Hmm, there's no use just thinking about it, let's blast it away."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Stand back."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "3, 2, 1...fire in the hole!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x125,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Kyaaah! What are you doing?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Oh...th-this is...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hm-hmmm! Totally seems like a sealed entrance... I smell treasure."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Wooow, you were right...!<CR>How did you know?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I'm telling you, it's my intuition. When you're a prospector, you can just tell."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Anyway, aren't you curious to see what's in there? Let's go look."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "You're right... There might be some relics from an ancient civilization..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Or there might just be the bones of ancient people... Hehehe!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hyaaah! Don't scare me like that!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "It's pretty dark...<CR>Should I light something up?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "No, not yet! There could be some combustible gas in the air."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x81,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "And you wouldn't wanna go KABOOM when you light the fire, would you?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "No, I wouldn't want that..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x80,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "We'll know for sure once we go further in. Ayesha, follow me closely."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Oh...what's this soft thing?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Huh!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x169,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Not too hard, but not too soft.<CR>The texture feels like an angel...<CR>Is this the treasure!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Th-That's me, Regina!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x16a,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Whoops, sorry, Ayesha. Haha, although, it's not that different from a treasure..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x16a,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Let's see, squishy-squishy...<CR>Hoho, now this is something..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x1a,
            "msg_string": "Nyah! Hyah!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x39,
            "expr_id": 0x2,
            "msg_id": 0x1b,
            "msg_string": "H-Hey! That tickles!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x16b,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Oops, sorry! Touching you feels so amazing, I can't stop myself..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x39,
            "expr_id": 0x2,
            "msg_id": 0x1d,
            "msg_string": "Hyaaah! Let's just investigate!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x1e,
            "msg_string": "Huh? Oh, just a little longer..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "No! Any more and I'll be confused on a whole lot of issues..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Well, I'm reluctant to stop, but I guess I'll get back to work..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "*sniff* *sniff* *sniff*<CR>...It seems like we're okay to light a<CR>fire. Let's get some light in here."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Hmm...I guess there's nothing special here. But the ruin itself does look familiar..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Now that you mention it, it looks similar to the ruin in Riesengang."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Maybe they're connected.<CR>Let's investigate further."
        }
    ]
}