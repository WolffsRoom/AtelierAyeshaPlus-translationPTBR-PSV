{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_820.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Regina...so about what we were talking about before, has anything happened since then?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Before...? Oh, do you mean about<CR>whether I'm gonna quit my job or not?<CR>Well, it's terrible!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "I haven't decided anything yet,<CR>but my parents keep bringing it up."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Like, \"Your room's just waiting for you,\" or \"a decent guy around here is looking for a wife,\" and so on."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh... They're really quick with the preparations. It's like they're trapping you in a corner..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Yup. It was inevitable, so I made up my mind."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I went to go tell Boss that I'll be quitting soon."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "I see... I'm starting to get sad."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Yeah, me too. Sorry, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "When it actually comes to quitting,<CR>you start thinking about stuff that<CR>you normally wouldn't."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Like, if I was able to leave something behind with this job, or if I obtained something really great..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x10,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Or like...I want to do something in the very end. I know it's not like me at all to act like this..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Yeah. For my last labor as a prospector, I want to leave something behind."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Well, if there's anything I can do,<CR>I wanna help!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "...Seriously?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "Yes. Super seriously! Whether it's treasure hunting or husband hunting!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x49,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Hahaha, Ayesha, you're such a nice girl!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x4b,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "...If you're gonna help me, then there's only one thing I want to do."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "All right, I've decided! I'll do it!!!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I want to tell you more about it, so can you come with me to the tunnel?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "The tunnel? Sure, I'll go with you."
        }
    ]
}