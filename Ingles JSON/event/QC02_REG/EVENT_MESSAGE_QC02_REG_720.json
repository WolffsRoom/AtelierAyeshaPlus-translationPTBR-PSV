{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_720.ebm",
    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "(That's right, maybe I should ask about the cloth Regina was looking for...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I see, cloth for a lining...<CR>The circulation of those goods<CR>have been declining recently."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Since it seems to be an important gift, I'd really like to help her..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Leave it to me! She's your friend,<CR>so I'll do my best."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "It might take some time, but if you tell me her address, I'll deliver it to her directly."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Wow, you're the best, Ernie!<CR>You're so dependable."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Now that I think about it, there's never been a time when you couldn't get an item..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "No matter what method I use, I want to meet my customers' demands. That's my motto."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "(I wonder what kinds of methods he's talking about...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Plus, I don't make clothes, but I do like to make ribbons and other small stuff..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "So, as a person who loves needlework,<CR>I definitely want to help her out."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Oh, how should I pay you?<CR>Should I pay you now?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Don't worry about it. Just do your best the next time I have a job for you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "So it's like we're bartering...<CR>That'll help me, too. Then, I'll take you up on that kind offer."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Then, is it okay if you let me choose the patterns and colors?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Yes, please do."
        }
    ]
}