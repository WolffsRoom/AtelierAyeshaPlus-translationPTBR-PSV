    "nb_messages": 0x21,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Good morning, Regina.<CR>Let's have breakfast together."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "...Huh?"
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "Hrmm, hrmm...<CR>Zzz...zzz..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x3,
            "msg_string": "She's still sleeping. I wonder if she stayed up late last night..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Maybe I should just start preparing..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "*yawn* Something smells delicious... Hrmm, this is nice..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Oh, good morning. Are you awake?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Ayesha, now I know how a newly-wedded husband must feel."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "A cute wife, like you, making breakfast for me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "That kind of life isn't bad, either..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Whaaat? But we're both girls."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Yup, that's the problem.<CR>Sadly, we can't be together..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "I'm pretty majorly bummed out about this..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "U-Umm, I just started preparing.<CR>Is there anything you'd like to eat?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Let's see... I wanna eat something meaty..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "For breakfast? Hmhm, Regina, you're always so energetic."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "No, no, it's actually the opposite.<CR>I'm not feeling it today, so I have<CR>to eat a big meal."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Huh?<CR>...You're not feeling well today?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x12,
            "msg_string": "Now that I think about it, it is rare for you to sleep in..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "It's not that I'm sick or anything,<CR>but I guess I'm still feeling that<CR>nightcap from last night."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd5,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Some things have been carrying over to the next day recently..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I mean, if I round-up, I'm basically 30 years old now..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Y-You don't have to feel that old yet..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I don't mean to, but I'm just not the same anymore."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "I feel like the energy I had a couple of years ago...just disappeared."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Getting old sure is heartwrenching..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "I-Is that so? I don't really get it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "That's cuz you're still young, Ayesha. You're just starting to enter the prime of your life."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "If you aren't careful, after you turn 20...it'll go super fast."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Wh-What'll go super fast?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x49,
            "expr_id": 0x2,
            "msg_id": 0x1e,
            "msg_string": "Hahaha, that just means that if there's something you want to do, you'd better do it now."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x4b,
            "expr_id": 0x2,
            "msg_id": 0x1f,
            "msg_string": "That's a warning from your life coach. Remember that."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "msg_string": "(I don't feel it yet, but maybe that is how it is...?)"
        }
    ]
}