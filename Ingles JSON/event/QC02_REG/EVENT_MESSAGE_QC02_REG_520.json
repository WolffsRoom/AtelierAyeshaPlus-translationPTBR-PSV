{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_520.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Whoa! So this is Vierzeberg!<CR>There are so many magnificent<CR>bridges, it's amazing!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Well, let's go our separate ways from here. I have a delivery to make."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Okay... What should I do?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "This is a good opportunity for you to  just wander around."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I'm sure there's a lot of things in this town that you've never seen before."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Sightseeing... That does sound fun..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "My friend's shop is just up the hill, so let's meet up there."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x10,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Sorry I'm making you wait around,<CR>but I'll introduce you to the<CR>person I was talking about!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "The hill... How do I get there?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "If you head down the street that you'll see when you enter the town, and just keep going, you can't miss it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0xa,
            "msg_string": "Hahaha, I'm still pretty confident that I can get lost."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "You'll be fine. But if anything does go wrong, let's meet up at this bridge."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0x5,
            "msg_id": 0xc,
            "msg_string": "Umm, even with that backup plan, there are so many bridges..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Oh, right. Well then, the hill it is!<CR>If you get lost, just remember to keep going up!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x19a,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Okay? See you later!"
        }
    ]
}