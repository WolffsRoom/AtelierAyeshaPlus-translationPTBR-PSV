{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_130.ebm",
    "nb_messages": 0x1c,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1af,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "\"Dear Sister, thank you for sending<CR>me the formal clothes for my<CR>coming-of-age ceremony.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "\"It all fit perfectly, even though you didn't take my measurements, so I was really surprised. You're awesome.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "msg_string": "\"Sis, how's your life been over there?<CR>I hope you haven't gotten sick or<CR>injured.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "\"It's been many years since you succeeded our dad and became a prospector.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "\"As your little brother, even though I want to cheer you on for working so hard...\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "\"I still want you to come back home.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "\"Sis, you're so talented, I'm sure you can do many other jobs besides being a prospector.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "\"The clothes you sent me look amazing. What do you think of being a tailor?\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "\"From now on, I'll go out and work as hard as you, Sis.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "msg_string": "\"Now, it's my turn to support our family.<CR>I can't let you carry the burden<CR>forever.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "\"I'm looking forward to a day where all of us can live together as a family again. Well, talk to you later.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "msg_string": "\"P.S. Mom and Dad said to tell you to come home every once in a while.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x34,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "msg_string": "\"The whole family would like to see your face again.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1b0,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1b0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hmm, that little chump is all grown up, sending me a letter like this..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1b1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "It's a good thing that my siblings are getting older, but my parents are growing old, as well..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Hello, Regina. Huh? Were you crying?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Whaaat? Of course not!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "...Is what I'd like to say, but I guess my eyes started watering up."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Wh-What happened? Was it something sad...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Umm, it was sad, but also happy."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I got a letter from my younger brother, saying thanks for the clothes I sent him."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "Wow, how did he like them?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Heh, it seems like they were a perfect fit. And it's all thanks to Juris."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Regina, you're really good at needlework. I think you could even open up your own shop!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "If you open up a shop, I'll totally root for you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Ayesha's saying the same thing, too. Hmm, I see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "A tailor... I guess that could be nice, too..."
        }
    ]
}