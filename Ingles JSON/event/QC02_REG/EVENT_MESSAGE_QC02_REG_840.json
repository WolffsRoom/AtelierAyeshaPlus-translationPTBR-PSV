{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_840.ebm",
    "nb_messages": 0x26,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "...How is it, Ayesha?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "One...two...three.<CR>Yup, I've got all the materials."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "We'll be able to start working."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "All right, then let's start right away."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I'll go call the guys.<CR>Go ahead and get started!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Regina, it's done..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yeah. I never thought we'd be able to build a steady bridge like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I wonder if everyone will be happy with it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Well, as my last labor, this turned out to be a splended one indeed!"
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x1,
            "msg_string": "Sure enough. Now, this tunnel can be used for 50‐no, 100 more years."
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "Regina, you really are an amazing gal!<CR>I always knew you'd make me proud."
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "Goodness, stop. You're not gonna get anything by flattering me."
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Dummy, I'm not saying that just because I want something!"
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "I've been looking after you since your parents entrusted me with you, but at first, I was really worried."
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "I wondered if a delicate girl could do prospector work... Even the men find it hard."
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "But you earned your stripes in the blink of an eye. Your efforts really put the guys to shame."
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "You were always my pride and joy. You were much manlier than any of the guys around here."
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "Manlier? Gimme a break.<CR>I am a girl, you know!"
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x1,
            "msg_string": "Shut up! I always thought you were the only one who could succeed me...<CR>*sniff* *sniff*"
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Ooh, even Boss's heart can be moved to tears!"
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "Don't mock me! Anyway, my pride always rested with you."
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "And doing something like this in the very end... I'm..."
        },
        {
            "type": 0x4,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "This is the last thing we can do for you. Now...just go get married or something and be happy."
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "Of course. Boss, thank you so much for all you've done for me till now!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "Goodness, I'm so tired now from doing something that I'm not used to."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "But now, I have no more regrets.<CR>I did all that I could."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "And that's all thanks to you, Ayesha. Thank you so much."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "No, no. I didn't do that much. You were the one that did this, Regina."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Don't be so modest. I was only able to go all-out because of you."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Anyway, my work here is done. I was able to end it on a better note than I hoped."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "You're right. And I'm sure something new is in store for you."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Yup! Although, I don't know what it's gonna be yet."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Your name will last for all eternity in this tunnel, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Stop exaggerating. My name won't last that long."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Huh? But the boss said he's gonna name it the Regina Kurtis Bridge..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x23,
            "msg_string": "BOSS!!!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x24,
            "msg_string": "He said he was gonna build a stone monument to commemorate the honor."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x25,
            "msg_string": "Ahhh! You gotta be kiddin' me!"
        }
    ]
}