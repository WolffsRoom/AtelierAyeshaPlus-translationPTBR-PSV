{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_REG_410.ebm",
    "nb_messages": 0x12,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, Ayesha, welcome!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Huh? Regina!? You have a shop, too?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yup, to earn some pocket money. The stall regulations are very lenient here."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Oh, I see. I assumed registering for a shop would be complicated."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Harry is the one in charge, and he's not too nosy about the details."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "That's one good point about him."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Anyways, I'll have a shop out every month, so come stop by when you feel like it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Okay... Oh, but I don't want to get in your way by talking to you too much..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Well, talking is part of tending a shop. Customers attract more customers."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Oh, I can kinda see that. You'd want to check out a shop if a lot of people are there."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Right? So I'm fully open for some chitchat! Even then, I still won't get that many customers anyway..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "How many customers do you get at a shop like this?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Well, it depends on the day,<CR>but it's not that much."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "But maybe by the time I finish up, I can have a nice meal and a nice drink..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I guess it might not look like much,<CR>but getting to enjoy nice food and<CR>drinks while taking a break..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Being able to chat like this and get to know more people...that's enough for me, I guess."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Wow, that does sound fun..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Well, so, come stop by Regina's Shop every now and then, please!"
        }
    ]
}