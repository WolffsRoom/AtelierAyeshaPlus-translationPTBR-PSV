{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_HAR_620.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Mr. Fred, I need your help..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x173,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "About baking? I'm sure I know about most things, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x177,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "If you're asking for my help, does it have something to do with weird baked goods?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Actually, yes. I was asked to recreate the taste of a snack from the past..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x179,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, this is about Mr. Harry's story."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Huh? You know about that, too?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yes, he asked me, as well.<CR>Mr. Harry seems to be telling<CR>that story to a lot of people."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I've had a similar experience,<CR>so I want to help him, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "I just don't have enough information.<CR>I can't even identify the recipe."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "You're right. No matter how little it is, if we had more information..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd3,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Oh, then umm...how about asking<CR>Ms. Marietta?"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "She's had the most chances to talk to Mr. Harry, so maybe she might know something..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Oh, now that you mention it, it does seem likely that Marietta would know something."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x173,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Yes. Please, go and talk to her.<CR>I, umm...don't have the courage to<CR>speak to her..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "But it's just asking Marietta a question..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x174,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Yes. I don't have the courage to do that... Anyway, please Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Got it. I'll go ask her right away!"
        }
    ]
}