        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x58,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hold on, Marietta. I still need to deliver my speech..."
