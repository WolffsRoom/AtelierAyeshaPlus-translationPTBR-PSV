{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_HAR_040.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "unknown2": 0x1,
            "msg_string": "Okay, I would like to start the 10th Thrilling Treasure Contest!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x1,
            "msg_string": "First of all, let's have a message from the organizer."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "Ladies and gentlemen who adore fine and rare items, welcome to the Thrilling Treasure Contest!"
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x1,
            "msg_string": "I am the organizer and winner of the last event, Harry Olson!"
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x1,
            "msg_string": "This is the contest's tenth running, and I take pride in how our recognition around the world has advanced."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x1,
            "msg_string": "And as a matter of fact,<CR>I am also proud of you folks."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "Now, mystery items still slumber all over the world."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x1,
            "msg_string": "To collect those items and to make their presence known to all..."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "I'd like each participant to adopt<CR>this noble ideal and exert themself!<CR>And eventuall‐"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x1,
            "msg_string": "Okay, thank you very much. Let's give him a big round of applause."
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "Harry is the same as always."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "Oh, Regina? You're gonna compete, too?"
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Yup. I have a business relationship with him. I'm taking a break and I'd rather slack off at my house, but..."
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "Anyway, I'm more surprised that you're here, Ayesha."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "Hahaha, I couldn't really say no."
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "I see. I guess we have the same motive. Well, let's just take it easy and..."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "And today, we have a new victim‐I mean participant!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "The go-getter apothecary, Ayesha!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x1,
            "msg_string": "Huh?"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Come on, stop looking so silly and please give us a short speech."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "Huh? Oh, yesss, umm...<CR>I-I'll do my best!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "Thank you. Hmhm, how innocent..."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "Now the 10th Thrilling Treasure Contest..."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "Will begiiin!"
        }
    ]
}