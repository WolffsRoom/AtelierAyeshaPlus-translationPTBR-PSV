{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_HAR_060.ebm",
    "nb_messages": 0x26,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Excuse me. Is Ayesha here?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, Mr. Harry. It's rare for you to visit me here."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yes. I had some formal topics I wanted to talk to you about."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "(Huh? I feel like Mr. Harry is acting somewhat different from usual...)"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I am currently questioning the meaning of my life."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "And as a result of my soliloquy, there was something I had to tell you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "*gulp* Wh-What is it?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I've decided to retire as a collector and hand over the reins to the next generation."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Huh? So you're going to quit collecting rare items? B-But why?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "I'm honestly surprised with your results in the contest."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xb2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I flatter myself as being a rare treasure collector."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I thought I put the knowledge and experience I've acquired over the years to full use in the previous contest..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "But every trace of my efforts and glory have become a thing of the past, thanks to one girl."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Your skill at being able to make bold choices about quality and rarity...is unbelievable for a rookie..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I've never seen such a magnificent item. Such a great girl...you are."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "M-Me!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yes. And I thought to myself that my mission might now be over."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "msg_string": "(Could it be that...Mr. Harry is<CR>depressed?)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "B-But, I thought your item was amazing, too!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "...Hm? No, no, I don't need to be cheered up. It was my loss, no matter what."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "No, I think your items are wonderful!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Because, I've always thought that you had so many things that I'd never be able to obtain."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "By some fluke, I won last time, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I think you'll definitely win the next contest!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "...So you're trying to say that my task is not yet done?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Yes. Mr. Harry, you're the only person who can collect rare items."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "You may be right. No, that must be it!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0x1b,
            "msg_string": "I was depressed because of one or two losses..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0x1c,
            "msg_string": "But there is a lot more treasure resting in this world that is calling for me. I had forgotten about that..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf9,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "Okay then, as of today, I'll throw away all of my pride as a champion..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xfb,
            "expr_id": 0x4,
            "msg_id": 0x1e,
            "msg_string": "And declare that I have become your lifelong rival!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Uh...huh? Lifelong...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "The \"Surprise! East-West Treasure Array!\" Oh, that's my idea for the subtitle of the next contest..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x22,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "So at the next contest, I'll strike you down with a vicious blow! As I will be your challenger!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x25,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Oh, but of course, this is only a metaphorical expression. I won't really strike you, so don't worry."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Well, I'll see you at the next contest. I'll be looking forward to it!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "There he goes... I think he returned to his usual Mr. Harry self."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x25,
            "msg_string": "I think...that's good, right?"
        }
    ]
}