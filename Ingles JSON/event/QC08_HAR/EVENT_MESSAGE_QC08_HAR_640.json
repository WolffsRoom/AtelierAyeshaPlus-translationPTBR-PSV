{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_HAR_640.ebm",
    "nb_messages": 0x13,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x173,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "I see, a baked good made from grounded up beans. Then..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "The ingredients were different from normal, but as a recipe, it seems to be really ordinary."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x177,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yes. We might be able to do something about Mr. Harry's memorable snack."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x178,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Plus, even I remember the year of that crop crisis."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x17a,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I think I was 12 years old back then. That year, no one had any harvest."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x174,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "This land didn't have much harvest to begin with, so we had no reserves. Many people were starving."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x174,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "And then Mr. Harry entrusted a baker,<CR>my teacher, with the ingredients.<CR>He went around town..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x175,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Delivering baked bread to everyone.<CR>I was also one of the people who<CR>received the bread back then."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "I see..."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "I still remember the taste of that<CR>bread. That was the moment I decided<CR>to become a baker."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "I never forgot how much it moved me,<CR>so I chose this occupation."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I've always wanted to repay Mr. Harry for his kindness...and this might be my one chance."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Can you wait for me for a moment? I'm going to write down the recipe right now."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x173,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "It's done. This is the recipe."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x177,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "However, we don't know the ingredients, so it's not complete."
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x178,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "You'll have to try various ingredients and aim to recreate the taste..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "This is more than enough.<CR>I'll take it from here!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x179,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yes, good luck. I'll be rooting for you!"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can now make the Flower Muffin."
        }
    ]
}