{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_HAR_660.ebm",
    "nb_messages": 0x26,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x0,
            "msg_string": "Mr. Harry! I brought the snack I promised!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "I'm not sure if this is it, but please give it a taste...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Oh, so it's finally done?<CR>As I expected of you, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1b9,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "Then, if you don't mind, I'll taste it right away. *munch* *munch* *munch*"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "H-How is it...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1ba,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "*munch* *munch*"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Uhhh..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1ba,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "*munch* *munch*<CR>Hrgh... *sniff*"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Wh-What's wrong? Did it taste bad?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1ba,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "msg_string": "That's not it... The smell, shape, texture, and this taste..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1bb,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "There's no mistake, this is my mommy's taste... I never thought I'd be able to taste it again..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "I'm deeply moved..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I'm glad... I was worried that I wouldn't be able to recreate it."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "No, you were amazing, Ayesha.<CR>The taste that I had forgotten..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "You splendidly reminded me of it.<CR>Thank you! Thank you so much...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf9,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "I don't have a reward that can match this taste..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I don't need one. While I was gathering the recipe, I heard a lot of amazing stories about you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "That you used so much money to help everyone in town that you risked your own business..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xfb,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "I knew what it was like to be starving."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I couldn't just stand there and watch children starve."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "That was all."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I'm sure the people you've helped have grown up, making this town very prosperous."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "I see... Hmhm, back then, I didn't think that far ahead, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I guess I was able to do something for this town that I love."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Mr. Harry... That's such a beautiful story."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "The one regret I have is that I couldn't show mommy how splendid I turned out."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Mommy passed away before I inherited the business. It was probably because of her long years of hard work."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "I've wanted to show my splendid<CR>appearance to my mommy...but that<CR>could never happen."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "But I've been striving to make sure I'll never be ashamed to face her."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc7,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "I-I gan't... I'm sho weak do sdories like diz... *sniff*"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc9,
            "expr_id": 0x4,
            "msg_id": 0x1e,
            "msg_string": "I'm sure Mr. Barry's mother is looging down on dyou from heaven..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Are you crying for Mommy and me?<CR>You're very kind."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Seeing your tears, I'm reminded of my feelings from before..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "So I'm not ashamed to face Mommy."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Today, after eating Mommy's snack,<CR>I feel like that feeling has<CR>solidified even more."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Thank you, Ayesha...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xcb,
            "expr_id": 0x4,
            "msg_id": 0x24,
            "msg_string": "No, thank you. *sniff* Please keep working hard from now on, too. *sniff*"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "You're right. I'm still young.<CR>And I still have...lots to do!"
        }
    ]
}