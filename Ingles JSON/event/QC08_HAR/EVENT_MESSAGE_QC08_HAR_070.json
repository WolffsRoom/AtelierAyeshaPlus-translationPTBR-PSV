{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_HAR_070.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Excuse me. Ayesha...oh, it seems that you are here."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Oh, Mr. Harry, it seemed like you weren't very energetic today..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "That's no surprise. I mean I am currently questioning the meaning of my life."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "A-Again?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "I couldn't help it. I've been defeated repeatedly by the girl who I declared I would defeat with all my might."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf9,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "How disappointing... The Collector King losing just sounds stupid. Hmph, just laugh at me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "That's not true! I won't laugh!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xfc,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "On the other hand, you continue to advance. You're more suitable for the title of Collector King."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "That's a bit..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xf7,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "The time to pass the torch to the new generation may be fast approaching. I don't feel like I can win against you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "That's not true. I've just been lucky this whole time."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I see, luck. Hmm, you're so modest.<CR>I am no match for you."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Yet here I am, being tossed about by waves of jealousy as my boat drifts through the storm..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I'm not sure what you're trying to say, but you're better at collecting items."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I was only able to win by chance. I'm sure you'll definitely win next time!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "...You really think so?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yes!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I see... You're right. It's true, I can't let it end here."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Retreating right after declaring to be your rival would be shameful."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Next time, next time...in the name of the former champion, I'll take my win and crush you good!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x56,
            "expr_id": 0x2,
            "msg_id": 0x14,
            "msg_string": "Just look forward to it.<CR>Hmhmhmhm-hahahahaha...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x5c,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "Bwahahahahaha! *cough* *cough*"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "You shouldn't push yourself to laugh so hard..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x58,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "There's no need for your consideration! We are rivals after all!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Now if you'll excuse me, I'll be looking forward to the next time we meet!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "msg_string": "(Hahaha...I wonder if Mr. Harry came here so I could cheer him up...?)"
        }
    ]
}