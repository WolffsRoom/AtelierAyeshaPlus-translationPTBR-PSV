{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_NIO_080.ebm",
    "nb_messages": 0x1e,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello, Marion and Linca. I'm coming in."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ayesha, welcome. Oh, could that girl be...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "My sister, Nio. She came back safely,<CR>so we stopped by to say hello."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Come on, Nio."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Nice to meet you, Marion.<CR>Sis...I mean, my sister has<CR>told me a lot about you."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I heard that you've shown concern for me time after time, so thank you very much!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "My, you're so cute.<CR>Hmhmhm, you're very welcome."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "And it's nice to meet you, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Nice to meet you, Nio."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yes. And please continue to look after both my sister and me."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "My, my, she's such a proper sister.<CR>I'm jealous."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Huh? Why are you jealous?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1e2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Because I have a hard time dealing with an ill-mannered child every day."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x16b,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I see. That sounds very troublesome."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "Hehehe, Sis, I got praised!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "If you get too excited, she'll find out that you're really hyperactive."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Oh...oops."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Mmhm, she's definitely cute. Come to think of it, I had a time like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x122,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "Huh?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Why are you questioning me...? You should've just not noticed it at all."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I apologize. I could not help it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Nio might look good in clothes like Linca's."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Maybe I should prepare a set for Nio, too..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Nio, please run away. Marion's bad habit is coming out."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "If you do not hurry, you will be forced to wear clothes like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Huh? But those clothes are really cute!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x1a,
            "msg_string": "I don't know if they'll look good on me or not, but they look great on you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "No, these clothes offer no protection against blades. I cannot recommend them."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "I don't think girls normally choose their clothes based on whether they can protect you from blades..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Nio, please don't grow up to become like this lady here..."
        }
    ]
}