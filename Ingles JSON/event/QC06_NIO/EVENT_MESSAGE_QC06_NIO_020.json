{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_NIO_020.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Okay, the synthesis is done for this.<CR>It totally got dark already..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Isn't it time for dinner soon?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Wh-What!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "Hehehe, I came again.<CR>Surprised?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "...I feel like I'm getting used to this, little by little."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "But stop sneaking up behind me and then talking to me all of a sudden."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Buuut, even when I try to knock,<CR>I can't touch the door."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "(Hmm, I wonder if it's okay to be talking so carefree with her like this...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "(Maybe I should use this opportunity to ask more about her...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "msg_string": "(But I wonder what I should ask.<CR>Umm...hmm...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "What's wrong? Why are you furrowing your brows?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Sorry, I was just thinking. Oh, I know!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Hey, when you came here last time, it was night, right?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "It's night this time, too. Is there a reason why you keep coming at night?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Well, at night, a seam opens up everywhere."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "A seam...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yup. An exit opens up everywhere at the place I'm at."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Is it like the lock on the door loosens?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Umm, something like that..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I think it's similar to when flowers are in bloom, cuz the person gets distracted by it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Huh...? Who are you talking about?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x138,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Oh, I need to get going..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13a,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Well, see you later, Sis."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x17,
            "msg_string": "Hmm...I kinda understand,<CR>but I kinda don't..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "But accumulating these clues is what's important!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x19,
            "msg_string": "Wait for me. I'll bring you back home soon...!"
        }
    ]
}