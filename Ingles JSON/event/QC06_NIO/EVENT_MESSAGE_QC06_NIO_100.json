{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_NIO_100.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Actually, Mr. Keith...I haven't thanked you yet."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "While I was captured, you called out for me many times."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "It was very reassuring.<CR>Thank you very much."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Oh, so you heard that?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Yes. I was alone and sad, but I was at this place where I couldn't even cry..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I wanted to cry, but I couldn't.<CR>And then I heard your kind voice."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "So even though I was all alone,<CR>I was able to bear through it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Mr. Keith, so you were doing such a thing for us, as well...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Well, you know...just while I was  investigating."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe6,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "I was just attempting to make contact using a different means than yours."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "What were you telling her?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe7,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I forgot. It's nothing of importance."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Oh, but I remember. Umm, it was like..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "\"Just have a little more patience. In time, your sister will come save you...\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Wow, Mr. Keith said such nice things...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x130,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "I-I just thought that would be more effective."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x132,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Nio, you don't have to say such useless information."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Huh? But it wasn't useless at all.<CR>I was only able to make it here..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Thanks to you, Mr. Keith!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Okay, I understand. Now let's end this conversation."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe6,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Anyway, we should get going.<CR>I'm not fond of wasting time."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "You don't have to get that embarrassed..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xe6,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "I'll say this to defend my honor.<CR>I, by any means, am not embarrassed."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "(Mr. Keith, I toootally know that you're a kind person!)"
        }
    ]
}