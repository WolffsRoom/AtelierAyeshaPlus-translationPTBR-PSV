        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x110,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Urgh.<CR>Nio, that hurts..."
