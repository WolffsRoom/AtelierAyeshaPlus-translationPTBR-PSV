            "name_id": 0xc,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ohhh, so this girl is Ayesha's little sister..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Yup, you girls do look alike. I'm sure you'll grow up to be a beautiful lady!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Wow, really!?"
