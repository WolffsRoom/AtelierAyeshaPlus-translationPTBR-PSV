        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Anyways, Nio, I'm the mix master of this tavern."
