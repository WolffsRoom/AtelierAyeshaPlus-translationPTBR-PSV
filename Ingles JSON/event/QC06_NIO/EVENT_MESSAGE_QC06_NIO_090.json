        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Come on, Nio, introduce yourself."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Okay. Nice to meet you, Juris! I hope we'll get along well."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Yeah, nice to meet you, too."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x141,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Whoa, Juris! Why isn't she calling you mister?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x143,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Nio, would you like a refill on your juice?"
