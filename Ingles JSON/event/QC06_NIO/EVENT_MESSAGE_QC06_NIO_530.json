{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_NIO_530.ebm",
    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Welcome to the Zweiteturm, Ayesha.<CR>Did you come here for research today?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, before that...is Mr. Keith here?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "He seems to be within the facility. Although, I cannot locate his exact location."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x31,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I was told that he was going to do some research in the facility's middle floor, so he must have gone down."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x33,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Currently, there is a deficiency in the facility's command relay pathways, and I cannot obtain any further details."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Okay. I'll go ahead and look around the lower floors."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x117,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Does he not get bored from reading books all the time...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Hahaha, he said this place was like his own personal paradise, so I'm sure it's fun for him."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x118,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "That is incomprehensible. I am sick and tired of books. I do not even want to see them..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "H-How can you say something like<CR>that...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x119,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ayesha, you would understand if you were a librarian in this facility for over 900 years."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Th-That probably is a tough job.<CR>I appreciate your efforts."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "So I would be grateful if you can relay to him that he should talk to the librarian every once in a while."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Okay, I'll tell Mr. Keith.<CR>I'll be going now!"
        }
    ]
}