{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_NIO_030.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Tonight is a nice night.<CR>The full moon looks so pretty."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "*yawn*"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Good evening, Sis.<CR>Wake uuup!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Hrrmm, Nio? If you're gonna come, I'd prefer if you came at an earlier time."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I was strolling around the area and lost track of time. This town is big, so there's lots of stuff to look at."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Ahhh, Nio! You've been sighted by other people!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "It's caused a big commotion recently. People've said they saw a ghost."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x138,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "What? Really?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "You can't go around causing trouble for people you don't know...or I'll get mad at you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13a,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "I felt bad when I scared away a man I didn't even know..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13c,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "But I just didn't know the place where I appeared, and I was wondering where I was..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13d,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Then the man got surprised on his own."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I see.<CR>So you didn't mean any harm?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13e,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "I tried to apologize, but he seemed to get even more scared and wouldn't listen to me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "So that's what happened...<CR>Well, just be careful next time."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Okay. I won't do anything to get you in trouble."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Oh, I guess it's time.<CR>I've gotta go back now."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Okay. Be careful, since it's dark."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Oookay. I'll see you later, Sis."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x4c,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Kyaaah!<CR>A w-will-o'-the-wisp!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "Heh, sooorry, but I'm not a ghost."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x4c,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "I-It's talking.<CR>H-Heeelp me!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "Hey, listen!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x4d,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "What!? A gh-ghost!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "unknown2": 0x1,
            "msg_string": "...If you're not willing to listen, fine. I have a different plan."
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "unknown2": 0x1,
            "msg_string": "Roaaarrr!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x4d,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Waaahhh, I won't taste good,<CR>so don't eat me!"
        },
        {
            "type": 0x4,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "Mwahahaha, I'mma gonna eat you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x1c,
            "msg_string": "Niooo..."
        }
    ]
}