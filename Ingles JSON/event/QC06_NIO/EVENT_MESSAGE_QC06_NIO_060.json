{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_NIO_060.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ayesha, welcome back. And Nio, welcome."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "It's really been a while since you've been here."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hehehe, thank you for letting me come. This place hasn't changed a bit."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Thank you for all the help you gave my sister while I was gone."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "My, my, how proper... Nio, you're so polite and well-mannered."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Well, I heard from my sister that you did a lot for me."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Thank you so much."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Stop that. I've known you from way back when, so what I did was only natural."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Wow, Regina, this room brings back so many memories!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "I think, at the most, Ayesha added some stuff."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Way back when, you two came to sleep over from time to time..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Yes. You gave me a whole bunch of sewing lessons."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "And you taught me how to cook.<CR>I guess we both learned valuable<CR>skills directly from Regina."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Hehehe, Regina's like our older sister."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hehe, and you two are like my younger sisters."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Younger sisters? Then that means...<CR>...Big Sis Regina?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x122,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "Huh? What are you saying all of a sudden?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Hehehe, I just wanted to try saying it."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Oh, that's not fair. I want to, too!<CR>Big Sis Regina!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x126,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "Ah, I got two more sisters all of a sudden. Then, I'll do my part and..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Ayesha, make dinner! Nio! You go do the laundry and clean the room!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Huh? Isn't the big sister supposed to do that stuff?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "That might be true of others, but we're different. This is how we do it in my family."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x123,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Regina, it's a little different than what I imagined..."
        }
    ]
}