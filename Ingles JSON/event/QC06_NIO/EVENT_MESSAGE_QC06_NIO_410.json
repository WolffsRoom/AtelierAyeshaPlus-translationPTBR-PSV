        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Of course! I'm gonna securely save up the sales money!"
