        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "*sniff* Nio, you're such a good girl... Then, maybe I'll take this?"
