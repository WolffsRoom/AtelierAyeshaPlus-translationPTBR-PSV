            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Huh, Nio!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Well, I heard that I could open up a shop here, so I'm trying it out."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I'm selling stuff that I gathered, like medicinal herbs."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x4,
            "msg_string": "You're really good with putting things into action. I haven't heard about this yet."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Sorry. I wanted to help you out..."
