        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "And I'm gonna do by best with the things that I can do!"
