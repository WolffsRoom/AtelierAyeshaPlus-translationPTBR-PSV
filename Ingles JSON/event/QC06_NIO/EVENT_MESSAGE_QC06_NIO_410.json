            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "When I have enough money saved up, I'll give it to you!"
