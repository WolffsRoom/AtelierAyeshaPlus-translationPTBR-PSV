            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "So I wanna do something for you,<CR>since you're always doing your best!"
