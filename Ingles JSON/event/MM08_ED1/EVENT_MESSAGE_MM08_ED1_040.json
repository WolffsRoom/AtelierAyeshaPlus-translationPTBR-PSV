{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM08_ED1_040.ebm",
    "nb_messages": 0x36,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x0,
            "msg_string": "I wonder what Mr. Harry's special something is all about..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "He didn't give us any hints in his letter. Hmm, what could it be?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "He said he wanted to surprise us, and that we should go to the bridge in  Hornheim."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I'm starting to get nervous..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Hmhmhm, I'm starting to get excited. Let's hurry up and go!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hello, Mr. Harry!<CR>Whoa, that's a big balloon...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Hmhmhm, surprised? This is my special, custom-made balloon..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x22,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I have christened it \"Knowledge and Freedom Explorer\"!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Wow. That's...a powerful name!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x25,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Isn't it? It satisfies my curious mind and adventurous spirit."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "So was your special something just the unveiling of this balloon?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Well, of course that was part of it. However, there's more to it than that."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x22,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Because, I had this balloon custom-made for you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Oh... Huh!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x25,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "For the past three years, you've been remarkable. You found various treasures, hidden items, and rare articles."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Honestly, I was jealous of your skills... The skills possessed by such a young adventurer."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "But I'm not an adventurer, I'm an apothecary..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x22,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "However! You cannot allow yourself to believe that you've reached the top..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x24,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Because this world is still full of hidden treasures that we don't even know about."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "That's...true. The things I found were only a small portion, compared to everything there is..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Yes, exactly. Just thinking about it is enough to get your blood flowing!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x15,
            "msg_string": "I wonder... It kinda makes me excited, but also kinda doesn't..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x56,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "Hmhm, just be honest with your feelings. I can hear the voice of your heart."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x57,
            "expr_id": 0x2,
            "msg_id": 0x17,
            "msg_string": "True, being an apothecary may be your vocation, but it doesn't have to be your only one!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x57,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "To pursue unknown treasures...is also your vocation!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x5e,
            "expr_id": 0x2,
            "msg_id": 0x19,
            "msg_string": "Let me ask you... Undiscovered treasures are still hidden all over the world. Would you like to find them together!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x1a,
            "msg_string": "Umm, does that mean...that you and I will travel together to hunt for treasure, Mr. Harry...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x58,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Exactly. This balloon was prepared for just that purpose!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Oh wow, now this is something. Sis, are you gonna go out on this adventure?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Hmhmhm, I'm sorry, but I'm going to borrow your sister for a while."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Don't worry. You won't have to wait too long. After a month or two, we'll return..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x161,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "With this ship full of unidentified treasures!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x20,
            "msg_string": "Whoa! I wanna see all of it, Sis!<CR>Do your best to bring back lots of treasure."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x21,
            "msg_string": "And you too, Mr. Harry! I'll be waiting for SUPER treasure!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15d,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "msg_string": "(Hmm...Mr. Harry's plan does sound kinda fun.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "msg_string": "(But I have my apothecary jobs and other promises... Ergh, what should I do?)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Well, this is all so sudden and I'm starting to get a little confused..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "There's no need to have doubt. Just give in to your heart's desires and scream, \"Yes!\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Umm, then... Yes!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Good, it's decided. Then let's leave at once!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "Excuse me... Do you mean, like, right now?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "Yes. The treasures that still sleep all over the world are awaiting our arrival."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "The world will be a strong opponent. However, if we team up, there's nothing for us to fear."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x22,
            "expr_id": 0x0,
            "msg_id": 0x2b,
            "msg_string": "We should be thankful for being born into this world full of mysteries and treasure."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x25,
            "expr_id": 0x0,
            "msg_id": 0x2c,
            "msg_string": "Hmhmhm, how wonderful is it that our world is so full of hope!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2d,
            "msg_string": "Wh-When you put it that way, I think this trip is getting more exciting..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2e,
            "msg_string": "Okay! Let's do this, Mr. Harry!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x2f,
            "msg_string": "Umm, well...I'm sorry. I have a previous engagement..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x30,
            "msg_string": "What!? You're not going? Hmm..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x31,
            "msg_string": "To decline an offer this grand, I must assume that you have already started chasing after a great treasure."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x32,
            "msg_string": "I see, I see... I guess fate demands that we be rivals after all."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x33,
            "msg_string": "I understand. You will go your way, and I shall go mine, each of us searching for our treasure."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x34,
            "msg_string": "We both will have a friendly rivalry with each other. That's also good."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x35,
            "msg_string": "Umm, treasure has nothing to do with it... I'm so sorry!"
        }
    ]
}