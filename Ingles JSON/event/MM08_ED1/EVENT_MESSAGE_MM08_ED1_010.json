{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM08_ED1_010.ebm",
    "nb_messages": 0x44,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x216,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "Oink moo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x138,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Whoops, that took longer than I thought! I need to hurry home!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13a,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "I'm sure Sis is worried by now."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "If I make her any more worried,<CR>I might get grounded!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x4,
            "msg_string": "All right, it's almost done,<CR>but...Nio sure is taking a while."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hyaaah, sorry I'm late, Sis! I'm home!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Welcome back. What took you so long?<CR>I was worried."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Hehe, sorry. I lost track of time while I was gathering the medicinal herbs."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Nio, that's not the only reason, is it?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13c,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Ahh, so you could tell?<CR>...I kinda loitered around.<CR>I'm sorry."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I know how you think. When the weather's this nice..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Even I'd want to loiter around a bit outside."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Well, I'm wrapping things up here,<CR>so let's take our lunch break."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13e,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Yay! I'm staaarrrving!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I'm done!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Hmhmhm..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "What are you laughing about all of a sudden? Is there food on my face?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "No, no, it's nothing. Eating meals with you like this..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Reopening our workshop, and with all these jobs flowing in...."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "Goodness, I can't keep up with all these orders! I don't have time to eat like this!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "...Was what I was thinking. Then it made me happy to realize these are the kinds of things I have to deal with now."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Wait, then you're in no position to be happy! Sis, you accept too many jobs without a second thought!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "Haha, I know, but all of them are so important, I can't say no."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "If I work hard enough through the night, I think it'll all turn out fine."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Wow, Sis! With all your new friends, you have so many clients now."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "If you don't start planning things out, it could get way out of hand real quick."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Do you know what your next plan is?<CR>You've been pretty vague about it,<CR>so I'm a little worried."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x1b,
            "msg_string": "I have a rough idea. Let's see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Oh, that's right. I have lots of orders from Ernie piling up."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x138,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "*gasp* Oh no! If you're late, you'll be making it harder for Ernie."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "I know, but he's always so forgiving about the deadlines, I end up being late..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13a,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Ernie looks after us a lot, so you can't be late."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "You're right. Okay, after I eat, I'll get right back to work."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Nio, will you help me?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Of course! If we do it together, I think we'll finish by tomorrow morning!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x23,
            "msg_string": "Let's do this! Yaaay!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "I feel like I had a delivery to make in Vierzeberg..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x25,
            "msg_string": "Correct! Hmhmhm, you're getting more reliable!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "I went on a lot of journeys and trained myself while you were gone."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "I think I'll leave tomorrow morning. Do you want to go with me, Nio?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x28,
            "msg_string": "Ooh, yes, yes! Don't leave me!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "Hmhm, okay. Then we should wrap it up early today and‐"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x2a,
            "msg_string": "And prepare for tomorrow! Leave the packing to me!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x2b,
            "msg_string": "Oh yeah, did I get a letter from<CR>Mr. Harry...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x2c,
            "msg_string": "He says he has something special for us. I wonder what it could be..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x2d,
            "msg_string": "He does? I bet it's really interesting!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x2e,
            "msg_string": "Maybe he found another new ruin.<CR>Or maybe he got something cool."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x2f,
            "msg_string": "This sounds really fun. I wanna go see, too...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x30,
            "msg_string": "You sure are extremely fond of Mr. Harry's hobbies, aren't you?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x31,
            "msg_string": "Yup. Hey, can I tag along with you?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x32,
            "msg_string": "Of course. If you go, I'm sure Mr. Harry would be happy as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x33,
            "msg_string": "Then it's decided. Tomorrow, let's go to Vierzeberg and check out his special something!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x34,
            "msg_string": "...Well, none of my orders need to be rushed. And, I did get a lot done today..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x35,
            "msg_string": "Oh, really? Then I guess we don't need to push ourselves."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x36,
            "msg_string": "Sis, you've been working nonstop for the past couple of days."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x37,
            "msg_string": "Maybe you should take a break..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x38,
            "msg_string": "Hmm...but I still have lots of work, so if I slow down, the deadlines are gonna sneak up on me in a flash..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x39,
            "msg_string": "No! If you work too hard and collapse, it's only gonna cause trouble!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x3a,
            "msg_string": "A first-class apothecary takes a break when she can! Resting is a part of the job, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x3b,
            "msg_string": "Yeah, you're right. Then maybe I'll take it slow today..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x3c,
            "msg_string": "...That's right, I forgot something important. There's something I need to research..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x3d,
            "msg_string": "You need to study? But Sis, you're already good enough to be a teacher."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x3e,
            "msg_string": "Haha, I'm still not to the point where I would feel comfortable teaching someone."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x3f,
            "msg_string": "There's lots of things I still don't know about. I still have a lot of hard work to do."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x40,
            "msg_string": "Maybe it's more like a pure interest in alchemy, rather than having to study..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13c,
            "expr_id": 0x4,
            "msg_id": 0x41,
            "msg_string": "I don't really like reading books..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x42,
            "msg_string": "Then, do you wanna stay home?<CR>I'll be gone for a couple of days."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13d,
            "expr_id": 0x4,
            "msg_id": 0x43,
            "msg_string": "Uhh, I don't want that!<CR>I'll go with you!"
        }
    ]
}