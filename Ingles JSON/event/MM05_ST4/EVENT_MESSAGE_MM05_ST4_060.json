            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "If it's just for a short while, I think I can hold him back. So Sis..."
