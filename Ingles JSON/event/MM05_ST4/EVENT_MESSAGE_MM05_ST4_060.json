            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yup. Nio, you did a good job hanging in there till now. Let's go back to the workshop together...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "I don't think I can... The person here is really mad, and he won't let me out of this place."
        },
