            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "But even so, I can still listen to you. If anything happens, come and tell me any time."
