{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM05_ST4_660.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Here you go. Thanks for coming...<CR>And here is where I stop being a store clerk."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ayesha, you've been so low on energy recently... Something wrong?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Huh? Do I look that gloomy?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "You're always, like, way up in the air, but you seem to have less energy than that recently."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Th-That's not true! I'm full of energy, see, look!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hm, looks like you're trying hard. Why are you‐"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Hmm, I've been wondering the same thing. Ayesha, recently you've been lacking your usual vigor."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "But rest assured, I have a special remedy."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hmhmhm, to prescribe medicine to an apothecary... I am pretty good."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Enough with the self-praise. So, what kind of medicine are you talking about?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I am, of course, talking about the collection I recently obtained!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Books and lithographs that were excavated from ruins, and pretty crystal balls and other ornaments!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "There's no way that Ayesha, with her burning curiosity and ambition, wouldn't be interested in these!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Heh...Mr. Harry's collection... I'll be sure to take a look at it next time."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0xe,
            "msg_string": "Hmm, displaying no reaction to even my treasured collection... This is looking pretty severe..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Really? I think that's a pretty normal reaction. Anyways, get back to work, Owner!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xb1,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "*sigh* It turned out to be a boomerang..."
        }
    ]
}