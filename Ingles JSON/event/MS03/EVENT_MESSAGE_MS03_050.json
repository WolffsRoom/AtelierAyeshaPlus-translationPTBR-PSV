            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "With this system, you use points to write in the diary. Writing entries can reward you with appropriate bonuses."
