{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS03_120.ebm",
    "nb_messages": 0x2f,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Umm, I want that one.<CR>And the ceramic one over here."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, it's rare to see you out shopping, Marietta."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "This bazaar is the only chance I get to be on the buyer's side."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2e,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I'm always selling items, but I really love shopping."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2f,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "It's a good opportunity, so I gotta have fun."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Well? Wanna go shopping together?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "That sounds fun! I'd love to join you."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Oh, that person is...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Oh, it's Mr. Keith. I wonder if he came to look for some lucky finds."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "He's as ruggedly handsome and stunning as always..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "(I wonder if Mr. Keith is Marietta's<CR>type...)"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "This is a good opportunity.<CR>I want to talk to him for a bit."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Ayesha, can you introduce me to him?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Uh, o-okay... But why?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I have a few questions I'd like to ask him... Like, whether or not he's seeing someone right now."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Ehhh!? I-I'm sure you'll be able to talk to him, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "Alright. If you're okay with it,<CR>then let's just go now!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Umm, excuse me."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Hm?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Oh, Marietta. Do you want something from me?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x14,
            "msg_string": "Eh, Owner!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I mean...Owner, what are you doing here?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Can't you tell, I'm on patrol. I'm checking for myself if the bazaar is going smoothly."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "What are you doing here?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a7,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Oh, nothing. Well, I've gotta get going now... Good-bye."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "*huff* *huff* Ugh, that scared me.<CR>I wonder when they switched..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "I guess we lost track of him in the crowd..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "I guess Mr. Keith and Mr. Harry look a little alike."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf9,
            "expr_id": 0x4,
            "msg_id": 0x1c,
            "msg_string": "HOW!? Goodness, even if they're both middle-aged men with mustaches, they're completely different."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xfa,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "I totally thought that I was going to reunite with the gentleman with the mustache..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xfb,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Oh...where could that splendid man have gone...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Oh, he's over there."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x20,
            "msg_string": "Huh? Where!? Oh, you're right!<CR>Okay, this time for sure!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x21,
            "msg_string": "A-Are you gonna go after him again?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x7a,
            "expr_id": 0x3,
            "msg_id": 0x22,
            "msg_string": "Of course. I'm gonna talk to him,<CR>no matter what."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x7c,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Ayesha, follow me!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x123,
            "expr_id": 0x4,
            "msg_id": 0x24,
            "msg_string": "Wha-huh!? Okay!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Umm, good afternoon."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Hm?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Oh, it's you girls again. I sure have run into you two a lot today..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x28,
            "msg_string": "What, again!? Why!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "That's my question. Could it be that you girls are following me?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "N-No. Well, good-bye..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0x2b,
            "msg_string": "Whew... Ahhh, that was a surprise..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2c,
            "msg_string": "What do you wanna do? Do you still want to look for Mr. Keith?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0x2d,
            "msg_string": "No, I'm good... I'm sure that no matter how many times I go, he'll just keep transforming into Owner."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0x2e,
            "msg_string": "Today's just a bad day..."
        }
    ]
}