{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS03_140.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Let's see... What should I buy today?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Little miss charming girl, do you need someone to carry your things?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Oh, Mix Master! I didn't expect to see you at the bazaar."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Yup. I like to come and look for lucky finds every once in a while."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "But, as expected of Vierzeberg, so many different things have caught my eye."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "You're right. There are a lot of<CR>ingredients or food from all over<CR>the place."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "Yeah, yeah, there are ingredients, too, but more importantly, there are so many cute girls!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x7,
            "msg_string": "Jeez, Mix Master, you have shopping to do."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Bwahaha, I know that. But, how do I say this? This is like a golden opportunity."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Coming all the way to Vierzeberg...is it really okay to just be looking for ingredients?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17d,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Isn't there something else I should be doing?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0xb,
            "msg_string": "As the master of a tavern, I think you should search for ingre‐"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17f,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "No! There are so many girls who are just waiting for me to ask them out!"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10c,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "If I ignore their plight, I'd be so ashamed of myself!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0xe,
            "msg_string": "I-Is that so...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10e,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "I mean, you do have a point there. I've been asking myself the same thing..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "But...<CR>Hellllooo, my ladies!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "...Me?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "(What? Marion and Linca? I-I wonder what's gonna happen...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "msg_string": "(Hahaha... I knew this would happen...)"
        }
    ]
