            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xea,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "We were going to start organizing them in the near future, but..."
