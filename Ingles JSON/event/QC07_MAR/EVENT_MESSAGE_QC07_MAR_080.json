            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Hehehe, I thought you might be busy,<CR>but is it okay if I interrupt?"
