{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_MAR_530.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "This place is a warren for Tauns.<CR>I come here a lot to gather<CR>ingredients for medicine."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I see. It's really full of plants,<CR>but it doesn't look like the soil<CR>is all that fertile..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "I mean, it's growing directly out<CR>of the rocky surface of the ruin.<CR>It's amazing."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "These are...medicinal herbs that are often used for alchemy..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I've heard that somewhere deep under the ruin, there's a crystal that gives plants power..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "The medicine made from the medicinal herbs here is very popular."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I see, so you're not just an ordinary apothecary?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Hehehe...um, but I am just an ordinary apothecary."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x122,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "Kyah! Wh-What is that!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Oh, that's a Fruit Hamster. There are a lot of them around here."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xa,
            "msg_string": "They're pretty mischievous, so I have a hard time dealing with them."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x126,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "I-It's...so cute! I want one!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0xc,
            "msg_string": "Huh? But they're so mischievous,<CR>if you have one as a pet,<CR>it'll cause so much trouble."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0xd,
            "msg_string": "They come all the way to my workshop to scavenge for trash, or come in through the window at night and bite my ear..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I'd be fine if they nibble on my ear."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Marion has a weakness for cute things."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I-I see..."
        }
    ]
}