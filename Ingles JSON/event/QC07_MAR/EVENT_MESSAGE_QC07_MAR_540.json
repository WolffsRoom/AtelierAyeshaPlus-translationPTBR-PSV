{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_MAR_540.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "This is...someone's grave?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Umm, have I told you before that I'm searching for my sister?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "That's right, I remember.<CR>Have you found any clues?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "No, not yet."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "My sister...her name is Nio, but she was spirited away in this ruin."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "So this is presently Nio's grave."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I've heard about people being spirited away at ruins in other areas, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I guess it's only happened a few times for as far back as the stories go..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "There are different theories, like<CR>people being captured by the ruin,<CR>or being possessed by a spirit, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "No one has uncovered the truth yet.<CR>Part of my assignment is to<CR>investigate that, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Huh? Do you actually know something?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Well, if there's one thing I can tell you...it's that I have no clue what's going on."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I-I see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I'm sorry. I'm still groping my way through the ruins. I'm not an expert or anything."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "If they sent an investigation team with me, we might find something out."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Since you have your circumstances to deal with, I'll let you know if I find anything out, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yes, please do...!"
        }
    ]
}