{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_MAR_740.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x1f8,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "Yo, long time no see, little missy."
        },
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x1ff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "I was just starting to think that you had finally given up."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "I apologize for being unable to visit after I claimed that I'll return as many times as it takes."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I explained my situation in the letter, but it still doesn't change the fact that I wasn't able to come here."
        },
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x200,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "Yup. I'm sure your work is hard,<CR>but you have to keep your promises."
        },
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x200,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "So, I can't let someone enter who can't keep her word."
        },
        {
            "type": 0x1,
            "voice_id": 0x20e,
            "name_id": 0x24,
            "extra_id": 0x203,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "Now, go home!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Okay. I'll go back for today."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Boss looks really happy today."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Huh...? He seemed to be mad."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "No, I can tell. Since the day he got the letter..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "He's been restless ever since."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xe9,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "No luck today, either. His head's as hard as the stones in the ruin."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Well, Marion‐"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hold it, Ayesha. Just gimme a sec."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Huh...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "That's too bad, Marion."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xed,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "It can't be helped. Like your boss said, it's my fault for not being able to keep my promise."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "But, I'm not done yet. I'll continue to visit."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Yup, you should. He's hardheaded, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Could you please keep coming without getting discouraged?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Huh? Yes. I'll come here no matter how many times it takes, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Okay, come again."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x17,
            "msg_string": "Regina, was that okay?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Hahaha, well, I don't wanna rob Boss of his delight."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Plus, maybe the job Marion mentioned before has already been accomplished."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "The one about building good relations."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "That didn't seem like good relations to me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Well, we'll just have to watch from the shadows."
        }
    ]
}