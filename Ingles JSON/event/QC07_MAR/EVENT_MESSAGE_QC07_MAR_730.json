{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_MAR_730.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Umm, hmm... What should I do...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Marion? Hellooo...huh?<CR>Is there a problem?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yeah. It's about the boss from Riesengang..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I was thinking of how I should persuade him next time."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, about that... He mentioned something about you."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Huh? Really?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yes. He said something like how that high-spirited missy hasn't been around lately and he was wondering about you."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Oh, he did? I wonder if he's worried about me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xe9,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "My other jobs here had their schedule pushed up, so I couldn't go, but this might be a good opportunity."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xec,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "No, I should say that it probably would have been a good opportunity..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xea,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "If only I didn't have that other job..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "You can't go to Riesengang today?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xed,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "No. I have to go to Hornheim to receive a package. It's urgent."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "If you don't mind, I could go receive the package for you."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I actually have to personally go there and issue a certificate."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "If I didn't have to do that, I was even thinking of having Linca go."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x99,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "Ugh, I wish there were two of me!"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "If you could learn...the shadow cloning technique, that could be possible."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x9a,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "You're saying that like it's easy.<CR>Can you do it?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I am making an earnest effort!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x9b,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Okay, okay."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Well, I feel like I just need one more push, but today, I have to prioritize the package."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "I'll apologize to the boss with a letter. Ayesha, thank you for letting me know."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I'll take it as an \"if you can't push, you have to pull back\" strategy."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "msg_string": "(Marion really is always busy with something.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "msg_string": "(I bet being an officer is harder than I can imagine.)"
        }
    ]
}