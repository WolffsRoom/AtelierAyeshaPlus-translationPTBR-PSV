{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_MAR_520.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, Ayesha. We've been waiting."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I'm sorry! I had to do several things, and it took me a while to come here."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Don't worry. We were the ones who asked you in the first place."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I guess this place doesn't have a boss like in Riesengang, so the investigation was much easier."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "My family has always been in charge of this place. Although, as you can see, it's untouched."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Oh, I'm sorry for entering without permission."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Don't worry. And it's not like this place is dangerous."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Well then, we're counting on you for a tour of the ruin."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Okay. I'll do my best!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "Hahaha, you don't have to put too much effort into it. Just take it easy."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Although, this ruin is much more mysterious than the others..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "It's full of vegetation and rich with nature. I've never seen anyplace like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "My grandfather said that it might've been a place that grew plants to begin with."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I'm not sure about the details, but you can still gather various kinds of medicinal herbs."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hmm, I guess it's just like the other ruins, in a way, since it's full of unknowns..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Well, if we knew everything, we wouldn't need an official like me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Okay, I'll take you farther in. "
        }
    ]
}