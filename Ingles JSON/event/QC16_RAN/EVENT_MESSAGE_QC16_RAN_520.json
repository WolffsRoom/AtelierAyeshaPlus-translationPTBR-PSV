{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC16_RAN_520.ebm",
    "nb_messages": 0x32,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ayesha...this is cruel.<CR>This is very, very cruel."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Wh-What's wrong? Are you hungry again?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe1,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Has your image of me solidified as a starving young man?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "That's cruel, too, in its own way.<CR>I am certainly hungry, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x188,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "That's not the problem. Right now, I'm grieving over my misfortune for being abandoned by the goddess of music."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x189,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "She's not blowing a wind with a new melody to me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "But, I'm sure you've been working hard, so it'll come to you some day..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18b,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "But when will that day come? As I continue to wait, the seasons continue to come and go..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18e,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "O, Ayesha, I beg of you! Please take me to a place where the wind blows..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "msg_string": "(A place where the wind blows...?<CR>I-I wonder if he wants me to take<CR>him to a cliff...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Oh, hey, Ayesha. How've you been?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Huh? Who's this person...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Who, me? I'm Ranun.<CR>I'm a seeker of sounds."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "(Huh? That was a very simple introduction compared to mine...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Uh, sounds...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "And, who are you? Won't you introduce yourself after asking for my name?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x126,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "I'm Ernie! I do trading for a living."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I've also known Ayesha for a long time."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Oh, what a coincidence. I've been in Ayesha's care multiple times, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "C-Care!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "There is no need for a useless obstacle to come between us. Right, Ayesha?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Um, I'm not really sure..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Ayesha, can I have a word with you?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "That person is no good. I'm getting a seriously bad vibe from him."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Huh? Really?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Yeah, there's no doubt about it.<CR>My intuition is rarely wrong."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "That can't be true. Sure, he's a little different, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "He doesn't work so that he can put all his effort into music."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x1c,
            "msg_string": "That's weird! In short, he doesn't work, and he's always just wandering around, right?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "I think it's more of...he's always trying to come up with new music."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "A life without contributing to society is meaningless! Is it possible that he doesn't even have a house?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "msg_string": "(I've never seen Ernie react to anyone like this...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Heeey, leaving me out of the conversation and whispering on and on to each other is quite rude, you know."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Ranun, I understand your situation. You must be in a lot of trouble, right?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "What? You're right. I'm in trouble because there weren't any sounds of the wind, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x14,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "There's a part of me that thinks my agony might make me look cool..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "I don't know about sounds or the wind, but other than that..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "I believe I can help you instead of Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x188,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Huh? You? Hmhmhm, I'll pass."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x189,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "I'm getting a bad feeling about this."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x18a,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "Yes, something about the compatibility of our wavelengths, and that is something I cherish the most."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "I don't admire how you use such a childish system for the basis of your social relationships."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "I believe that what connects people to each other is a well‐grounded relationship based on mutual trust."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xb7,
            "expr_id": 0x3,
            "msg_id": 0x2b,
            "msg_string": "Hmhmhm, I wonder on what grounds he determines what is well-grounded..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x2c,
            "msg_string": "(Oh, I get it! Ernie and Ranun have a totally opposite way of life!)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x2d,
            "msg_string": "(Now that I think about it, they're like oil and water. Hmm...what should I do?)"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2e,
            "msg_string": "Don't worry, Ayesha. I'll take full responsibility for bringing this person to his senses."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xbf,
            "expr_id": 0x3,
            "msg_id": 0x2f,
            "msg_string": "By my senses, I'm perfectly fine.<CR>I've already got full control of them."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x30,
            "msg_string": "There's no reason to hesitate.<CR>Come on, let's go."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x31,
            "msg_string": "(Ohhh, I hope this ends up okay...)"
        }
    ]
}