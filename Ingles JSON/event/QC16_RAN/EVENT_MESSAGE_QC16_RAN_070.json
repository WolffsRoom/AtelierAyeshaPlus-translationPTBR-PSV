{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC16_RAN_070.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hey Ranun, before you get off, carry this."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Why? I told you that I graduated from doing labor."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Does your conscience not ache from making a weakling like me carry such a heavy thing?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Come on. You'll bite your tongue if you keep talking."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xbe,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "Hmph. A first-class singer like me<CR>would never do such an unsightly<CR>thing as‐oww!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "See, what did I tell you? Ranun, you always say one word too many..."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xc3,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "That's the way I live. Goodness, I don't want to carry anything that weighs more than my instrument."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I gave you a ride here, didn't I?<CR>I'll consider this as covering your<CR>ticket price."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xbc,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "That's sneaky. If that's the case, why didn't you tell me this beforehand?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Cuz I knew you'd complain if I told you."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "After we're done, I'll treat you to the meal of your choice, okay?"
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe5,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "You think you can bait me with food? You're thinking too lightly of me."
        },
        {
            "type": 0x1,
            "voice_id": 0x10,
            "name_id": 0x10,
            "extra_id": 0xe8,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "However, if you say any meal, then I'd like the daily special from White Crow..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Food after working tastes even more delicious. Come on, let's get this over with."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "(He's totally trapped at Ernie's pace. But Ranun seems to be having fun, too...)"
        }
    ]
}