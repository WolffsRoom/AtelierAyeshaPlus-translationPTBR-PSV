{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC13_ODI_510.ebm",
    "nb_messages": 0x1e,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Did you find the book you were looking for?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x1,
            "msg_string": "Actually I don't know which sections have what kinds of books, and..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "I'm looking for alchemy books...<CR>Do you have them here?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "So, books regarding alchemy. I will initiate the search. Please wait."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x186,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "There are 58,400 results.<CR>Should I read you the list?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Th-That many...? It's gonna be hard to read them all..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Except for a few rare exceptions, this facility has a variety of books."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "You may be able to narrow down your search. Would you like to do so?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Umm, I'm looking for alchemy books<CR>about flowers. Would you happen to<CR>have one...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Alchemy and flowers. I have included the key terms. I will initiate the search again."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x186,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Sending signal...<CR>Please wait one moment."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Okay, I'll wait."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Sending signal...<CR>Please wait one moment."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Okay..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "An unexpected malfunction has occurred. The database of alchemy search results has disappeared."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "...Huh?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x117,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "An additional malfunction has occurred. The database of flower search results has disappeared."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "What...? I feel like I did something terrible..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x119,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Please do not worry. The only things that disappeared were the search result databases."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I see, so the books are different."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x197,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Yes. Only the search results have disappeared. This has had no effect on the actual books that are kept."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x31,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I apologize, but please refer to the original book. Please head to the entrance over there."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x33,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "However, as I said earlier, the passage is blocked by the bookshelves that collapsed."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "We are currently performing repairs to the passage. Please wait one moment."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "msg_string": "(I sure have had to wait a lot today...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Thank you for waiting. The removal of the obstacles is now complete."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Thank you so much, Ms. Librarian. You've really been a great help to me."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "No. This is my job. The appropriate bookshelf you are looking for is 4-D 3."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Now, I hope for your safe return."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Okay.<CR>...Huh, my safe return?"
        }
    ]
}