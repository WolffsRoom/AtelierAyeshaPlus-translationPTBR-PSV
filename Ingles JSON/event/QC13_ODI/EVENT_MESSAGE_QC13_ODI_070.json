{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC13_ODI_070.ebm",
    "nb_messages": 0x1f,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x19f,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Thank you so much. Today's cake was very delicious."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "While I was eating these sweets that Ayesha brought me...one old memory has been restored."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Wow, it's about your past, right?<CR>What did you remember?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "It is about my master from before.<CR>He was intelligent, and very gentle."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Master left as he said, \"I'll return soon, so wait right here.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I believed his words and have been waiting here all this time, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x117,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "I have gotten a little tired."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "What? Ms. Odelia...I'll come here more often...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x119,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Thank you, Ayesha. However,<CR>waiting itself is not what is hard."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Without any duties, I have no reason to exist."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "From simply following the orders that were given to me, it is hard to confirm the significance of my existence."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "That's...umm, what kind of person was your master?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Well, that is a very old memory, so I cannot remember it clearly, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I feel like he was similar to Keithgriff."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Oh, to Mr. Keith...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x14e,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "However, inside he was completely different. Master was a very kind person."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x151,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "I would like Keithgriff to follow the example of Master."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Hahaha...I can't even picture Mr. Keith being nice..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x155,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Why is he so coarse and tyrannical?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Haha, I wonder..."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x150,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Since he is similar to Master,<CR>it is very unfortunate.<CR>Keith is very unfortunate."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Did you call for me?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Whoa, Mr. Keith! Umm, no, we didn't call for you. We weren't saying anything bad about you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "...?<CR>Well if you don't have any business with me, that's fine as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Oh, I know, Mr. Keith! Would you like to have some cake with us?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "I brought a really delicious one!"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "No. Thinking about sweets disgusts me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Hahaha, d-disgusts you...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x117,
            "expr_id": 0x4,
            "msg_id": 0x1c,
            "msg_string": "How shallow. You should eat at least one slice of cake with us."
        },
        {
            "type": 0x1,
            "voice_id": 0x8,
            "name_id": 0xd,
            "extra_id": 0x118,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "Goodness, you are so disappointing. Disappointing and unfortunate, Master."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x1e,
            "msg_string": "Whoa, it seems like Ms. Odelia is getting out of control..."
        }
    ]
}