{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_WIL_730.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ayesha, over there...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "Yay, we found her! Look, look,<CR>that's the Wind Ruler."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Wow, she's really pretty...<CR>She's shining."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "All right, let's tie her up!<CR>Ayesha, are you ready!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Let's just tell her our situation and see if she'll cooperate. She doesn't look like a bad spirit."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "What are you saying? There's only one way to deal with a spirit!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "You give them a hard punch, and make them listen to you! That's how it goes."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x7,
            "msg_string": "Ehh...are you sure it's okay to do something like that to a pretty spirit like her?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Don't let your guard down. They may look like that, but spirits are pretty vicious."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Their values are completely different from ours. If you're not careful, they'll slice you with blades of wind..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Hrgh, I...wouldn't want that to happen."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Hey, don't chicken out. We're finally here, so we've gotta go all-out!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "So, you didn't hesitate to come this far, Wind Ruler!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Bell, if anything, we're the ones that came this far..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hrgh... A-Anyways, we came here to capture you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "Come quietly! Turn yourself in!"
        },
        {
            "type": 0x4,
            "voice_id": 0x3d,
            "name_id": 0x33,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "Are you saying you are going to capture me?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x82,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "Yup. It saves time, the quicker you catch on. You can resist, but it'll be useless!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x83,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "I'm gonna catch you and prove that I'm a full-fledged witch!"
        },
        {
            "type": 0x4,
            "voice_id": 0x3d,
            "name_id": 0x33,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "How foolish. See if you can stand my blades...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Whoaaa...h-here she comes!"
        }
    ]
}