{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_WIL_620.ebm",
    "nb_messages": 0x1c,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "...and so, I want you to buy this from me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hello, Marietta... Oh, Bell!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Are you here to shop? Sorry, but can you wait till I'm done with my business."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I'm currently negotiating a sale!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Let's see... How do you use this? Actually, what is this to begin with?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Umm, that's a trade secret. You'll just need to be in the know to use it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "But, it'll be fine, since I'm sure the person who understands what it is will be able to figure out how to use it!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "That's not the way this works. I can't display something for sale in the store if I can't explain what it is."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Make an exception for me! Don't worry, I'm sure you can sell this for a high price in the future!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Bell, isn't that a magic tool?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yeah, it's a valuable piece. It's a fine item that you'll rarely get to see."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "But, it's hard to sell it when I have to hide the fact that it's a magic item."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Wilbell, I'm sorry...but I don't think I can buy this from you."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Huuuh? Whyyy nooot?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf7,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I'm sure the owner would agree if it was easy to tell that it's a great treasure."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "...A great treasure?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a6,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yup. Like the ones from the ruins.<CR>For example, this one."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1c2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I see... Just for personal reference, how much would this be?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Let's see... The owner really likes this kind of stuff, so it'd be at least a million Cole..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "ONE MILLION!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "(Oh, this might lead to...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Bell, I just remembered that I have to do something, so I'll be going..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Hold up."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Uh, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "We'll split the reward fifty-fifty,<CR>so you're coming with me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "*sigh* I knew it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Well, let's go find a great treasure!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "(I knew this would happen...<CR>Bell immediately puts her<CR>thoughts into action.)"
        }
    ]
}