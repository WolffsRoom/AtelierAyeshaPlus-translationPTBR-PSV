{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_WIL_030.ebm",
    "nb_messages": 0x19,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Well, now that I have Bell with me, let's head out in high spirits!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "Hold it right there! Before we leave town, there's one thing I need to tell you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x82,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Okay? It's important,<CR>so listen carefully. "
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x83,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "We, witches, can't reveal our existence to the world..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x84,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Because our magical powers are so strong. It's a really serious matter if we abuse our power."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "We can control the weather, produce something from nothing, and can even shoot down stars in the night sky..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "If abused, it's even possible for us<CR>to...destroy the world."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "A-A-Amaaaazing! Bell, I didn't know you could use that kind of magic...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Huh? O-Of course I can...or maybe I should say that I'll be able to, over the course of time..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd5,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "In any case, we live modestly,<CR>hiding from the world."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I didn't know. I guess being a witch is pretty hard. Huh? But..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "What!? Is my outfit weird?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xc,
            "msg_string": "It's not weird, but, how can I say it...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "(I wonder if I'm the only one who<CR>thinks she's not trying to hide it<CR>all that much...?)"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Huh? What's wrong? Why are you looking at me like that?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "No, no, it's nothing!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "If you ever reveal my true identity, I'll turn you into a frog!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Hyah! I don't like frogs, so can't you turn me into a cat or cow..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Cats and cows are outside my forte!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Oh, then I'd prefer something with fluffy fur, like a dog."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x14,
            "msg_string": "Jeez, it'll be fine as long as you don't tell anyone!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Right. I won't tell anyone that you're a witch."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x80,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Shhh! Not so loud! What if someone heard you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc7,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Ahhh, sorry!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Be more careful. Okay, let's get going!"
        }
    ]
}