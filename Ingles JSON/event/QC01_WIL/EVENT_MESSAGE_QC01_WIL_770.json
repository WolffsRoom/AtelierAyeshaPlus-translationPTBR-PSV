{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_WIL_770.ebm",
    "nb_messages": 0x41,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Bell, let's go tell your<CR>Great-great-grandmother right away!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x169,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Huh, already...? Well, that's..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x16b,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hahaha, why don't we do it tomorrow?<CR>I'm not mentally prepared yet..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Nope. These things go much better when you do them immediately."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I'll be by your side, okay?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "...Okay, I'll report to her."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "Wilbell, you have been expelled.<CR>What business do you have with me?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "U-Umm, well..."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "Surely, you did not call me for no particular reason, right?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Well, that's, I mean..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "(Bell, you can do it...!)"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "...I have something that I really want to tell you."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Something you want to tell me...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Yes. I won't quit being a witch!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I've always been a witch, and that'll stay the same forever!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "Wilbell, you do realize that what you did was not permissible, correct?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yes, Great-great-grandmother. My last task submission was frivolous. I'm sorry."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I thought you would be happy, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "I'm sorry, I was wrong."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "And after you got mad at me,<CR>I thought really hard..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "About my tasks, about you,<CR>Great-great-grandmother,<CR>and...and about magic..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I thought lots and lots about whether I had the qualifications to be a witch."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "...And, did you get your answer?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "No. I don't know. I didn't reach my answer."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "But, I did understand something...<CR>That I am a witch, after all."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "I reflected back on myself, and thought a lot, and that was the answer I came to."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Being expelled isn't something that can be annulled, just because you've determined to become a witch."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Yes, I know. That's why I went out and tried my best."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Well, it's not something I can physically show you...but I made an agreement with the Wind Ruler."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "unknown2": 0x1,
            "msg_string": "With the Wind Ruler...?<CR>Does that mean you captured the wind?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "I couldn't fully catch the wind...but she did promise me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "That she'll let me borrow her power of the wind."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "unknown2": 0x1,
            "msg_string": "An agreement with a spirit is very hard and challenging to make."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "unknown2": 0x1,
            "msg_string": "And for you to have achieved that..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Great-great-grandmother! What Bell is saying is true! I was there, too!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "I thought I beat the Wind Ruler with Ayesha, but she wasn't using her full power..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "But the Wind Ruler did acknowledge us!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "unknown2": 0x1,
            "msg_string": "I see, Wilbell. I understand your point."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x26,
            "unknown2": 0x1,
            "msg_string": "It's not a story one can accept without proof of the contract, however..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x27,
            "msg_string": "*ba dump* *ba dump*"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x28,
            "unknown2": 0x1,
            "msg_string": "I'll trust Ayesha's story for now."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "Huh? That means..."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2a,
            "unknown2": 0x1,
            "msg_string": "To be acknowledged by the Wind Ruler, you would have needed something more than just magic."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2b,
            "unknown2": 0x1,
            "msg_string": "You must have worked hard, Wilbell. And..."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2c,
            "unknown2": 0x1,
            "msg_string": "You have a good friend."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2d,
            "msg_string": "Great-great-grandmother..."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2e,
            "unknown2": 0x1,
            "msg_string": "Ayesha, as you can see, she's still an inexperienced girl, but..."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2f,
            "unknown2": 0x1,
            "msg_string": "Thank you so much for all your help.<CR>And please..."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x30,
            "unknown2": 0x1,
            "msg_string": "Keep watching over her with a warm heart from now on, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x31,
            "msg_string": "Y-Yes, of course."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x32,
            "unknown2": 0x1,
            "msg_string": "Don't forget your original intentions, and keep working hard on your training, Wilbell."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x33,
            "msg_string": "Yes, thank you,<CR>Great-great-grandmother...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x34,
            "msg_string": "Yaaay! I get to continue being a witch!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x35,
            "msg_string": "Congratulations, Bell...!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x36,
            "unknown2": 0x1,
            "msg_string": "At any rate, the Wind Ruler...<CR>Hmhm, that brings back memories."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x37,
            "unknown2": 0x1,
            "msg_string": "When I was your age, I made a contract with her, as well."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x38,
            "unknown2": 0x1,
            "msg_string": "Give my regards to the Wind Ruler when you see her again."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x39,
            "msg_string": "Yes, I will!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3a,
            "unknown2": 0x1,
            "msg_string": "And one more thing...the cake I received was delicious."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3b,
            "unknown2": 0x1,
            "msg_string": "Thank you, Wilbell."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3c,
            "unknown2": 0x1,
            "msg_string": "The next time you come back,<CR>I'll bake cookies in return."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3d,
            "unknown2": 0x1,
            "msg_string": "So...come by. I want to see your face again."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x3e,
            "msg_string": "...Yes. Me, too. Thank you,<CR>Great-great-grandmother...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x3f,
            "msg_string": "(At one point, I wasn't sure what was gonna happen, but I'm so happy for you, Bell...!)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x40,
            "msg_string": "(After all, being a witch suits you best!)"
        }
    ]
}