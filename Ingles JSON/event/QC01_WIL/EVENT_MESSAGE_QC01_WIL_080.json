{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_WIL_080.ebm",
    "nb_messages": 0x2f,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "And then, and then, the sweets from that shop are super yummy!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I even thought about spending aaall my money to buy up all their sweets."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Huh, they're that good? I'm really interested now. Let's go there together next time."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Sure! I'll lead the way!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Huh? What's that sound?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Ohhh, it's my great-great-grandmother!<CR>I gotta borrow this desk for a bit!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yes, this is Wilbell!<CR>Sorry to keep you waiting!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "(I didn't think Bell was afraid of anything, but she looks rattled...)"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x12,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "Hmhm, you don't have to talk so loudly. I can hear you perfectly."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x12,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x1,
            "msg_string": "Wilbell, it's been a while since we talked."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x12,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "I'm glad to see you're doing well.<CR>I'm relieved."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Yes! I'm happy to see that you look well, as well!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "And so, how may I help you today?"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "I'll get right to the topic at hand. The item that you sent the other day..."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "Was very well made.<CR>Everyone was surprised, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Th-Thank you so much,<CR>Great-great-grandmother...!"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "The person who made it seems to be quite skilled. Is this person your friend?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Ergh!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "(She knows...)"
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Your letter didn't seem to mention anything about this friend, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Great-great-grandmother, that's, well, the circumstances were complicated, and..."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "No matter the circumstance, I conclude that there's nothing to consider."
        },
        {
            "type": 0x4,
            "voice_id": 0xffffffff,
            "name_id": 0x28,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "You seem to be in need of a good lecture."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Oh nooo! I'm so sorry!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "msg_string": "(Ohhh...now I kinda get what's going<CR>on...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "That lecture was pretty long..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x1a,
            "msg_string": "Great-great-grandmother used to be so nice... But recently, every time she sees me, I get scolded."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x1b,
            "msg_string": "Great-great-grandmother must really hate me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "I-I don't think that's true. She was scolding you because you tried to cheat."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "B-But...her level of anger was more in line with hatred."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x1e,
            "msg_string": "I was probably adopted. I bet I was left somewhere, like under a bridge..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "I-I don't think...any of that is true."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "I'm sure she's only strict with you because she's thinking about you..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Hmm..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "If you messed up, then you just have to try again from the beginning, okay?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Don't worry, I'm sure you'll do fine next time!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "You...think?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Yup! Bell, you can do it as long as you try!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x166,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "You're right... I'm not weak enough to get discouraged by something like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "I'll try again! I'll make<CR>Great-great-grandmother acknowledge me next time for sure!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x28,
            "msg_string": "Yup, that's the spirit!<CR>You can do it, Bell!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "Yup, I'll do it. Well then, I'm gonna count on your cooperation again."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "I'll do it better next time!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x2b,
            "msg_string": "Huh? Do what better...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x2c,
            "msg_string": "I'm getting pumped now! I'm gonna come up with a new strategy!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x19a,
            "expr_id": 0x0,
            "msg_id": 0x2d,
            "msg_string": "I'm going home! See ya, Ayesha!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0xffffffff,
            "msg_id": 0x2e,
            "msg_string": "(I-I don't know why, but I get the feeling that \"doing it better\" means something different to Bell...)"
        }
    ]
}