        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1aa,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "I knew it, there's a letter.<CR>Let's see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x28,
            "extra_id": 0x1ab,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "\"I cannot thank you enough for always taking care of Wilbell.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x28,
            "extra_id": 0x1ab,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "\"As a small token of my gratitude, this time, I'd like to grant one of three wishes.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1ab,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Mm-hmm, mm-hmm. Huh!? Three wishes!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1ab,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "S-She can do something like this, too...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x28,
            "extra_id": 0x1ab,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "\"Of these three choices, please imagine the one that you most wish to receive.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1ab,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Imagine my wish... My wish would be..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1ab,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Okay, let's choose this one."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x28,
            "extra_id": 0x1ab,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "\"I really hope that you continue to look after Wilbell.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1ae,
            "expr_id": 0x0,
            "msg_id": 0xb,
