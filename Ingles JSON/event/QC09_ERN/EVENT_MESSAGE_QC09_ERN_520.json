{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_ERN_520.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a4,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello. I brought the medicine you ordered."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5f,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "Wow, really!? Thank you! My next job will go smoothly, thanks to this!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Hmhmhm, I'm glad I was able to help. Good luck with your big job."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x61,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "My big job... Now I'm starting to get nervous..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, it's rare for someone who's always happy, like you, to get nervous."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "It's a business meeting with a certain landlord, so even I'd get nervous."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "So, the merchant who was in charge of the crops that were harvested on this landlord's property just retired..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "And he hasn't decided who's going to take his place yet."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "S-So if you succeed, then that's going to be amazing, right?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yup. I'll become a great merchant who deals with all the crops from that entire area..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Normally, a newcomer like me wouldn't even get a chance at such a big opportunity..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "The landlord is a difficult person, and he hasn't chosen a replacement yet..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "But thanks to your medicine, it looks like I've won his favor."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Wow, then I'll be rooting for you! I'll be really happy, too, if you become a great merchant!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x102,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Hrgh, I don't do well when people have high expectations for me..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x108,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "This is a business opportunity, but this meeting is still too big and heavy for me to handle right now."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I see... I guess I wouldn't even know what to do if someone told me, \"You're a great merchant starting tomorrow!\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "But this is a great opportunity. I'm sure you should try your best!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x109,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Yeah...you're probably right. I don't know how much I can do, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x10a,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I'll do my best so that I can report back to you with some great news!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "(Ernie is always doing his best. I'm sure things will turn out great.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "(But if he comes through...I wonder if it'll be harder to reach Ernie...)"
        }
    ]
}