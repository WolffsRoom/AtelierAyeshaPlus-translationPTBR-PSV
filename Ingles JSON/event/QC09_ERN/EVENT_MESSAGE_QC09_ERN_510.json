{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_ERN_510.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Well, maybe I'll take a little break. I wanna eat lunch, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hello, Ayesha. Umm...do you have some free time?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Oh, sure. I was just about to take a break."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "That's good. I brought some sweets today..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Wow, sweets! Then let's enjoy them with some tea."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ah, that was so delicious. I have enough energy to work some more now!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Oh, Ernie, did you want to talk to me about something?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Oh, how did you know? I didn't even say anything..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "I can tell just from looking at you. I've known you for a long time."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x126,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "I see. Yeah, well, I came here today because I have a favor to ask you."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x127,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "I didn't want to ask, since it's for my own selfish reasons, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x127,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "I really need your medicine."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "My medicine? You don't have to be so secretive about it. Of course it's okay."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "If it's for you, I'm more than happy to help. Besides, you're always looking after me."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Really? Are you sure?<CR>Are you going to be okay?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Of course! I can synthesize in my spare time."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5f,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Thank you, Ayesha! That'll be a great help!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x61,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I have an important client who seems to like your medicine a lot."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "But he ran out of all the medicine he had, so he begged me to get some more for him."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I have a big business deal with him coming up, so I couldn't say no. Do you think you can prepare the medicine?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Sure thing. No problem!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Thank you! This'll really help me out, Ayesha!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x102,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Sorry for asking you to do a favor to help me out for my own personal reasons."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "(Ernie always looks after me!<CR>This will be an easy task.)"
        }
    ]
}