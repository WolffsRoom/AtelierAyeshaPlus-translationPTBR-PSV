        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x126,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "Unfortunately, my friend is a guy. He's a good friend of mine."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "He's helped me out before, too, so I couldn't just sit and watch while he was in trouble."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Hmhmhm, I see. But, I'm glad I was able to help."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I'll go deliver this right away.<CR>See you later, Ayesha!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "msg_string": "(I'm glad I was able to help Ernie.<CR>I hope his friend's fields will be<CR>okay...)"
