            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello, Ernie. I've gathered all the Anti-Bug Grass that you wanted!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Wow, this is a lot... With this much, I hope it'll be effective."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yes. The smoke from holding the dried grass over the fire will be especially effective."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Duly noted. I was debating whether or not to ask you for help, but I'm glad I did."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I'm sure my friend will be happy with this."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Umm...is your \"friend\" a woman?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "What!? N-No! Goodness, you girls sure like to talk about that stuff..."
