{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_ERN_010.ebm",
    "nb_messages": 0x21,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Well then, here's the payment.<CR>Thank you for the service."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "No, no, thank you for your patronage."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Oh, that's right! I have one sad bit of news for you, Ernie."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Sad? Is it like a business cancellation...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Nope. If I did that, my shop would be in trouble, too."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "It's about that girl who always makes the medicine. She's gonna stop making medicine for a while."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Huh? You mean Ayesha?<CR>How do you know that, Marietta?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Well, we've become acquaintances.<CR>She's a lovely girl, don't you think?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Ernie, you're a smoother operator than I thought."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x126,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "Don't tease me. Ayesha is like a little sister to me."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ohh? I still think that's suspicious, but okay. And about her business closure..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2e,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "She's gonna be traveling here and there. I heard there's something she wants to find..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "That reminds me, I think she left a message at her workshop..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "So she did close her business. I wonder where she could be right now..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hello.<CR>Oh, Ernie?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Huh, Ayesha!? What are you doing here!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Oh, I'm sorry. Long time no see, Ernie."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I felt bad for leaving without telling you."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x126,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Haha, don't worry about it.<CR>But, what happened?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Well, lots of things happened...and so I decided to go search for Nio."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Huh? For Nio...? But Nio is..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "I don't know the details yet, but Nio is waiting for me somewhere."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc5,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Well...it's hard to explain, but there is a reason."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x102,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Ayesha..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x108,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "Okay. I'm not sure what your<CR>circumstances are, but if you<CR>say so, I believe you."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x10a,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "If there's anything I can do,<CR>just let me know."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Ernie... Thank you so much."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2e,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Hey, hey, what're you guys talking about? Am I the only one who doesn't follow what's going on?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Oh, sorry. Well..."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "This shop sells various ingredients and items for alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can register synthesized items as products."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Registered products will occasionally show up at the shop."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "However, item categories that can be registered depends on the shop."
        }
    ]
}