{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_ERN_530.ebm",
    "nb_messages": 0x24,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x0,
            "msg_string": "Now that I think about it, I haven't seen Ernie in a while. I wonder what happened..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x1,
            "msg_string": "I remember him saying something about a big business opportunity..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x2,
            "msg_string": "I wonder if he became a great merchant who manages a whole area of land..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x3,
            "msg_string": "Or maybe the meeting got cancelled because he didn't like my medicine..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Hmm, now I really want to know..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hello?<CR>Ayesha, are you here?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ernie!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Long time no see. I'm sorry I couldn't visit you earlier. I've been busy."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Don't worry. So, what happened with that business you were talking about...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Well, thanks to you, we came to a nice agreement!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Whaaat!? Ernie, that's amazing! Congratulations!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "It's all thanks to you, Ayesha. Thank you so much!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "No, I didn't do anything. It's all because you worked so hard for it."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "No, I've really come to realize that I couldn't have won this contract by myself."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x106,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Thanks to your help, and everyone else's, I was able to come this far."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Ernie, you're so modest, but I like that about you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I'm sure everyone wanted to help because they like your personality."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x109,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Ayesha... Yup, I'm really glad I got to do this job..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x10a,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Hmhm, maybe my dream will come true after all."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Your dream? Is it like to become a famous merchant who travels all over the world?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5f,
            "expr_id": 0x2,
            "msg_id": 0x14,
            "msg_string": "That's not quite it. Hehe, it's cliche, but I want to open my own store someday."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x61,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I don't care if it's small, as long as it has a red roof and a nice atmosphere."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "For the store clerk...let's see... I'd want to have a girl, or a composed, mustached man."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Wh-Why does he need a mustache?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x102,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "I admire manly men who have mustaches. I've always been so weak..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x108,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "So I told myself that when I got older, I'd grow a mustache, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x109,
            "expr_id": 0x4,
            "msg_id": 0x1a,
            "msg_string": "No matter how long I wait, nothing. I wonder if I'm really lacking manliness..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x1b,
            "msg_string": "I-I wonder... Even without a mustache, I think you're an amazing person."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x1c,
            "msg_string": "But a mustache... Would it be like the one Mr. Harry has?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x10a,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Huh? I-I wonder. Mr. Harry's is...a bit different from what I like...I think?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Why do you have such low self-esteem?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x62,
            "expr_id": 0x2,
            "msg_id": 0x1f,
            "msg_string": "Well, haha... But I guess there's nothing I can do about it now."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x65,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "I just need to do what I can, one step at a time!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "We haven't reached a formal contract, so I can't let my guard down, but I'll do my best!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "You're so lucky.<CR>Your dream is growing...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "msg_string": "(Ernie is always working so hard. I hope they settle on a nice agreement...)"
        }
    ]
}