{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_ERN_720.ebm",
    "nb_messages": 0x1f,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Hmhmhm♪<CR>Hmhmhm♪"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, Tanya, are you working here today?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "You seem to be in a great mood.<CR>Did something good happen?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "Hehehe, I'm actually on my way to a good thing. I'm gonna go take a bath."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, would you like to join me, Ayesha?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Huh? There's a bath in a place like this?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yuuup. Further down from here, there's a hot spring."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "You can rinse all your sweat off,<CR>so it'll feel so nice."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "(A hot spring...? My skin does feels all icky from the sand and salt and dust...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yes! I'd love to go with you!"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Okay, then I'll take you there!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "Phaaah... This feels sooo good. I feel like I'm just gonna melt away..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Being able to see the horizon in all directions...it feels miraculous to take a bath in a place like this."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "I'm sure no one's watching, but being naked outside makes me nervous."
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "Hahaha, please just relax and enjoy it. No one's trying to watch us."
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "No one even lives around here in the first place."
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "The hot water here has salt in it,<CR>so you'll float to the top if you<CR>stretch out your arms and legs."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "Let's see... Oh, you're right!<CR>This is so cool and marvelous..."
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x1,
            "msg_string": "It's springing out from the salt lake, so it's good for treating frostbite and back pain."
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Plus, it makes it harder to catch a chill after bathing."
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x1,
            "msg_string": "If it wasn't so hard to get here,<CR>I'd tell everyone about it."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "I see. So it has all sorts of beneficial effects... Maybe it's something in the salt..."
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "unknown2": 0x1,
            "msg_string": "It's not the same as your medicine,<CR>but the power of salt is amazing!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "unknown2": 0x1,
            "msg_string": "The power of salt... Oh, that's it!"
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "unknown2": 0x1,
            "msg_string": "Huh? Is something wrong?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "unknown2": 0x1,
            "msg_string": "If people used salt for more than just cooking, like this, it'd sell much better."
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Hm? Used like this...?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "Yup. Tanya, I just thought of a great idea!"
        },
        {
            "type": 0x4,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "unknown2": 0x1,
            "msg_string": "Uh, congratulations?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "unknown2": 0x1,
            "msg_string": "Hehehe, I better go tell Ernie right away!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "unknown2": 0x1,
            "msg_string": "...But before that, I need to thoroughly enjoy this. Haaah, it feels so good..."
        }
    ]
}