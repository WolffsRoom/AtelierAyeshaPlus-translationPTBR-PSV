{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC14_NAN_420.ebm",
    "nb_messages": 0x1c,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Whew, maybe I should take a break...<CR>I'm so tired."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I bet Nanaca is on a journey with her cows today."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x2,
            "msg_string": "Hmhm, I've met Nanaca in so many different places, like the Marshland and Salt Desert..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x3,
            "msg_string": "Now that I think about it, Nanaca travels to a lot of amazing places."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x4,
            "msg_string": "I guess I'm not that different..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "But I'm sure she wouldn't come to a place like this..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Hey, you guys, this way. It's just a bit farther to the delicious grass."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "There she is!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Oh, Ayesha. This is an unexpected meeting."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Nanaca, how did you come all the way out here?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I'm surprised, too... I thought I was the only person who knew about this place."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "How did you get here, Ayesha?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Oh, I came in a balloon. Did you come by balloon as well?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Nope. My cows are afraid of flying, so I can't..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "But there's a better way."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "A better way...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "But that's a cowgirl secret!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x11,
            "msg_string": "Urgh, I really wanna know..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Ayesha, want to change jobs and become a cowgirl? I think you've got the talent for it."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Pana always looks so happy. I'd like to go on a walk with you and our cows."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Become a cowgirl with Nanaca? Wow, that does sound fun!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "It would be fun! We'd follow the seasons and travel with our cows, listening to the call of the soil."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "When you see the cows sleeping at night, you can feel just how peaceful this world is."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Uhh...that's very tempting, but I think I still prefer to be an apothecary."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4a,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "Hmhmhm, that's unfortunate. But I do think that you're a great apothecary."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Oh, I need to get going soon. See you later, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "msg_string": "(She's so mysterious. You need a balloon to get here...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "(I wonder how Nanaca was able to come here with all of her cows...)"
        }
    ]
}