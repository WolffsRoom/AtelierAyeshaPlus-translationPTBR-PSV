{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC14_NAN_430.ebm",
    "nb_messages": 0x20,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, Juris! I finally found you."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I've been gone for a while.<CR>Are you doing well, Nanaca?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "I wanna ask you the same question.<CR>How have you been, Juris?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb6,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "We've all been worried, since you haven't come back to the village."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Yeah, lots of stuff's been going on.<CR>I was pursuing a big one."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Tell everyone not to worry about me."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "That's not enough. Stop by for once. Everyone is really worried."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x11a,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "And I am, too... I've been lonely."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "What? I thought you said you're okay by yourself."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x11e,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "This and that are different.<CR>I haven't seen you in forever."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Hmm, is that so...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x120,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Yes it is. Goodness, this is why everyone says huntsmen are no good."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ayesha, I'm sorry. You saw a disgraceful moment."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Don't worry. Nio and I are like that, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x35,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "Having your younger sibling depend on you is a special privilege of being an older sibling."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "I've never thought of that as a special privilege..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "Ayesha, you shouldn't be laughing."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb6,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "This is how my brother is, so you'll have a lot of problems if you stay with him..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Huh?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Hey, Nanaca. We don't have that kind of relationship."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Ayesha will have more problems dealing with that kind of joke, so stop it."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Huh? Really? Okay..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "I thought that Ayesha was the only person who could possibly be with my brother..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "That's just what I always thought. Sorry, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "But, I wasn't joking."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x19,
            "msg_string": "I know it's obvious that you'll have problems if you stay with Juris, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x1a,
            "msg_string": "Even still, I don't think he's a bad<CR>guy... What do you think?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x1b,
            "msg_string": "Huh!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4a,
            "expr_id": 0x2,
            "msg_id": 0x1c,
            "msg_string": "Hmhmhm! Although, as his sister, I might just be seeing him in a favorable light."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Nanaca!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Yes! I'm sorry!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "msg_string": "(Siblings are nice after all...)"
        }
    ]
}