{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC14_NAN_080.ebm",
    "nb_messages": 0x17,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, Ayesha!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Guess what! Poros came back!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Poro, who disappeared? Huh? What do you mean by Poros?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Poro got a double. See, these two calves are the same."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Okay, say thank you to Ayesha for looking after you."
        },
        {
            "type": 0x1,
            "voice_id": 0x206,
            "name_id": 0x20,
            "extra_id": 0x22f,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "Oink moo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x206,
            "name_id": 0x20,
            "extra_id": 0x22f,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "Oink moo!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "Whoa, you're right! That's amazing!<CR>I'm so happy for you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Although I wasn't much help..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "No, no, I think you changed the course of the stars when you went out to look for Poro."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "I've heard that lost cattle become the messengers of the god of hunting, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "There are also times when they return, like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Oh, I see. I'm so glad for both of them."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "But, I have a bit of a problem. I can't tell them apart if they're like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "They're identical. The more I look at them, the less differences I see..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x186,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "So I'm thinking about renaming them."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x186,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I'm thinking of calling one Poro and the other Jiro, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Both of them start running away whenever I call out \"Poro.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Oh yeah, Poro runs away when her name is called..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Yup. I'm really happy that they're Poros for sure..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "But it's double the work now to run after them. Hey you guys, come baaack."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "(What if two Nios come back...?)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "(Hmm. I guess that'll be okay, too...)"
        }
    ]
}