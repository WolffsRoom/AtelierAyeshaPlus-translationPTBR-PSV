        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x133,
            "msg_string": "Hehehe, thank you for saying that my cows are cute."
