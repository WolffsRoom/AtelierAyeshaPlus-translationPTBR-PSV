            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x13c,
            "msg_string": "Oops, I need to get going now. If I don't hurry, it'll be nightfall..."
