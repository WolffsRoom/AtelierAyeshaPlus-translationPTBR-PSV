        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4b,
            "expr_id": 0x2,
            "msg_id": 0x138,
            "msg_string": "She's so strong, carrying all that luggage. Very impressive..."
