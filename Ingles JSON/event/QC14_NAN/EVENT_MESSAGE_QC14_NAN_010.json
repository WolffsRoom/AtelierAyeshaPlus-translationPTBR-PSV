            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x135,
            "msg_string": "Cows...? Hmm, I've never thought about it, but I guess I do..."
