        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x146,
            "msg_string": "If you'll excuse me...<CR>I hope we meet again... Umm..."
