            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4a,
            "expr_id": 0x2,
            "msg_id": 0x137,
            "msg_string": "So, her name is Pana? Hmhm, that's a perfect name for her."
