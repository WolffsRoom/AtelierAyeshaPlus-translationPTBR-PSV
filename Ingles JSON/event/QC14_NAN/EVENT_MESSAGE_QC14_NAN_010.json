            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x136,
            "msg_string": "Pana always helps me out, too.<CR>She's family to me."
