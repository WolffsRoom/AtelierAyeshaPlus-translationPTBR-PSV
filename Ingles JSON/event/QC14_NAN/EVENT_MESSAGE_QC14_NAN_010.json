            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x147,
            "msg_string": "Sorry, I haven't asked for your name yet..."
