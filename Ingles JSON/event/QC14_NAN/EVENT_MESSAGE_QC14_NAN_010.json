            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x139,
            "msg_string": "Haha... She's strong and kind, but she's also a glutton."
