        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3548,
            "msg_string": "Oh, we have to get going, too.<CR>C'mon, Pana, we're leaving."
