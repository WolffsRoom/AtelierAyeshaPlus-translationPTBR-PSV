        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0x13a,
            "msg_string": "A cow that eats a lot is a good cow. Please keep taking good care of her."
