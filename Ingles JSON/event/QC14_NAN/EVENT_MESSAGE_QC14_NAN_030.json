{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC14_NAN_030.ebm",
    "nb_messages": 0x23,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Heeey, Ayeshaaa! And Paaanaaa!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Nanaca! Yaaay, we got to meet again!"
        },
        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x216,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "msg_string": "Oink moo!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "Hmhmhm, hello!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x4,
            "msg_string": "I was just thinking that it'd be great if Ayesha was here..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "And then I actually saw you."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "A lot of my friends come here, so I<CR>thought...maybe you would, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I see... I didn't know a lot of people come here."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Oh, no, hardly any people come here. The friends that come here are the ones that aren't human."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Like wild bunnies and deer.<CR>This area has lots of water."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I stop by here a lot to let everyone take a drink when I'm headed to Hornheim."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ohh, I see. Pana, do you wanna drink some water here, too?"
        },
        {
            "type": 0x1,
            "voice_id": 0x205,
            "name_id": 0x1f,
            "extra_id": 0x216,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "msg_string": "Oink!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Hahaha, you should go drink with my cows."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "The water around here is very clean and delicious."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x185,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "But there's some bad water, too, so you should be careful."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x10,
            "msg_string": "Huh? Bad water...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x186,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yup. Bad things seep out from the dirt and get mixed into the water."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x187,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Your stomach will feel bad if you drink it, so be careful."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I didn't know there was such a thing as bad water. I'll be careful."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "My calf mistakenly drank it last time, and it was pretty bad."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I remember my grandma telling me that this area is a difficult land..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Long ago, like hundreds of thousands of sun rotations ago, a poisonous monster lived here."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Huh, a poisonous monster?<CR>Th-That's scary..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Don't worry, it's a story from long ago. It doesn't exist anymore."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "But that monster's poison is still in the land, and..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "We need to watch out for that."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "I see. Nanaca, you know about a lot of things."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Hehehe, I learned it all from my grandma. And then..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Hey Nanaca, we're leaving soon.<CR>We should get past this area<CR>before the sun sets."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Okay. Sorry, Ayesha, we need to get going soon."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "I'll see you later."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19a,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Oh, okay. See you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "msg_string": "(I wanted to talk to her a little longer, but I guess it can't be helped.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "msg_string": "(This area is dangerous after sunset.)"
        }
    ]
}