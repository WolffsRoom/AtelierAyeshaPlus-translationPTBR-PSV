{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM02_ST1_040.ebm",
    "nb_messages": 0x24,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1fb,
            "msg_string": "Wow! What a splendid room...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x18,
            "expr_id": 0x0,
            "msg_id": 0x1fc,
            "msg_string": "Oh, it's not that big of a deal. I have plenty more rooms just like this one."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a,
            "expr_id": 0x0,
            "msg_id": 0x1fd,
            "msg_string": "Think of this as your own house,<CR>and feel free to use it."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1fe,
            "msg_string": "Harry, your generosity and the looseness of your purse-stings are exceptional, as always."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x56,
            "expr_id": 0x2,
            "msg_id": 0x1ff,
            "msg_string": "Oh, getting praised like that is making me blush. Oh, goodness gracious."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x58,
            "expr_id": 0x0,
            "msg_id": 0x200,
            "msg_string": "You said your name was Ayesha? I'm sure coming here from the countryside couldn't have been that pleasant."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x21,
            "expr_id": 0x0,
            "msg_id": 0x201,
            "msg_string": "I believe Marietta told me that you sell medicine..."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1f,
            "expr_id": 0x0,
            "msg_id": 0x202,
            "msg_string": "In that case, you're somewhat connected with my store. There's no need to hold back."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x203,
            "msg_string": "Okay, I'll use this room.<CR>Thank you so much!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a,
            "expr_id": 0x0,
            "msg_id": 0x204,
            "msg_string": "No, no, I'm happy to help a young apothecary."
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x205,
            "msg_string": "If you have any worries, feel free to come talk to me. Until we meet again."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd4,
            "expr_id": 0x4,
            "msg_id": 0x206,
            "msg_string": "Goodness, Harry sure can't be helped."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd5,
            "expr_id": 0x4,
            "msg_id": 0x207,
            "msg_string": "He said he was gonna try to remember, but I'm sure he never even knew."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0x208,
            "msg_string": "Whatever the case may be, its hard to hate him, so don't feel bad, okay?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x209,
            "msg_string": "Of course not. I really hope it's okay that he lent me this room..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x20a,
            "msg_string": "It's fine. Harry was a total miss, but you were able to borrow this nice room, so I guess we broke even."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x20b,
            "msg_string": "People come here from all the surrounding areas, so it's a perfect place to search for things."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x20c,
            "msg_string": "You're right. Although, I'm still not sure where to start..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x20d,
            "msg_string": "Glowing flowers...and clues about Nio... I need to find them, no matter what!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x20e,
            "msg_string": "Regina, I'm gonna overcome any challenge that comes my way."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0x20f,
            "msg_string": "I'm sure I'll find clues about Nio somewhere!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x210,
            "msg_string": "Yup, you can do this, Ayesha!<CR>I'll do my best to help you."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x211,
            "msg_string": "I just intended to walk around after this job was done anyway."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x212,
            "msg_string": "Feel free to depend on me whenever you want."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x213,
            "msg_string": "Wow, having you with me will be a great help!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x34ee,
            "msg_string": "Regina, what is that?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x34ef,
            "msg_string": "A map! For the area around here. I saw it in the room, so I brought it with me."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x34f0,
            "msg_string": "We need to know what's around before we can start searching."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x34f1,
            "msg_string": "Oh, a map... I don't know anything about the area outside my workshop."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x34f2,
            "msg_string": "I guess I have to start by looking around."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x34f3,
            "msg_string": "That's right, I think this'll really help us out. Also, asking the people around town might be good, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x34f4,
            "msg_string": "Okay! I'll do my best!"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can now use Harry's Room."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can now use shortcuts.<CR>Press <IM19> to choose where to go and you will be teleported there."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can use the shortcut feature to get back to the world map."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "If traveling between areas doesn't consume time, you can use shortcuts."
        }
    ]
}