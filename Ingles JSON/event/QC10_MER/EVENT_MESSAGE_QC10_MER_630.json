            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "(That's...gotta be the stars.)"
