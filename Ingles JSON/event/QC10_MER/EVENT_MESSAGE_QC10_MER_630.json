        {
            "type": 0x1,
            "voice_id": 0x217,
            "name_id": 0x2e,
            "extra_id": 0x224,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "Sparkles, different ones."
