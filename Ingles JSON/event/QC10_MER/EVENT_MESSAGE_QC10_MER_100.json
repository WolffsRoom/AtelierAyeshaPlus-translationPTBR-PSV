    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x214,
            "name_id": 0x2b,
            "extra_id": 0x220,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "Sparkles delivered. A lot delivered."
        },
        {
            "type": 0x1,
            "voice_id": 0x214,
            "name_id": 0x2b,
            "extra_id": 0x220,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "Sparkles shine pretty,<CR>eat sweet, thanks."
        },
        {
            "type": 0x1,
            "voice_id": 0x214,
            "name_id": 0x2b,
            "extra_id": 0x220,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "msg_string": "Very yummy. Thank you."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "No, no, it was my pleasure.<CR>Please come back anytime."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, hey, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Oh, Marietta. Are you on vacation? You've come a pretty far ways."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a7,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Nope. A merchant should always listen to the opinions of their customers in person."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "So I figured I would do that while I was here making a delivery."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x27,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "It's not bad to get out of Vierzeberg every once in a while. Well, I'm glad I came!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yup. This is a wonderful town. Plus...the Homunculi are so cute!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a8,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yup, yup. I wanna come here again,<CR>but not for business!"
        },
        {
            "type": 0x1,
            "voice_id": 0x214,
            "name_id": 0x2b,
            "extra_id": 0x220,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "msg_string": "Come again. Ayesha is a friend. "
        },
        {
            "type": 0x1,
            "voice_id": 0x214,
            "name_id": 0x2b,
            "extra_id": 0x220,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "msg_string": "Marietta is a friend, too.<CR>We like you a lot."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2f,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Kyaaah! You're so cute! I love you, too!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "This is such a wonderful place, but the owner stills says he doesn't want to come."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Haha, Mr. Harry is a busy person."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "That's not it. He was bit on the butt by a dog when he was young..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x161,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "And ever since then, he's been scared of dogs, or any creatures that look like dogs."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x35,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Hahaha, is that why? But, do you think they look that much alike?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I don't think so. Dogs don't walk on two legs."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Either way, he's such a wimpy guy."
        }
    ]
}