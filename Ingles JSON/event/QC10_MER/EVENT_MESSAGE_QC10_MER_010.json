{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC10_MER_010.ebm",
    "nb_messages": 0x19,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0x12,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x3594,
            "msg_string": "Welcome!<CR>...Oh, hey, Regina."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1bb,
            "msg_string": "Hey, is Harry here? I wanted to see him."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x1bc,
            "msg_string": "Mr. Owner? Yup, he's here. He's trying to look busy, but he isn't actually doing anything."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6d,
            "expr_id": 0x2,
            "msg_id": 0x1bd,
            "msg_string": "So, you're here to see him?"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1be,
            "msg_string": "Well actually, she's the one who wants to see him."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1bf,
            "msg_string": "I'm Ayesha Altugle, an apothecary.<CR>It's nice to meet you."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x1c0,
            "msg_string": "Ayesha...? I feel like I've heard that name somewhere..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6d,
            "expr_id": 0x2,
            "msg_id": 0x1c1,
            "msg_string": "Could you be the person who made this biiitter medicine?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc7,
            "expr_id": 0x4,
            "msg_id": 0x1c2,
            "msg_string": "Oh, I did make that medicine.<CR>I'm sorry it's so bitter..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x1c3,
            "msg_string": "No, don't apologize. Your medicine is really popular."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6d,
            "expr_id": 0x2,
            "msg_id": 0x1c4,
            "msg_string": "Some people even travel pretty far just to buy your medicine from us."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x1c5,
            "msg_string": "I was wondering what kind of person made this medicine, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x1c6,
            "msg_string": "Who knew she would be so young and cute...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xca,
            "expr_id": 0x0,
            "msg_id": 0x1c7,
            "msg_string": "H-Huh? C-C-Cute...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x1c8,
            "msg_string": "Aww, are you embarrassed?<CR>Hehehe, how cute."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x1c9,
            "msg_string": "Hyah, I'm not like that... Umm, I don't think I'm all that cute...."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x1ca,
            "msg_string": "Hahaha, you are cute, to the point that it just makes me want to tease you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0x1cb,
            "msg_string": "Please, stop saying I'm cute..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1cc,
            "msg_string": "Ayesha...you're playing right into Marietta's hands..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x1cd,
            "msg_string": "Hahaha, I guess I should formally introduce myself, since such a cute apothecary came all this way..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6d,
            "expr_id": 0x2,
            "msg_id": 0x1ce,
            "msg_string": "I'm Marietta, the shopkeeper of this store."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x1cf,
            "msg_string": "If you need anything, or have anything you want to talk about, feel free to ask anytime."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1d0,
            "msg_string": "Oh, yes. Pleased to meet you..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x1d1,
            "msg_string": "So Marietta, we're here to see Harry. He's here, right?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x1d2,
            "msg_string": "Oh, that's right. Hold on, I'll go get him."
        }
    ]
}