    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "You have lots of things in your shop, Marietta."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I guess so. I can get anything that I like or want to sell. The same goes for the owner..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Mr. Harry can, too? He's so passionate about his work..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf5,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "In a useless manner. He always brings things that normal people wouldn't buy."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "And since nooo one buys them,<CR>they get put in storage."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf6,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Like an old coin from the ruins, or a book written in an ancient language..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "A book written in an ancient<CR>language...? I might be able<CR>to read that book!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "The synthesis books I have at home were like that, and I was able to read the alchemy book that I got before..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xf7,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Ohh, then you're amazing, Ayesha.<CR>You can read ancient languages!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "I think the owner said something about how this book is about Anciemy or something."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Anciemy...? I've never heard of that, but now I'm interested."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Oh, then I'll look for it and have it ready for you here next time."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Come and buy it if you want."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Alchemy books will now be sold."
