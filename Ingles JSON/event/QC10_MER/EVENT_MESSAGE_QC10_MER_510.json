        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Yup, that's totally fine.<CR>It's nothing super urgent."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "But wouldn't it have been better if you asked that delivery man?"
