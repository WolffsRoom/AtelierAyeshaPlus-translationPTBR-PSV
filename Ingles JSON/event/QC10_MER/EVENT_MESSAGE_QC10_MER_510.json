        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "I'm not sure when I'll be going there, but if that's okay, then I'll do it."
