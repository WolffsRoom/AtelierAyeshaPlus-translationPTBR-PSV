        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Don't worry, you're much more suited for this. You'll know why once you get there."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x16,
