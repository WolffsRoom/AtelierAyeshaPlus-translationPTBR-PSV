        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x162,
            "expr_id": 0x5,
            "msg_id": 0xd,
            "msg_string": "Oh, I see. Umm, what should I do?"
