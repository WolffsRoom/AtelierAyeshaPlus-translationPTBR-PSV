            "voice_id": 0x21d,
            "name_id": 0x37,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "Well, don't worry. I'll take care of it!"
