            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Hyah! He sounds so scary...<CR>I-I'm so sorry."
