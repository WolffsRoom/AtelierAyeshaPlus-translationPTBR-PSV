        {
            "type": 0x4,
            "voice_id": 0x21d,
            "name_id": 0x37,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "Ohh, so you're from Harry's.<CR>Sorry for yelling at you."
