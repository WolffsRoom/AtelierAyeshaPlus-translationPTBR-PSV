            "type": 0x4,
            "voice_id": 0x21d,
            "name_id": 0x37,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "Oh, that. The usual trade route was flooded..."
