            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Um, I'm sorry. Marietta from Harry's Trading House asked me to come here and..."
