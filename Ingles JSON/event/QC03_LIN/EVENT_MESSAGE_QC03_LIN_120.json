{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC03_LIN_120.ebm",
    "nb_messages": 0x2a,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Huh? That person over there is...Linca?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Linca! What are you doing in a place like this?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hm? Oh...I was thinking a bit about the past..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Oh, about the story that you guys didn't finish before?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "(I want to hear more about the story, but...I wonder if it would be rude of me to ask...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Yes... I have decided. I think I should tell you about my past."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Huh...? But...if you don't want to talk about it, I don't want you to force yourself..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Ayesha, you are my friend. I want you to hear it. If you do not want to, I will not..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Well, if you say so. I am your friend."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x19b,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Thank you. Then please listen. I am not sure if I can describe it well, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "In the past, I was...doing things that were not so good."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Eh, not so good...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Yes. Following the orders I was given by the person who raised me, I caused trouble for Marion and others."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Back then, I believed that I was not allowed to disobey these orders."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "One day, there was a big battle and I was captured."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "With no relatives or guardians,<CR>all I could do was wait for my<CR>day of judgment."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "However, for some reason, Marion saved me, even though I was her enemy."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Marion will not tell me why she saved me, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "I now stay by Marion's side to repay my debt to her for saving my life."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "So that's what happened..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Maybe it is because the \"me\" from back then is still somewhere inside my heart, but using my sword to protect people..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Does not feel like it suits me."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Ayesha, you are my friend,<CR>but in reality, I do not<CR>deserve to have friends."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Linca..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Ayesha...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Even so, I'm still your friend."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "I don't know all the details, but Linca, you are a kind and nice person."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "And that's enough for me. Let's continue to be friends like we are now, okay?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Ayesha...if you are okay with that,<CR>then I would like that, as well..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "But, why are you telling me this all of a sudden?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x1e,
            "msg_string": "...I have a hunch, and it is not good."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x1f,
            "msg_string": "This land, compared to the center,<CR>is very peaceful, so I have forgotten<CR>the past, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x20,
            "msg_string": "Something might happen in the future that is related to my past."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Because of that, I started to worry that you may get caught up in it...so I wanted to tell you my story."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Your past...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Yes. If you see Linca...please be careful."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "...Huh? If I see...Linca?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Ayesha, you are so kind, I am worried about you. But, you cannot let your guard down around me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x26,
            "msg_string": "Wh-What do you mean?<CR>I don't understand..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Just beware of Linca.<CR>Please remember that."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "Now then..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0xffffffff,
            "msg_id": 0x29,
            "msg_string": "(Beware of Linca... I-I don't get it.<CR>I wonder what that means...)"
        }
    ]
}