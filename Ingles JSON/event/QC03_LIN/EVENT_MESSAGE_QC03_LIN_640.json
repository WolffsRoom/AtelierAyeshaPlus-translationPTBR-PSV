{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC03_LIN_640.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Something suited for Linca...<CR>I wonder what it could be..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I have never done or even thought of doing anything other than with my sword."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Maybe I only have my sword after all..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "That's fine, too, if it's not your goal but your means, as Ayesha said."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, that reminds me, what ever happened with that plan I heard the other day about defeating a dragon?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Yes. Ayesha said she would take me with her, so I have been waiting for her ever since."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Hmm, I see. Going up against a dragon... It sounds like even the preparations alone would be troublesome."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "(Slaying the dragon...?<CR>Ohh, I totally forgot!)"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Oh, Ayesha. Did you come here to play?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Could it be that you are finally prepared to slay the dragon?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Oh, no. A lot of things still need to be arranged..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I see. Well, I'm sure slaying a dragon is a pretty big task, so do you best."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I will be waiting for you to ask me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Y-Yes. I'll do my best. Oh, I suddenly remember I have to do something, so I'll be going now..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "(Wh-Wh-Wh-What should I do!? I can't just tell her that I forgot about her!)"
        }
    ]
}