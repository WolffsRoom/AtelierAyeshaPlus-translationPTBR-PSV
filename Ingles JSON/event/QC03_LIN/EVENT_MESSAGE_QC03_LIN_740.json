{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC03_LIN_740.ebm",
    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "...is what happened."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "So she came, after all. But even so, why did she have to go to Ayesha again...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "I'm sorry about this. I'm really glad you didn't get hurt."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "She was really scary, but she wasn't violent."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "However, we cannot put you in any more danger."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1e2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I know. She asked us kindly, so why don't we accept her invitation?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xe9,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "If she'll be satisfied with that..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Umm, what should I do...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xed,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "If having you accompany us was one of her conditions, I feel like we have no choice..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "We do not want to involve you any further, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "No, no, I came this far,<CR>so I'll go with you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "Plus, I'm curious about the other Linca."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "If you say so, that'll help us a lot. We'll take you up on your offer."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Just don't let your guard down. It's dangerous, so try to stay close to Linca at all times."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "U-Understood!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "(It turned into a big thing now.<CR>But, I can't just pretend not to<CR>know anymore.)"
        }
    ]
}