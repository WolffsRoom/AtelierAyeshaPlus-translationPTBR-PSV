{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC03_LIN_100.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Linca, thank you very much."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "*sigh* It was a not a very challenging battle. At this rate, my skills will begin to deteriorate."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Linca, you said that you didn't like fighting before, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "When you're fighting, you look very lively."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Now that you mention it, you might be right. Ayesha, your observations are very keen."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "It just occurred to me that I might like to move my body."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Marion's job is to think, and my job is to move my body."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I think we make a good combination.<CR>What do you think, Ayesha?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x8,
            "msg_string": "Hmm, well..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Hrh...do you think we make a bad combination?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "No, no, I was thinking that it's great. It just suits you two so much."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I see! Then that must mean that we should stay together forever."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Marion is scary when she gets mad,<CR>and is annoying when she tells me to<CR>tidy myself up or comb my hair..."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "But I still cannot imagine separating from her."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "If we make a good combination, then it is only natural for us to stay together."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Hehehe, Linca, you really do like Marion, don't you?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Ayesha, that is a little different. If I have to respond, I do not like her."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Huh? Really? But you both get along so well!"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "As I said earlier, she is scary when she gets mad, and is annoying when she tells me to tidy myself up or comb my hair."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "In any case, I am not good at dealing with her. Why is she always like that?"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x166,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "She should be a bit nicer..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Haha...I'm sure that's a sign of her kindness."
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x168,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "It is? That is hard to believe..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "(I'm sure her strictness is her true kindness...)"
        }
    ]
}