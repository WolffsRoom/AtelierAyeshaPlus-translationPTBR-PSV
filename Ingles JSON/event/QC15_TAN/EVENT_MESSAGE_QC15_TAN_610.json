{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC15_TAN_610.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Ayesha, there's a letter for you.<CR>Hmhm, guess who it's from."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hmm, I wonder... Oh, it's from Tanya!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1aa,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Let's see... Oh, she wrote about you too, so I'll read it out loud."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "About me? Ooh, I wonder what she said..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "\"Hello Ayesha, it's Tanya. I finally have enough money for the trip.\""
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "\"The next time I'm not too busy with the family business, I'm planning to go to Vierzeberg.\""
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "\"If you can, please show me around the city! I'd love to see the bazaar, as well!\""
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "\"I also want to see Marietta so I can thank her for the gift.\""
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "\"I'm looking forward to seeing you<CR>in the city. That's all for now.<CR>From, Tanya.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1ac,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "She has enough money now? Good job, Tanya!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ooh, so Tanya's coming here?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I'm sure she's really excited. She was really looking forward to coming to town."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xc,
            "msg_string": "Hmm, but I wonder when she's gonna come... And where we're gonna meet..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0xd,
            "msg_string": "Uhh, she didn't write any of that. Maybe she couldn't wrap her head around it..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "In this town, even if you're both here, it'll be hard to just run into each other."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "And I'm sure she doesn't know where my shop is, either..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x10,
            "msg_string": "I guess the best we can do is keep a sharp eye out for her..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Anyway, so, Tanya's coming to town..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "In that case, I need to get it ready for her..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Huh? What are you talking about?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Hmhmhm, it's gonna be a surprise for when Tanya gets here!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x79,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "All right, I can't just stand around like this. I need to go get ready!"
        }
    ]
}