{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC15_TAN_630.ebm",
    "nb_messages": 0x2f,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Wow, what is this!?<CR>It's really sparkly and pretty!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "You don't know about spirit stones? You're not too informed, are you?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x166,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Everyone knows that this is the best stone if you want to pray for the sound health and well-being of your family."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x45,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "I see. M-Maybe I should buy it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, you're gonna buy it?<CR>Then I'll give you a discount!"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Oh, but I can't spend my money impulsively..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Boo! Don't give me false hope. I thought you were gonna be my first sale..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "(That's...Tanya!)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Tanya! Hello!"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Oh...Ayesha! Thank goodness I got to see you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I was worried. I got your letter, but I was wondering if you were gonna be able to get here safely..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "I'm sorry. I never dreamed there'd be this many people."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd3,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "I thought that maybe it'd just work out when I got here, but that wasn't the case."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd6,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I never knew so many people could live in one place..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I was surprised when I first came here, too. I thought that maybe there'd be a hundred people..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "But there were way more than that.<CR>Did you not get lost?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "I did. I was thinking of asking someone about where your house was, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "I didn't know who I was allowed to ask."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "And I was looking for the store that sells salt, but I couldn't find that, either."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x44,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Eventually, I found a shop that sells weird things."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7e,
            "expr_id": 0x3,
            "msg_id": 0x14,
            "msg_string": "Hey, I hope you're not talking about my shop!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x82,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "I mean, don't have your emotional reunion in front of my shop! It's getting in the way of my business!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x83,
            "expr_id": 0x3,
            "msg_id": 0x16,
            "msg_string": "If you both aren't here to shop,<CR>then go hooome!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x14,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "I-I'm sorry!"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x129,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "I-I'm sorry!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "See? The bazaar is over there."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "And my house is that way.<CR>And on the other side..."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x12d,
            "expr_id": 0x4,
            "msg_id": 0x1b,
            "msg_string": "Wow, wow, wooow! Amazing!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x1c,
            "msg_string": "*ahem* Now you see how big this town is, right?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "msg_string": "(Why am I bragging?)"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a0,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Ayesha, what are you doing in a place like this?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x1f,
            "msg_string": "Oh, you're... Are you Tanya?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Oh, Marietta, I was planning on visiting you after this."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "This is Tanya, and this is Marietta!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "She's the shopkeeper of the store that sells your salt."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Hello, I'm Tanya Volta. Thank you for buying our salt!"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "And thank you for the handkerchief!<CR>I've been wanting to thank you!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Oh, no problem. Thank you for your business."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x26,
            "msg_string": "Welcome to Vierzeberg from so far away! It must've been a tough trip."
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Yes, but everything in this city is amazing! Even my fatigue went away!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x28,
            "msg_string": "Everyone says that the first time they come here. Well, I guess I can't blame them..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x29,
            "msg_string": "That's right, I almost forgot!<CR>I prepared something for you!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6d,
            "expr_id": 0x2,
            "msg_id": 0x2a,
            "msg_string": "Tanya, can you come to my store right now?"
        },
        {
            "type": 0x1,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2b,
            "msg_string": "Now? Okay."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x2c,
            "msg_string": "Oh, Ayesha, you should come, too.<CR>I wouldn't want you to miss this."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2d,
            "msg_string": "Okay... What don't you want me to miss?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x2e,
            "msg_string": "Hmhmhm, that's a secret!<CR>I'm really getting pumped up now!"
        }
    ]
}