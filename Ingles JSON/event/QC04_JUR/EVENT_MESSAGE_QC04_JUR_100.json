{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_100.ebm",
    "nb_messages": 0x20,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "*yawn* Good morning. Juris, thank you for staying up all night on watch."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Sure. You should go wash your face.<CR>I'll take my nap soon...oh, but<CR>before that..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ayesha, I know you probably won't like it, but there is something I need to ask you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Wh-What is it? And why are you being so formal...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "It's about your sleep talking."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Wha‐!? I asked you before not to listen to it!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x161,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Don't be ridiculous. I can't cover my ears all night while I'm on watch."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "That's...true, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "How can I say this? You continuously babble on throughout the night."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "You're more talkative when you're asleep than when you're awake."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "R-Really? I never knew...<CR>This is too embarrassing..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I remember a few things that stuck out..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "What exactly is \"Kitty Bread\"?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Eh? I guess I was talking about the kitty bread at the bakery..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Is that so? It sounded like you were saying things like..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "How you want to eat a cat, or bake a cat inside bread and eat it..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Hyah! I-I-I-I said no such thing!<CR>...I think!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x161,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Different people have different tastes in food, but I'm not so sure about eating cats..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "I-I'm telling you, it's not about that. It's about kitty bread!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "It's bread that's in the shape of a kitty! It's not like eating a cat."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "It has a sweeeet jam filling inside."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Hmm, sweet jam...? That's...interesting."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Huh? Juris, do you...actually like sweet things?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "It's not to the point that I \"like\" them, I just have a taste for them."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Is that so? Then, should we go eat them together next time?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x19,
            "msg_string": "I'll bring some delicious tea, too!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x1a,
            "msg_string": "Huh? No, I don't think that's..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x35,
            "expr_id": 0x2,
            "msg_id": 0x1b,
            "msg_string": "Oh, you can't? I feel so happy when I have tea and sweet bread."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "No... Having sweet bread with you while drinking tea is..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xda,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "You should do that kind of thing with<CR>Nanaca."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Are you sure? Hmm, that's a bummer."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "msg_string": "(Either way, it's embarrassing that I talk a lot in my sleep...)"
        }
    ]
}