{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_630.ebm",
    "nb_messages": 0x17,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Juris, is this enough bedding for you?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Yeah. I can sleep anywhere, as long as I have a blanket."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "You can't do that. It gets cold at night, so you might get sick."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "You should take this spare blanket, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, it seems like they're in the middle of something... Are you busy?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Well, since the calves are big now,<CR>and I'm okay on my own..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I was thinking about heading back out to hunt."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I always pack for my brother. If I didn't, he would only take the bare essentials."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Sorry, Ayesha, but I'll talk to you later."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "...That's right. Ayesha, there's something I need to tell you..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I heard you helped Nanaca before with her calf."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I don't think we've ever paid you back for that."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "What? There's no need to pay me. I can't accept payment for something as little as that."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Besides, Nanaca is my friend."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I figured you might say that,<CR>but I can't let that stand."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "It's customary in my family to give thanks, and not just with words, but also with actions."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "But, I really can't accept money.<CR>I'd feel really bad afterward."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Hmm, I see... Then how about this?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "I've been hunting for a while now.<CR>I consider myself to be trained in<CR>the skills needed to protect myself."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "If you need my help, just come talk to me. I'll lend you my power, as a substitute for the payment."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x14,
            "msg_string": "Oh, really? That'll really help me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "(Having Juris come with me would be really reassuring. Maybe I should ask him sometime.)"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Juris can now join your party."
        }
    ]
}