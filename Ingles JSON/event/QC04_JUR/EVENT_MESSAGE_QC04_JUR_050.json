{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_050.ebm",
    "nb_messages": 0x22,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Thank you for the food! Juris, I didn't know you were so good at cooking."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I was never really big into meat,<CR>but I can't get enough of yours."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "You'd have a booming business if you opened up a shop!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "There are no huntsmen who don't know how to cook their own prey."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I don't think I'm good enough to the point where I could open my own shop, but I can cook to a certain extent."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Well, the night is advancing.<CR>Ayesha, you should go to sleep first."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I'll look after the fire for a while."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Huh? Are you sure?<CR>Aren't you tired, too...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "You seem to be more tired than I am.<CR>You were nodding off earlier while<CR>you were eating."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "That's not true. I'm still full of...<CR>*yawn* ...Aww."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "See? You seem to be reaching your limit. You don't have to push yourself."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I'll take a nap in the morning. You can just wake up a little early for me."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "It's what I usually do when I hunt alone, so you don't need to hold back."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "O-Okay, if you insist..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "*yawn* It's morning. How refreshing..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Oh, Juris, good morning."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x19d,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Morning. Looks like you slept well."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Well Juris, you should take your nap..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Yeah, I'll do that."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "By the way, Ayesha, you sure do talk<CR>a lot in your sleep. Thanks to that,<CR>I didn't get bored."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "What!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Like, \"This synthesis failed,\" or \"I'm gonna get eaten by a monster!\""
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "You seemed to be having a lot of trouble in your dream."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "U-Umm, Juris...were you watching me...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x161,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "It's not that I was watching, but I did see you in my peripheral vision."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x19,
            "msg_string": "What!? You can't observe a girl when she's sleeping!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "But I wasn't observing..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Other than that, I heard you say the words \"more please\" and \"delicious\" quite often. And‐"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7a,
            "expr_id": 0x3,
            "msg_id": 0x1c,
            "msg_string": "Ahhh, I get it! Please don't say anything more!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "I don't think you need to be that embarrassed. I don't mind."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7c,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Arrrgggh, but I mind..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "msg_string": "(Ahh, this is embarrassing.<CR>I never knew I talked in my sleep.)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "msg_string": "(I-I have no choice but to watch Juris while he's taking his nap and...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "msg_string": "(But that kinda seems pointless.<CR>Urgh, my face is burning up!)"
        }
    ]
}