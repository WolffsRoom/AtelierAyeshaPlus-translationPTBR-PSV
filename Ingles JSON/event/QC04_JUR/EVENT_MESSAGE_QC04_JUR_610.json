{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_610.ebm",
    "nb_messages": 0x1c,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "It seems like you've helped Nanaca. Thank you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hyah! Mr. Brother!<CR>How long have you been here?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xb0,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Juris, your bad habits are coming out again. You're hiding your presence too much!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Hrm, I didn't mean to scare you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "No, no, I'm sorry I got scared."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Sorry. I just unconsciously hide my presence..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "In any case, this is a nice opportunity to thank you."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Because of Nanaca's job, she can't help but estrange herself from people."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x19d,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "I'd appreciate it if you could keep being friends with my younger sister from now on, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Hehe, of course. I'm happy that I made more friends."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "If you see her again somewhere,<CR>please say hello to her. Bye."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x141,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Whoa, I've never seen my brother talk to someone for that long before."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Huh? That was long!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x143,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "He only says the minimum amount that's necessary to people who aren't related to us..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I see. Could it be that your brother...doesn't like other people?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "I don't think so. I think he's just a quiet guy..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "He's often by himself in the forest or up in the mountains, so he doesn't interact with people that often."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Hehe, I guess the same's true for me, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "What kind of job does he have? Since you mentioned forests and mountains, is he like a lumberjack?"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Simply put, he's a huntsman. He's off running after beasts most of the time."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I've heard that animal horns can be used as ingredients for medicine, so..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "You two might already have some kind of connection, Ayesha."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Yeah. Maybe your brother's helped me in some way before..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I wish I could've given him a more proper greeting..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x11a,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "He wanders off as soon as he's done with his business..."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x11c,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "But if you can be friends with my brother, it'd make me happy, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "You're right. I'll greet him properly the next time I see him."
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x1b,
            "msg_string": "Hehehe, yes please."
        }
    ]
}