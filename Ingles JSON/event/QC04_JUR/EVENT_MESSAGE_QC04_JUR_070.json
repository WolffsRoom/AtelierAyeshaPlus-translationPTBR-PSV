{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_070.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, so there you are. It's been a while since I've seen one of you guys."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Huh? Did you find something nice?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yeah, this."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x122,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Hyaaah, that's a bug!<CR>What are you gonna do with it!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Gonna do? Is there any other reason to  pick up a bug than to eat it?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x123,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "I think there are plenty, like ignoring them in the first place, or throwing them away as soon as you pick them up..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Not a lot of people know this, but this bug is delicious. And, it has an invigorating effect."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x123,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "But still, it has lots of legs, and it looks a little plump..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "That's where all the taste comes from."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Among huntsmen, it's also considered to be a lucky bug. Since it has so many legs, they say you can track your prey."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Urgh, you know...I'm not a huntsman, so..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Well, just pretend that you've been tricked or something and give it a try."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "No, I don't want to."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Hmm, I heard from Nanaca that girls like things that are small and squishy..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0xe,
            "msg_string": "I don't think that applies to just anything..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x77,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "Either way, let's just throw it away. Forget about this bug and let's continue our journey."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I guess I have no choice, if you're gonna resist this much..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x49,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "*crunch*"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7a,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "Wh-What was that sound!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Huh? Oh, it's nothing to worry about."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7d,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "(H-He ate it! Juris, totally just ate that bug!)"
        }
    ]
}