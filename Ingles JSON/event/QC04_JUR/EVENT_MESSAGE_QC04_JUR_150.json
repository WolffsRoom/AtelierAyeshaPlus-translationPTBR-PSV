{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_150.ebm",
    "nb_messages": 0x29,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Lalala, lalala...hmhm.<CR>Hehe, is it almost done...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, yes? Come in."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Sorry. I didn't know you were working. Should I come back later?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I'm almost done, so will you wait for me?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I see. Then sure, I'll wait.<CR>There's no need to rush."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Sorry to make you wait, but I'm at a crucial part of finishing this up."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x194,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Don't worry, I'm used to waiting."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I've hidden in the brush for a whole day in order to hunt my prey."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Oh, I've had times when I've spent the whole day stirring to make medicine."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "We have totally different jobs, but I guess they both require patience..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Thank you for waiting. Hehehe, this gave me more trouble than I thought..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "You didn't even make me wait that long."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "So, Juris, why did you come here today?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Oh, I have something I want to give you. I hope you can accept it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a5,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "*gasp* This is..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "It's an amulet that I made. I carved it from the dragon's horn."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I want you to accept it as proof..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Proof...? Oh, you mean like as proof of defeating the dragon?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "No... I can't really explain what it's proof of..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "It's just that, I fought to protect my family, and I've gained something else from that battle."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Something inside of me definitely<CR>changed. It doesn't have a shape.<CR>It's something like faith..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I think I sort of understand what you're trying to say..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "There's no meaning to victory by itself. I know that already, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I'm still trying to find meaning in it. I still have a ways to go..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "I put all of those confusing feelings into the shape of that amulet..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Sorry, I can't really put it into words, but please accept it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Hehehe, I accept it with much gratitude."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15f,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "What's wrong, Juris?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "I carved that amulet with my feelings for you. I must tell you that, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x1e,
            "msg_string": "Huh? Feelings for m-m-me!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x39,
            "expr_id": 0x2,
            "msg_id": 0x1f,
            "msg_string": "Th-That's..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x46,
            "expr_id": 0x2,
            "msg_id": 0x20,
            "msg_string": "I can trust you with all my heart...<CR>That you will have my back...<CR>That you are...my comrade."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "C-Comrade?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x4a,
            "expr_id": 0x2,
            "msg_id": 0x22,
            "msg_string": "If, in the future, you need to battle something..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x4b,
            "expr_id": 0x2,
            "msg_id": 0x23,
            "msg_string": "I want you to call on me without hesitation. As a comrade, I'll come rushing faster than anyone else."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Haha, I really don't think I'll ever be in that kind of situation..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x4d,
            "expr_id": 0x2,
            "msg_id": 0x25,
            "msg_string": "Haha, you're probably right. But aside from that, if you're ever in trouble, you can rely on me."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x47,
            "expr_id": 0x2,
            "msg_id": 0x26,
            "msg_string": "That amulet is proof of our friendship."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "Okay! I'll cherish it..."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You got the Dragon Horn Amulet."
        }
    ]
}