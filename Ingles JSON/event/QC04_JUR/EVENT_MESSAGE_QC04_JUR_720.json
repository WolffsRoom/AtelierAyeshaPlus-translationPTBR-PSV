    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hmm, it's so crowded over there. I wonder why..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Whoa, there's a big wolf...!<CR>What is he doing here...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "He's the leader of the pack of wolves around here."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Oh, Juris, do you know a lot about this wolf?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I got a request, so I captured him. Although, I never thought I'd see him again."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "He's one smart wolf. He gave me a real hard time."
        },
        {
            "type": 0x4,
            "voice_id": 0x41,
            "name_id": 0x52,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "Urrrrrr...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "He...he seems to recognize you, Juris..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xda,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Sorry. I didn't accept this job so they could treat you like this..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Being held like that... I feel bad..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xdb,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "...He caused a lot of trouble.<CR>There's nothing we can do."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xe0,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "But, what could hurt his pride more than this...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Yo, Juris. And Ayesha! If you're in town, come stop by at my tavern."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Oh, hello, Mix Master."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I was planning on stopping by."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa2,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "Really? You've been acting rather cold to me lately..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "It's making me sad, you know..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Stop saying such misleading things."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa6,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "Well, you've piled up some stories on your journey, right? Tell me about them over a drink."
        }
    ]
