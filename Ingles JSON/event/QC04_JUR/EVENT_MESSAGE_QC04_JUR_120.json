{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_JUR_120.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "It will be sunset soon.<CR>We should camp here for the night."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I agree. Then I'll prepare our meal..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "No. We won't be able to keep our strength up with portable rations."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I won't be long, so wait here for a while."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Wow. Then, I'll have some warm soup waiting for you when you get back!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Warm soup...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "What's wrong? Would you prefer cold soup?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "No... I just remembered that my mother and father had conversations like this..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Oh, now that you mention it, this might be more of a husband and wife kind of conversation..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3a,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Was your father a huntsman as well?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yeah. He was the most skilled huntsman in our family. Whenever he went out to hunt, he came home with a big game."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "He was my hero and my goal was to someday catch up to him. However..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "He passed away a few years ago. He went out to hunt one day and never came back."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "I see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Huntsmen make their living by taking the lives of beasts. I don't know if it had anything to do with that, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Not many of us die of old age."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "It's said that life circulates and passes on to the next life."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "But..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Well, this job is always fraught with danger. It's like a superstition."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Juris. Umm, please come back safely."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I don't intend to hunt something dangerous right now, so there's no need to worry."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x19e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Well, I'll be going."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "(A huntsman's wife... I'm sure she'd be really worried until her husband comes home...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "(Wait, what in the world am I thinking about...?)"
        }
    ]
}