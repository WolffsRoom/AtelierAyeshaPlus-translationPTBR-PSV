{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC12_KYL_620.ebm",
    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Yo! I heard Juris finally did it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, so you know already? You sure get your information fast."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Don't underestimate me. As the owner of this tavern, I pride myself on being up to date on everything."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "But I never thought he'd be able to slay that dragon..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Juris didn't come to tell you about it?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Nope. He's shy like that. He doesn't like blabbering about himself."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10c,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Although, I fully understand that he's not trying to come across as being heartless to other people or anything."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10e,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "But, what he accomplished is a big deal. I need to throw him a celebration."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "A celebration...?<CR>Hehehe, that sounds amazing."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17d,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Doesn't it?<CR>So, I have a favor to ask you."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17e,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Can you drag Juris here?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17e,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "The ever-so-shy Juris would never come here if we tell him we're gonna have a celebration for him."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I understand.<CR>Leave it to me."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x182,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Yup. I'm counting on you. I'll get all the preparations ready. Good luck!"
        }
    ]
}