{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC12_KYL_050.ebm",
    "nb_messages": 0x20,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Urgh, I'm so hungry. I actually haven't eaten lunch yet..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "*sniff* *sniff*<CR>...Huh? Something smells delicious..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "I wonder what this is... It's peculiar, but it smells so yummy... *sniff* *sniff* Is it coming from this way?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa7,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "I mean, this does look delicious,<CR>but...isn't the smell way too strong?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "It's one of the most aromatic spices you can get in the east."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hmhm, it makes my nose tingle a bit."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa9,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "No, it's more than a tingle.<CR>It makes my nose all funky."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xaa,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "But a spice from the east... As a cook, my fingers are just itching to try it."
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Yeah, right? I thought you'd be able to put it to good use..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Hello!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Oh, Ayesha.<CR>Are you here for lunch?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Hey, gimme a second. This is gonna be tricky..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Oh, Ernie... *sneeze*<CR>And Mix Master...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xcd,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "You two are...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yup. Kyle is one of my clients."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Ha! What a cute sneeze.<CR>So, are you here to eat lunch?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xce,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Yes. My stomach...!<CR>And I thought...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x41,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Umm...what?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xce,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "So I...!<CR>I...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "She came here tempted by the fragrance of the spice. It does smell good."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xce,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Yes...!<CR>Umm, I...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I see... I guess it was too stimulating for you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xce,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Just...!<CR>I...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Yeah, I think that's probably for the best. We'll talk some other time."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xce,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "In that case...!<CR>But this...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xce,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "So I...!<CR>If you'll excuse...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xce,
            "expr_id": 0x4,
            "msg_id": 0x1a,
            "msg_string": "*sneeze*"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "I didn't think Ayesha would stop by...<CR>I feel bad for her."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa2,
            "expr_id": 0x3,
            "msg_id": 0x1c,
            "msg_string": "So she's weak to spices...?<CR>I feel bad for her too, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x1d,
            "msg_string": "Either way, you're amazing.<CR>How were you able to establish<CR>such a mutual understanding...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5f,
            "expr_id": 0x2,
            "msg_id": 0x1e,
            "msg_string": "Hmhmhm, well I have known her for a long time. Of course I can understand her."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa8,
            "expr_id": 0x3,
            "msg_id": 0x1f,
            "msg_string": "No...I don't think that's the reason.<CR>Ernie...you're pretty amazing."
        }
    ]
}