{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC12_KYL_040.ebm",
    "nb_messages": 0x2c,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa2,
            "expr_id": 0x3,
            "msg_id": 0x0,
            "msg_string": "Man, why do you always have to treat me like that?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I'm just saying the truth.<CR>It's very simple."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa6,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Look, there are times when the truth can hurt people's feelings."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "That's because you've lived a shameful way of life."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Umm, what's the problem? I don't think it's good to fight..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Huh? We're not fighting..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Ha! Ayesha, you don't have too many guy friends, do ya?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa3,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Guys become better friends by telling each other our real opinions like this."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa8,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "So it's basically like baring our souls."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Oh, I see... Oh, are you eating lunch here, too, Juris?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yes. I dine here occasionally."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xaa,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "You're no fun, Juris. You should come eat here all the time."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I prefer to eat my meals in peace."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Also, this was really unexpected. I didn't know you two knew each other."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x14,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Well, it was a forced relationship."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Well, it was a forced relationship."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x141,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Whoa, we totally just said the same thing! This goes beyond friendship, and puts us on the level of lovers."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Hmhmhm, I think it's wonderful that you two get along so well."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x143,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Ayesha...<CR>That's not the problem here..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "What are you talking about?<CR>Anyway, just get me another drink."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10c,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Ugh, you're gonna drink more? You stupid heavy drinker!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x12,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I'm doing a favor for the owner of this tavern. I think you should thank me."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10d,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Tsk. Well...I did get some nice alcohol. I think this one tastes good, ya know!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I'll take whatever I can drink. Although, I don't have high hopes for any alcohol that you chose..."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10f,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "You...! You're so cruel, Juris! I've been studying up on alcohol, ya know!"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x112,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Man, this hurts... Since when have you been the type of guy who says such heartless things...?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Oops, I'm sorry. I totally left a girl unattended."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x2,
            "msg_id": 0x1b,
            "msg_string": "Haha, don't worry. I'm having fun watching you two talk."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x35,
            "expr_id": 0x2,
            "msg_id": 0x1c,
            "msg_string": "But why are you saying such harsh things,<CR>Juris?"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x110,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "Well...it's not something I'd like to admit, but I'm a non-drinker. I can't drink a single drop of alcohol."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Huh? But you're the owner of this tavern!"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x111,
            "expr_id": 0x4,
            "msg_id": 0x1f,
            "msg_string": "Haha, isn't that funny? I wanted to own my own tavern, so I studied like crazy."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x113,
            "expr_id": 0x4,
            "msg_id": 0x20,
            "msg_string": "But Juris is so cold to me.<CR>Ayesha, please give me some praise..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x21,
            "msg_string": "Mix Master, I feel so bad for you..."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Ayesha, let me give you one piece of advice. There's no need for you to care for him."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "The more you care about him, the more he'll get carried away."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10f,
            "expr_id": 0x4,
            "msg_id": 0x24,
            "msg_string": "Whoa, what an awful thing to say.<CR>Fine then, you've scarred me enough."
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x10e,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "I'll have Ayesha praise me the next time you're not around."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Should I...praise him?"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "You should decide that based on the conversation we just had."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x15b,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "I personally don't think you should."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "Umm, but, now I know that you two are very good friends..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "Guy friendships are kinda nice!"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xa2,
            "expr_id": 0x3,
            "msg_id": 0x2b,
            "msg_string": "Hmm, but I'd rather be with a girl..."
        }
    ]
}