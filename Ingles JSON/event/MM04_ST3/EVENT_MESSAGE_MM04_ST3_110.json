{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM04_ST3_110.ebm",
    "nb_messages": 0x27,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Nio!"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, Sis, you came."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "I kinda had a feeling I'd be seeing you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "The slags are very docile. They seem to like flowers..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "It looks like they like the smell of flowers. They communicate through odors."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Plus, they're the ones who led me here."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "They look kinda like the slags that are always running amuck in the ruins..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "But they sure don't act like them at all."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "They're actually all calm and sweet."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "It's just that they've been neglected and they're all just lonely."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "For me, I have you to come visit me every once in a while."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "But they don't have anyone. And they haven't for a long time...for like hundreds of years."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I know I couldn't bear that..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Do you like these flowers, too?"
        },
        {
            "type": 0x4,
            "voice_id": 0x223,
            "name_id": 0x53,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "Vur..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "It smells nice. Can I please take one?"
        },
        {
            "type": 0x4,
            "voice_id": 0x223,
            "name_id": 0x53,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "Vur?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Sorry, but I only need one. Is that okay?"
        },
        {
            "type": 0x4,
            "voice_id": 0x223,
            "name_id": 0x53,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Vur!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "...Huh? Is something wrong?"
        },
        {
            "type": 0x4,
            "voice_id": 0x223,
            "name_id": 0x53,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "unknown2": 0x1,
            "msg_string": "..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1d5,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Whewww...I'm starting to get tired..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Oh, right. I guess I should start heading back now, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "I'll see you again, right?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd0,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "...I don't know."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Huh?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x1b,
            "msg_string": "It feels like it's been getting harder to come out here lately."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x1c,
            "msg_string": "I've been sleeping much longer, and even when I am awake, it doesn't take long before I get sleepy again..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd1,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "And when I'm sleeping, it feels like I'm being pulled somewhere..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0xd2,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "So I've been trying to stay awake for as long as I can, but I can't help it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Nio..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Sis, thanks for today. I'm really happy I got to talk to you."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "See you..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "msg_string": "..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x23,
            "msg_string": "Nio seems a little different from before..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc5,
            "expr_id": 0x4,
            "msg_id": 0x24,
            "msg_string": "Could she really be running out of time...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "I can't take it easy anymore.<CR>I need to rescue her...!"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You got Darkness Petals."
        }
    ]
}