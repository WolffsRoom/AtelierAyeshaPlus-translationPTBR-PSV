            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Oh, and I also got that mysterious vessel from Mr. Keith, too..."
