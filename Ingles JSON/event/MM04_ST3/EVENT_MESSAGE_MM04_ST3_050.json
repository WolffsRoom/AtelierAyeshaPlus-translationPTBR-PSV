        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0x5,
            "msg_id": 0x4,
            "msg_string": "Maybe I should go over what I've done. Umm...so far, I've collected..."
