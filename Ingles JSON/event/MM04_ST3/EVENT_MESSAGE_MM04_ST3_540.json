            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Well, these flowers bloomed in<CR>Dry Valley, so I came to take a look."
