        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x124,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "So, could these really be the vengeful ghosts that Marion was talking about? *shiver*"
