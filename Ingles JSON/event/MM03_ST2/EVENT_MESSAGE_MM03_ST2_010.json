        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x78,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "No, no, that doesn't matter right now. Nio!"
