{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM03_ST2_070.ebm",
    "nb_messages": 0x21,
    "messages": [
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "unknown2": 0x1,
            "msg_string": "I'm gonna read the book Mr. Keith recommended to me."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "unknown2": 0x1,
            "msg_string": "\"Due to recent research, many plants and animals that were considered to be mere legend have been rediscovered.\""
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "\"This book will introduce you to the study of flowers that contain unknown properties.\""
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "unknown2": 0x1,
            "msg_string": "Legendary flowers...? Maybe it'll have the flowers from the ruins..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "unknown2": 0x1,
            "msg_string": "Alrighty then, I'm gonna read this whole book start to finish."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "unknown2": 0x1,
            "msg_string": "Let's see, this is..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "unknown2": 0x1,
            "msg_string": "Uh-huh, uh-huh, I see..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "unknown2": 0x1,
            "msg_string": "Whew...I still have a long way to go."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "Oh, this is the glass flower that bloomed in the Glass Factory! Let's see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "unknown2": 0x1,
            "msg_string": "\"...a plant that absorbs silicon from the ground and blossoms with a glass-like flower...\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "\"It may be possible to utilize and apply this property to create a living building material...\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "\"An experiment to construct a three-story building from the biogenic substance of this flower was a success.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "\"There are still more tasks to be done, but the synthesis of a living building material was successful.\""
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "Whoa... Alchemy is amazing..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "I can do a little synthesis, but nothing like these people..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "It seems like I'm a little different from an alchemist after all..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "Riesengang spring water... Hey, this book is talking about the area near my workshop!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "Maybe it'll have something about the flowers in the ruin... Let's see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc4,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "*yawn* I stayed up all night...<CR>I can't keep my eyes open..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc6,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I should take a break and make some tea."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "This book didn't have any clues to lead me to Nio."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Mr. Keith, what am I supposed to do now...?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Even if I asked him, he probably wouldn't tell me."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "It might be good to start by investigating the mysterious flowers that grow around here..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x19,
            "msg_string": "The book has a flower that waits for rain, one that blooms every 100 years, and one that doesn't bloom in the sun."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x1a,
            "msg_string": "Of these three...the flower that waits for rain must be near my workshop..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0x1b,
            "msg_string": "It even says it's near Riesengang."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15d,
            "expr_id": 0x5,
            "msg_id": 0x1c,
            "msg_string": "I wonder where the other two are..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0x5,
            "msg_id": 0x1d,
            "msg_string": "The flower that blooms every 100 years is at the end of an endless meadow..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15f,
            "expr_id": 0x5,
            "msg_id": 0x1e,
            "msg_string": "And the flower that doesn't bloom in the sun is along the shore of a big sea. Hmm...they don't seem very local..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "I guess I'll have to go to different places and gradually gather more information."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x20,
            "msg_string": "Yup! There's no use just scratching my head. I can do this! Yeah!"
        }
    ]
}