{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM03_ST2_520.ebm",
    "nb_messages": 0xc,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, there she is. Bell, I wanna ask you something."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hm? Okay, what is it?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "You know how you gave me that alchemy book? Well, that book had a lot of really good information in it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "But, I finished reading it already. Would you happen to have any other alchemy books?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, yeah, that one. Uhh, I only had that one alchemy book."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I'm a witch, so I don't have much need for books on alchemy."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I see. The book did seem like it was valuable..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "But I got that book in town. Yeah, that weird pencil 'stache guy‐"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0x8,
            "msg_string": "Weird pencil 'stache guy...? Are you talking about Mr. Harry?"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yeah, yeah. He forced it on me, saying something about it deepening one's understanding of ancient civilization."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Maybe that guy has other books..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15b,
            "expr_id": 0x5,
            "msg_id": 0xb,
            "msg_string": "Mr. Harry... Yeah, I should probably go ask him."
        }
    ]
}