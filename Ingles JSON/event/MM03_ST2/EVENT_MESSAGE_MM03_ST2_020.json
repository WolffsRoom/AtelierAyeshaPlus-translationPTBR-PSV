        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xca,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "I...think so, too. There's gotta be a way to help her..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I remember him saying...that investigating the flowers was also a key."
