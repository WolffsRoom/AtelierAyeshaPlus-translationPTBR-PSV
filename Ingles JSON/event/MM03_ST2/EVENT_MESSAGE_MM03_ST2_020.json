    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, what are those? They're sparkling."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Glass flowers...? They're so pretty...!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "So, are these the glowing flowers that you were talking about? The ones that bloom in ruins? They are pretty..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I've been to different ruins, but I've never seen anything like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "These glass flowers are a first for me, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Look at them...they're not fake,<CR>they're actually alive!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Whoa, you're right!<CR>They smell nice, too."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Hmhmhm, I'm glad I'm a prospector. Otherwise, I never woulda seen such mysterious flowers."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x195,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Yeah. There were some mysterious glowing flowers where Nio disappeared as well..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Nio... I miss her..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x122,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "Wh-What is this? Ayesha, be carefu‐"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "Th-That's...Nio!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x126,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "What's going on!? I've...never seen anything like this."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7a,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "Nio, wake up! It's me, your sister, Ayesha!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Come home with me. Everyone's waiting for you!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Oh..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x128,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "She disappeared..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xc7,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "msg_string": "..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x165,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "H-Hey! I know I don't know anything about this kinda thing, but..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x166,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I really think Nio is still alive!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x166,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Like with what just happened. It felt totally different than just some kinda illusion."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x167,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "So, I'm sure there's a way to help her!"
