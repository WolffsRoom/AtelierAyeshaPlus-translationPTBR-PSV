{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS05_040.ebm",
    "nb_messages": 0x35,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Continuing on, I'd now like to introduce all the judges!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1e3,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "First is Mr. Harry Olson, whose<CR>privilege for being the organizer<CR>allows him to serve as a judge!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x59,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Hahaha! People, I expect to see an item that'll surpass mine! Although, I'm sure that's a tall order!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Okay...how childish! And please allow me, the host, to be a judge, as well!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Items that'll sell in the store...I mean, I'll be looking forward to all the wonderful items!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x21,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hello everyone! Please don't expect any leniency in the evaluations, like last time! My evaluations will be strict!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Oh, what's this!? What is Mr. Harry trying to say!?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I, who will also be acting as a judge, can't hide my surprise! But we have no time to waste, so continuing on...!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x21,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Let me first say this! For today, I brought my finest item. I can't lose!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x129,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "This is a surprise! Continuing from<CR>his earlier statement, I've never<CR>seen Mr. Harry this serious!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x12b,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "As a judge, I'll exert my power fairly and faithfully! You can count on me!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x1,
            "msg_string": "Now, our next judge is an official who tediously carries out her duties throughout the region, Ms. Marion!"
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "*ahem* I'll be giving strict evaluations, so be ready!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x1,
            "msg_string": "Next is the baker who delivers deliciousness to the dining tables of Vierzeberg, Mr. Fred!"
        },
        {
            "type": 0x1,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x42,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "Hey! I'll be looking forward to seeing if I can get any new ideas for new bread recipes!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x1,
            "msg_string": "Next is the man who opened a tavern to help travelers rest and unwind in Hornheim, Mr. Kyle, the Mix Master!"
        },
        {
            "type": 0x1,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1a1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Hey! I'm gonna be the cool judge,<CR>so look forward to me!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x1,
            "msg_string": "Our next judge travels to various<CR>places as a peddler, the good-natured Mr. Ernie!"
        },
        {
            "type": 0x1,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x62,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Hello! I'm excited to see what kinds of items are gonna be presented. Good luck, everyone!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x1,
            "msg_string": "Next it's time to introduce everyone's favorite cowgirl, Nanaca!"
        },
        {
            "type": 0x1,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x193,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Hello, my name is Nanaca. I'll do my best at being a judge!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a6,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Okay, that concludes the judge introductions! Everyone, please put all your might into your judging!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "Now, I'd like to go ahead and start the contest! Contestants, please get ready for your turn!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Looks like it's starting. I need to decide which item to exhibit."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15e,
            "expr_id": 0x5,
            "msg_id": 0x18,
            "msg_string": "I need to try my best and choose<CR>something the judges might like.<CR>Let's see..."
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "unknown2": 0x1,
            "msg_string": "Which item should I exhibit?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1a,
            "unknown2": 0x1,
            "msg_string": "Is this okay?"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "unknown2": 0x1,
            "msg_string": "Yup, this is the one!<CR>Okay, let's do this!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "unknown2": 0x1,
            "msg_string": "I would now like to start our contest! First contestant, come on down!"
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "unknown2": 0x1,
            "msg_string": "Well, this item comes with my highest recommendation! I'm convinced that there are no other items like it in the world!"
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "unknown2": 0x1,
            "msg_string": "Well, I'll show you a special item!<CR>Of course, every item in my<CR>collection is priceless."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "unknown2": 0x1,
            "msg_string": "However, the item I'm about to show you is a keen item that may have left its name in a past generation!"
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "unknown2": 0x1,
            "msg_string": "That's correct, you all are about to<CR>become living witnesses of history,<CR>for this..."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "unknown2": 0x1,
            "msg_string": "Okay, okay! There's no end to this, so let's just stop it right there! Thank you so much!"
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "unknown2": 0x1,
            "msg_string": "Hello everyone! Before I bring out my entry, there's something I have to apologize for!"
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "unknown2": 0x1,
            "msg_string": "Although I've organized this contest numerous times, I still have yet to present my best item."
        },
        {
            "type": 0x4,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x24,
            "unknown2": 0x1,
            "msg_string": "With this ultimate item, I'm willing to stake my career as a collector on it winning! Feel it with all your soul!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "unknown2": 0x1,
            "msg_string": "...He continued his passionate spiel without even giving me a moment to stop him! Thank you very much!"
        },
        {
            "type": 0x4,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x26,
            "unknown2": 0x1,
            "msg_string": "Okay, okay, this is the one I'm presenting. Please take a look at my finest of fine items."
        },
        {
            "type": 0x4,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x27,
            "unknown2": 0x1,
            "msg_string": "Hmhm, it's as if my victory has already been decided. Take a look and be wowed!"
        },
        {
            "type": 0x4,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x28,
            "unknown2": 0x1,
            "msg_string": "This is my item. I found it by chance while I was hunting, but I think it's a rare item."
        },
        {
            "type": 0x4,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x29,
            "unknown2": 0x1,
            "msg_string": "This is the item I decided on, after multiple examinations and inspections. Please judge it well."
        },
        {
            "type": 0x4,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2a,
            "unknown2": 0x1,
            "msg_string": "It's completely worthless for me, but... It'll do for the people here."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x2b,
            "unknown2": 0x1,
            "msg_string": "Okay then, judges, please assess these items carefully."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2c,
            "unknown2": 0x1,
            "msg_string": "Start your assessments...now!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2d,
            "unknown2": 0x1,
            "msg_string": "Okay, time's up!<CR>That's it for the assessments!<CR>Next person, please come on down!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2e,
            "unknown2": 0x1,
            "msg_string": "XXX"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2f,
            "unknown2": 0x1,
            "msg_string": "Now for the final exhibitor!<CR>Ayesha, please come on down!"
        },
        {
            "type": 0x4,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x30,
            "unknown2": 0x1,
            "msg_string": "O-Okay! Thank you for having me!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x31,
            "unknown2": 0x1,
            "msg_string": "Now, what will the results be!? Let the assessments start!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x32,
            "unknown2": 0x1,
            "msg_string": "Okay, time's up! That's it for the assessments!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x33,
            "unknown2": 0x1,
            "msg_string": "That concludes all the assessments for all the contestants!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x34,
            "unknown2": 0x1,
            "msg_string": "Please wait while we tally the results!"
        }
    ]
}