{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS05_030.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Now, before we get to the competition, let's meet all of our exhibitors!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1e3,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "Everyone, please give us a short introduction!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x1,
            "msg_string": "First up is our organizer who was just introduced, Mr. Harry Olson! Please keep it short!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x56,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "Why hello! I hope you're all having fun. I shall show you all my collection!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x56,
            "expr_id": 0x2,
            "msg_id": 0x4,
            "msg_string": "Hahaha! I may have been defeated before, but I won't go down that easy this time! Brace yourselves!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Okay, Mr. Harry seems to be burning up with passion! But since I see no end to this, I'd like to continue on!"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "extra_id": 0x56,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "I won't hold back anymore... To reclaim my championship, I'll knock Ayesha down to the ground with all my might!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "After repeated defeats, he finally made a personal declaration of war! Is this a hint that violence is in store for us!?"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x1,
            "msg_string": "Next is Regina, who has taken part in this contest every time!"
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x199,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yes, hello! Well, like always, let's take it easy."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x1,
            "msg_string": "Up next is the self-proclaimed<CR>\"great witch\"! Ms. Wilbell!"
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Hehehe, I'll earn the win with a secret item that's passed down among witches!"
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x1,
            "msg_string": "Our next exhibitor is the hunky huntsman whose sole love is hunting, Mr. Juris!"
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x19e,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I don't know how I got here, but I'm ready to go. Thanks for having me."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x1,
            "msg_string": "Our next exhibitor came from a faraway land, and works as a bodyguard, Ms. Linca!"
        },
        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "I am not sure what this is all about, but battling is my forte. I will win."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x1,
            "msg_string": "Our next exhibitor is the wandering alchemist, Mr. Keith! Can we have a few words, please!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x13,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Whether any item will be on par with mine...I shall enjoy this without any expectations."
        },
        {
            "type": 0x4,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x1,
            "msg_string": "And, here's our final exhibitor!<CR>Ms. Ayesha!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Y-Yes! Umm, so well...I-I'll do my best!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1a6,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Okay, thank you very much! I'm so excited to see what kinds of items will be shown!"
        }
    ]
}