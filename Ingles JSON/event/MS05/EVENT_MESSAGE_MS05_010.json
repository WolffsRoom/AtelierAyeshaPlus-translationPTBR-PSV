            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "For the duration of the contest,<CR>you're more than welcome to join<CR>whenever you want."
