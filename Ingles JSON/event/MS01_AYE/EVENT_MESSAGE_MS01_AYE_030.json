        {
            "type": 0x1,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Right. Dozing off in the early afternoon is hard to resist, whoever it may be."
