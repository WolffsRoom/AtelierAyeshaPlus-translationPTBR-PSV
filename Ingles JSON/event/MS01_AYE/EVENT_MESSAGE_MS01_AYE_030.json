        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x196,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Hmm, let's let her be. The sun's still high, and this place is safe."
