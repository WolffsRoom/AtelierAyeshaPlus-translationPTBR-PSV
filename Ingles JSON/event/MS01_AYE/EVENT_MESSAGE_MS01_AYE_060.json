{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS01_AYE_060.ebm",
    "nb_messages": 0x4b,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ayesha, you're here? I have a delivery!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, okay! Thank you."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "For me, huh? I wonder what it is..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15a,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Whoa, did you forget your own birthday? It looks like a present."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x15d,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Since you were gone, I kept it till you got back, but I wonder what's inside..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x160,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "If it's food, share it with me!?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Haha, okay, we'll share it."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "This is so exciting! I wonder who it's from..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x26,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Here. It's from an energetic girl with a pointy hat."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "From Bell? Oh, there's a letter attached."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1aa,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Okay, let's see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "\"Happy birthday.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "\"Thank you for always putting up with my selfishness.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "\"Please be my friend from now until foreeever.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "\"I worked really hard to pick out your present. I hope it pleases you.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "\"I'm looking forward to spending more time with you. Sincerely, Wilbell.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Bell...thank you. I'll be looking forward to that, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Hehehe, Bell wrote such polite sentences in the letter... She's like a completely different person."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Thank you for the present. I'll take good care of it."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x26,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Here, it's from Regina."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a3,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "From Regina? Oh, there's a letter attached."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1aa,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Okay, let's see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "\"Thank you for helping me with my last job.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "\"I still had some cloth left over, so I made this during my free time.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "\"I hope you like it.<CR>Happy birthday, Ayesha!\""
        },
        {
            "type": 0x1,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "\"It may be small, but let's celebrate. Sincerely, Regina.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1ac,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Thank you, Regina. I appreciate all you've done for me, as well."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "I wonder what's inside...<CR>Regina's so good at needlework."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x26,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Here. It's from that weird duo that I see around town a lot."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a3,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "From Marion and Linca? Oh, there's a letter attached."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1aa,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Okay, let's see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "\"Ayesha, thank you for always being nice to Linca.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "\"Please let us send you a birthday present to express our gratitude.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "\"We'll see you around.<CR>Marion & Linca.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Thank you Marion and Linca."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Hehe, I wonder if they picked out this gift together..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x26,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Here. It's from a fella with a nice body. He wouldn't by any chance be your \"special\" friend, would he?"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a3,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "O-Of course not. Umm, I guess it's from Juris."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1aa,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Oh, there's a letter attached."
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x27,
            "msg_string": "\"Ayesha, happy birthday. Thanks for the help with that dragon.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x28,
            "msg_string": "\"I heard from Nanaca that it was your birthday.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x29,
            "msg_string": "\"It's a special day, so I thought I should send you something.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x2a,
            "msg_string": "\"I've never given a gift to a girl before, so I'm not confident that you'll like it.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x2b,
            "msg_string": "\"But, I'd like for you to accept it. I'll be counting on you from now on, as well.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x2c,
            "msg_string": "Juris, I didn't expect you to actually be sensible about something like this..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x2d,
            "msg_string": "But, thank you so much!<CR>I'll definitely use it!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x26,
            "expr_id": 0x0,
            "msg_id": 0x2e,
            "msg_string": "Here. It's from that ruggedly handsome customer I told you about! You're so lucky, Ayesha. I mean, sooo lucky!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a3,
            "expr_id": 0x0,
            "msg_id": 0x2f,
            "msg_string": "I didn't know Mr. Keith struck your fancy so much."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x30,
            "msg_string": "That's right. You won't find such a cool and rugged gentleman anywhere else."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x31,
            "msg_string": "Introduce me to him next time, please!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x32,
            "msg_string": "Hahaha, I will, the next time I get the chance... Oh, there's a letter attached."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1aa,
            "expr_id": 0x0,
            "msg_id": 0x33,
            "msg_string": "Okay, let's see..."
        },
        {
            "type": 0x1,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x34,
            "msg_string": "\"I shall give this to you.<CR>Keith.\""
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x35,
            "msg_string": "What? That's it? It doesn't feel anything like a birthday card..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0x0,
            "msg_id": 0x36,
            "msg_string": "But, thank you very much, Mr. Keith."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x69,
            "expr_id": 0x2,
            "msg_id": 0x37,
            "msg_string": "It's from a little girl who claimed to be your sister."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x38,
            "msg_string": "Huh? Do you mean...Nio?"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x39,
            "msg_string": "Sooo, I heard you found your missing sister."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x3a,
            "msg_string": "I've been wanting to meet her and have a little chat."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3b,
            "msg_string": "Oh, that's right. You and Nio never actually met before...."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3c,
            "msg_string": "Sorry, I'll bring her to the shop next time."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6a,
            "expr_id": 0x2,
            "msg_id": 0x3d,
            "msg_string": "Please do!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3e,
            "msg_string": "Even so, Nio could've just given it to me in person..."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x3f,
            "msg_string": "Haha, she must've been embarrassed. Especially because you two are always together."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0x40,
            "msg_string": "Okay, and here's a belated present from me!"
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2e,
            "expr_id": 0x0,
            "msg_id": 0x41,
            "msg_string": "I mean, I'd be in an awkward position if that was all you got."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x42,
            "msg_string": "That's not true! You didn't have to worry about that."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2e,
            "expr_id": 0x0,
            "msg_id": 0x43,
            "msg_string": "Now, now, you've helped me here and there, so let me take you out for dinner or something."
        },
        {
            "type": 0x1,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2e,
            "expr_id": 0x0,
            "msg_id": 0x44,
            "msg_string": "I know this really good place. Let's go eat there today, okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You got a Floral Staff."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You got Fur Gloves."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You got a Chain Shirt."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You got Cryptid Fur."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You got Himmel Schenk x3."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0xffffffff,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You got Royal Baguette x3."
        }
    ]
}