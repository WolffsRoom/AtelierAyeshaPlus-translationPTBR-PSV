{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS01_AYE_090.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hey Sis, I've been able to walk around town extra proudly lately."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, why's that? Did something good happen?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "No, it's about you. Don't you know?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "People in town have been raving about how amazing you are."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Whaaat? I didn't know that."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Goodness, you're so slow as always."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15e,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Mr. Harry has been going around calling you \"Master Ayesha\" recently."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "And everyone in town's been saying that if you have a problem, go talk to you first."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x15f,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "That's the word on the street."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x161,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Even Mr. Keith...oh, he's gonna get mad at me if I say this..."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15a,
            "expr_id": 0x5,
            "msg_id": 0xa,
            "msg_string": "D-Don't stop now. What did Mr. Keith say?"
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x13e,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "It's a secret! But he was praising you..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Oh, but Ernie was worried about you. He's afraid you might overwork yourself and collapse."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "And other people around town were saying, \"Ayesha is amazing,\" too!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x15c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I didn't even know..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "With the talk, you're a celebrity now!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x38,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Celebrity...? I can't do that..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Hehehe, why not? I'm totally happy..."
        },
        {
            "type": 0x1,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x40,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Cuz everyone is praising my sister."
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "msg_string": "(Wh-What should I do? I didn't know so many people were talking about me...)"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "(I'm getting nervous about walking down the street. I need to make sure I don't move my right hand and foot in synch.)"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Master Ayesha? Is Master Ayesha home?"
        },
        {
            "type": 0x1,
            "voice_id": 0xd,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Hellllooo, Master Ayesha!"
        },
        {
            "type": 0x1,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x76,
            "expr_id": 0x3,
            "msg_id": 0x17,
            "msg_string": "Ahhh! Stooop!"
        }
    ]
}